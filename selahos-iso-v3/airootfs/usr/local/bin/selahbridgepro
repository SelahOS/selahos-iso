        right = QVBoxLayout()
        right.setSpacing(10)

        detail = QFrame()
        detail.setObjectName("card")
        detail.setMinimumHeight(130)
        dl = QGridLayout(detail)
        dl.setContentsMargins(14, 12, 14, 12)
        dl.setSpacing(6)
        dl.setColumnMinimumWidth(0, 80)
        dl.addWidget(_label("Name:",   C["muted"], size=11), 0, 0)
        dl.addWidget(_label("Exe:",    C["muted"], size=11), 1, 0)
        dl.addWidget(_label("Prefix:", C["muted"], size=11), 2, 0)
        dl.addWidget(_label("Type:",   C["muted"], size=11), 3, 0)
        self.det_name   = _label("—", C["parch"])
        self.det_exe    = _label("—", C["muted"], size=11)
        self.det_prefix = _label("—", C["parch"])
        self.det_type   = _label("—", C["teal"])
        self.det_exe.setWordWrap(True)
        for row, lbl in enumerate(
                (self.det_name, self.det_exe, self.det_prefix, self.det_type)):
            dl.addWidget(lbl, row, 1)
        right.addWidget(detail)

        action_row = QHBoxLayout()
        self.btn_launch   = QPushButton("Launch")
        self.btn_launch.setObjectName("launch")
        self.btn_launch.setFixedHeight(36)
        self.btn_viewlog  = QPushButton("View Log")
        self.btn_viewlog.setObjectName("secondary")
        self.btn_viewlog.setFixedHeight(36)
        action_row.addWidget(self.btn_launch)
        action_row.addWidget(self.btn_viewlog)
        action_row.addStretch()
        right.addLayout(action_row)

        right.addWidget(_label("Launch Output", C["muted"], size=11))
        self.log = _log_panel()
        right.addWidget(self.log, stretch=1)

        self.status_lbl = _label("Select an app to launch.", C["muted"], size=11)
        right.addWidget(self.status_lbl)

        body.addLayout(right, stretch=1)
        root.addLayout(body, stretch=1)

        self.btn_add.clicked.connect(self._add_app)
        self.btn_remove.clicked.connect(self._remove_app)
        self.btn_launch.clicked.connect(self._launch_app)
        self.btn_viewlog.clicked.connect(self._view_log)
        self.app_list.currentRowChanged.connect(self._on_selection)

        self._apps: list = []
        self._refresh_list()

    def _refresh_list(self):
        self._apps = _load_apps()
        self.app_list.clear()
        for app in self._apps:
            item = QListWidgetItem(f"  {app['name']}")
            item.setForeground(__import__("PyQt6.QtGui", fromlist=["QColor"]).QColor(C["parch"]))
            self.app_list.addItem(item)
        self._on_selection(self.app_list.currentRow())

    def _on_selection(self, row: int):
        if 0 <= row < len(self._apps):
            app = self._apps[row]
            self.det_name.setText(app["name"])
            self.det_exe.setText(app["exe"])
            self.det_prefix.setText(app.get("prefix", "apps"))
            self.det_type.setText("Electron app" if app.get("electron") else "Win32 app")
            self.btn_launch.setEnabled(True)
            self.btn_remove.setEnabled(True)
            self.btn_viewlog.setEnabled(True)
        else:
            self.det_name.setText("—")
            self.det_exe.setText("—")
            self.det_prefix.setText("—")
            self.det_type.setText("—")
            self.btn_launch.setEnabled(False)
            self.btn_remove.setEnabled(False)
            self.btn_viewlog.setEnabled(False)

    def _add_app(self):
        dlg = AddAppDialog(self.window())
        if dlg.exec() == QDialog.DialogCode.Accepted:
            app = dlg.result_app()
            if app:
                self._apps.append(app)
                _save_apps(self._apps)
                self._refresh_list()
                self.app_list.setCurrentRow(len(self._apps) - 1)

    def _remove_app(self):
        row = self.app_list.currentRow()
        if row < 0:
            return
        name = self._apps[row]["name"]
        reply = QMessageBox.question(
            self, "Remove App",
            f"Remove '{name}' from SelahBridgePro?\n(The app itself is not uninstalled.)",
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No)
        if reply == QMessageBox.StandardButton.Yes:
            self._apps.pop(row)
            _save_apps(self._apps)
            self._refresh_list()

    def _launch_app(self):
        row = self.app_list.currentRow()
        if row < 0:
            return
        app = self._apps[row]
        cmd = [
            "selahbridge-winapp",
            "--name",   app["name"],
            "--prefix", app.get("prefix", "apps"),
            app["exe"],
        ]
        self.status_lbl.setText(f"Launching {app['name']}…")
        _log_append(self.log, f"→ {' '.join(cmd)}")
        subprocess.Popen(cmd)
        _log_append(self.log, f"✓  {app['name']} launched — log: "
                    f"/var/log/selahbridgepro/winapp-{app['name'].replace(' ', '-')}.log")

    def _view_log(self):
        row = self.app_list.currentRow()
        if row < 0:
            return
        app    = self._apps[row]
        slug   = app["name"].replace(" ", "-")
        log_f  = WINAPP_LOG_DIR / f"winapp-{slug}.log"
        alt_f  = Path(f"/tmp/winapp-{slug}.log")
        target = log_f if log_f.exists() else (alt_f if alt_f.exists() else None)
        if target:
            try:
                text = target.read_text(errors="replace")
                lines = text.splitlines()[-120:]
                self.log.setPlainText("\n".join(lines))
                self.log.verticalScrollBar().setValue(
                    self.log.verticalScrollBar().maximum())
                self.status_lbl.setText(f"Log: {target}")
            except OSError as e:
                self.status_lbl.setText(f"✗ Could not read log: {e}")
        else:
            self.status_lbl.setText("No log yet — launch the app first.")


class LicenseTab(QWidget):
    def __init__(self):
        super().__init__()
        root = QVBoxLayout(self)
        root.setContentsMargins(28, 24, 28, 24)
        root.setSpacing(16)

        root.addWidget(_label("License & Activation", C["gold"], bold=True, size=15))
        root.addWidget(_divider())

        # Status card
        self.status_frame = QFrame()
        self.status_frame.setObjectName("card")
        sf_lay = QVBoxLayout(self.status_frame)
        sf_lay.setContentsMargins(18, 14, 18, 14)
        sf_lay.setSpacing(6)
        self.status_lbl  = _label("Checking…", C["muted"], size=13)
        self.detail_lbl  = _label("", C["muted"], size=12)
        sf_lay.addWidget(self.status_lbl)
        sf_lay.addWidget(self.detail_lbl)
        root.addWidget(self.status_frame)

        # Machine ID
        mid_row = QHBoxLayout()
        mid_row.addWidget(_label("Machine ID:", C["muted"]))
        self.mid_lbl = QLineEdit(_machine_id())
        self.mid_lbl.setReadOnly(True)
        self.mid_lbl.setFixedWidth(320)
        mid_row.addWidget(self.mid_lbl)
        btn_copy = QPushButton("Copy")
        btn_copy.setObjectName("secondary")
        btn_copy.setFixedWidth(80)
        btn_copy.clicked.connect(lambda: QApplication.clipboard().setText(self.mid_lbl.text()))
        mid_row.addWidget(btn_copy)
        mid_row.addStretch()
        root.addLayout(mid_row)
        root.addWidget(_label(
            f"Send your Machine ID to {SUPPORT} to receive a license key.",
            C["muted"], size=11))

        root.addWidget(_divider())

        # Activation
        root.addWidget(_label("Activate with License Key", C["parch"], size=13))
        key_row = QHBoxLayout()
        self.key_input = QLineEdit()
        self.key_input.setPlaceholderText("SELAHPRO-XXXX-XXXX-XXXX-XXXX")
        self.key_input.setFixedWidth(320)
        key_row.addWidget(self.key_input)
        self.btn_activate = QPushButton("Activate")
        self.btn_activate.setFixedWidth(120)
        self.btn_activate.clicked.connect(self._activate)
        key_row.addWidget(self.btn_activate)
        key_row.addStretch()
        root.addLayout(key_row)
        self.act_result = _label("", C["muted"], size=12)
        root.addWidget(self.act_result)

        root.addStretch()
        self._refresh_status()

    def _refresh_status(self):
        status, detail = _license_status()
        labels = {
            "licensed":   ("●  Licensed",      C["teal"]),
            "trial":      ("●  Trial Active",   C["gold"]),
            "expired":    ("●  Trial Expired",  C["red"]),
            "notstarted": ("●  Not Started",    C["muted"]),
        }
        lbl, color = labels.get(status, ("●  Unknown", C["muted"]))
        self.status_lbl.setText(lbl)
        self.status_lbl.setStyleSheet(f"color: {color}; font-size: 13px;")
        self.detail_lbl.setText(detail)

    def _activate(self):
        key = self.key_input.text().strip().upper()
        mid = _machine_id()
        expected = _expected_key(mid)
        if key == expected:
            LIC_DIR.mkdir(parents=True, exist_ok=True)
            LIC_FILE.write_text(key)
            os.chmod(LIC_FILE, 0o600)
            self.act_result.setText("✓  Activated successfully!")
            self.act_result.setStyleSheet(f"color: {C['teal']}; font-size: 12px;")
            self._refresh_status()
        else:
            self.act_result.setText("✗  Invalid key for this machine.")
            self.act_result.setStyleSheet(f"color: {C['red']}; font-size: 12px;")


