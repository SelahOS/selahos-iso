        self._worker.start()


APPS_REGISTRY = Path.home() / ".config" / "selahbridgepro" / "apps.json"
WINAPP_LOG_DIR = Path("/var/log/selahbridgepro")


def _load_apps() -> list:
    try:
        return json.loads(APPS_REGISTRY.read_text()) if APPS_REGISTRY.exists() else []
    except (json.JSONDecodeError, OSError):
        return []


def _save_apps(apps: list):
    APPS_REGISTRY.parent.mkdir(parents=True, exist_ok=True)
    APPS_REGISTRY.write_text(json.dumps(apps, indent=2))


def _detect_electron(exe_path: str) -> bool:
    app_dir = Path(exe_path).parent
    markers = [
        app_dir / "resources" / "app.asar",
        app_dir / "resources" / "electron.asar",
        app_dir / "LICENSES.chromium.html",
    ]
    if any(m.exists() for m in markers):
        return True
    resources = app_dir / "resources"
    if resources.is_dir() and any(resources.glob("*.asar")):
        return True
    return False


class AddAppDialog(QDialog):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.setWindowTitle("Add Windows App")
        self.setMinimumWidth(520)
        self.setStyleSheet(parent.styleSheet() if parent else "")

        layout = QVBoxLayout(self)
        layout.setSpacing(14)
        layout.setContentsMargins(20, 20, 20, 20)

        layout.addWidget(_label("Add Windows App", C["gold"], bold=True, size=14))
        layout.addWidget(_divider())

        grid = QGridLayout()
        grid.setSpacing(10)
        grid.setColumnMinimumWidth(0, 90)

        grid.addWidget(_label("Name:", C["muted"]), 0, 0)
        self.name_edit = QLineEdit()
        self.name_edit.setPlaceholderText("e.g. Spark Desktop")
        grid.addWidget(self.name_edit, 0, 1, 1, 2)

        grid.addWidget(_label(".exe Path:", C["muted"]), 1, 0)
        self.exe_edit = QLineEdit()
        self.exe_edit.setPlaceholderText("/home/user/.wine-selah-apps/drive_c/…/App.exe")
        grid.addWidget(self.exe_edit, 1, 1)
        btn_browse = QPushButton("Browse…")
        btn_browse.setObjectName("secondary")
        btn_browse.setFixedWidth(80)
        btn_browse.clicked.connect(self._browse)
        grid.addWidget(btn_browse, 1, 2)

        grid.addWidget(_label("Prefix:", C["muted"]), 2, 0)
        self.prefix_edit = QLineEdit()
        self.prefix_edit.setPlaceholderText("apps")
        self.prefix_edit.setText("apps")
        grid.addWidget(self.prefix_edit, 2, 1, 1, 2)

        self.electron_check = QCheckBox("Electron app (auto-detected)")
        self.electron_check.setStyleSheet(f"color: {C['parch']};")
        grid.addWidget(self.electron_check, 3, 1, 1, 2)

        layout.addLayout(grid)

        self.detect_lbl = _label("", C["muted"], size=11)
        layout.addWidget(self.detect_lbl)

        layout.addWidget(_divider())
        buttons = QDialogButtonBox(
            QDialogButtonBox.StandardButton.Ok | QDialogButtonBox.StandardButton.Cancel)
        buttons.setStyleSheet(f"color: {C['parch']};")
        buttons.accepted.connect(self._on_accept)
        buttons.rejected.connect(self.reject)
        layout.addWidget(buttons)

        self.exe_edit.textChanged.connect(self._on_exe_changed)
        self._result_app: dict | None = None

    def _browse(self):
        start = str(Path.home())
        for candidate in sorted(Path.home().glob(".wine-selah-*/drive_c")):
            start = str(candidate)
            break
        path, _ = QFileDialog.getOpenFileName(
            self, "Select Windows Executable", start,
            "Windows Executables (*.exe);;All Files (*)")
        if path:
            self.exe_edit.setText(path)

    def _on_exe_changed(self, text: str):
        if not text or not Path(text).exists():
            self.detect_lbl.setText("")
            return
        is_e = _detect_electron(text)
        self.electron_check.setChecked(is_e)
        self.detect_lbl.setText(
            f"Detected: {'Electron app' if is_e else 'Standard Win32 app'}")
        if not self.name_edit.text():
            self.name_edit.setText(Path(text).stem.replace("-", " ").replace("_", " ").title())
        if not self.prefix_edit.text() or self.prefix_edit.text() == "apps":
            m = __import__("re").search(r"\.wine-selah-([^/]+)/drive_c", text)
            if m:
                self.prefix_edit.setText(m.group(1))

    def _on_accept(self):
        name = self.name_edit.text().strip()
        exe  = self.exe_edit.text().strip()
        if not name or not exe:
            QMessageBox.warning(self, "Missing fields", "Name and exe path are required.")
            return
        if not Path(exe).exists():
            QMessageBox.warning(self, "Not found", f"File not found:\n{exe}")
            return
        self._result_app = {
            "name":     name,
            "exe":      exe,
            "prefix":   self.prefix_edit.text().strip() or "apps",
            "electron": self.electron_check.isChecked(),
        }
        self.accept()

    def result_app(self) -> dict | None:
        return self._result_app


class WindowsAppsTab(QWidget):
    def __init__(self):
        super().__init__()
        root = QVBoxLayout(self)
