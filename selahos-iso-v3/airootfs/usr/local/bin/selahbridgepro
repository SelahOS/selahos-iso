# License secret loaded at runtime — not stored in source control.
# Deployed to /etc/selahbridgepro/.keydata at ISO build time.
def _load_secret() -> str:
    kf = Path("/etc/selahbridgepro/.keydata")
    try:
        return kf.read_text().strip() if kf.exists() else ""
    except OSError:
        return ""

_SECRET = _load_secret()

