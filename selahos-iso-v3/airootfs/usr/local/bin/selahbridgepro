KNOWN_DAWS = [
    {"key": "flstudio",         "name": "FL Studio",          "ver": "21+",   "profile": "flstudio"},
    {"key": "ableton",          "name": "Ableton Live",       "ver": "11/12", "profile": "ableton"},
    {"key": "reaper",           "name": "REAPER",             "ver": "7+",    "profile": "reaper"},
    {"key": "protools",         "name": "Pro Tools",          "ver": "First", "profile": "protools"},
    {"key": "digitalperformer", "name": "Digital Performer",  "ver": "11.x",  "profile": "digitalperformer"},
]

SAMPLE_RATES   = [44100, 48000, 88200, 96000]
BUFFER_SIZES   = [32, 64, 128, 256, 512, 1024]


# ═══════════════════════════════════════════════════════════════════════════════
#  LICENSE HELPERS (mirrors selahpro logic)
# ═══════════════════════════════════════════════════════════════════════════════

def _machine_id() -> str:
    for p in [Path("/etc/machine-id"), Path("/var/lib/dbus/machine-id")]:
        if p.exists():
            return p.read_text().strip()
    import socket
    return hashlib.sha256(socket.gethostname().encode()).hexdigest()[:32]

def _expected_key(mid: str) -> str:
    raw = hashlib.sha256((mid + _SECRET).encode()).hexdigest()[:16].upper()
    return f"SELAHPRO-{raw[0:4]}-{raw[4:8]}-{raw[8:12]}-{raw[12:16]}"

def _license_status() -> tuple[str, str]:
    """Returns (status_label, detail_string)."""
    mid = _machine_id()
    if LIC_FILE.exists():
        if LIC_FILE.read_text().strip() == _expected_key(mid):
            return ("licensed", "Activated on this machine")
    if TRIAL_FILE.exists():
        try:
            first = datetime.date.fromisoformat(TRIAL_FILE.read_text().strip())
            rem = TRIAL_DAYS - (datetime.date.today() - first).days
            if rem > 0:
                return ("trial", f"{rem} day(s) remaining")
            return ("expired", "Trial expired")
        except ValueError:
            pass
    return ("notstarted", "No trial started yet")


# ═══════════════════════════════════════════════════════════════════════════════
#  BACKGROUND WORKER
# ═══════════════════════════════════════════════════════════════════════════════

class CommandWorker(QThread):
    line_out  = pyqtSignal(str)
    finished  = pyqtSignal(int)

    def __init__(self, cmd: list, env: dict | None = None):
        super().__init__()
        self.cmd = cmd
        self.env = env or os.environ.copy()

    def run(self):
        try:
            proc = subprocess.Popen(
                self.cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                text=True, env=self.env, bufsize=1
            )
            for raw in proc.stdout:
                line = raw.rstrip()
                if line:
                    self.line_out.emit(line)
            proc.wait()
            self.finished.emit(proc.returncode)
        except FileNotFoundError:
            self.line_out.emit(f"✗  Command not found: {self.cmd[0]}")
            self.finished.emit(127)
        except Exception as exc:
            self.line_out.emit(f"✗  {exc}")
            self.finished.emit(1)


# ═══════════════════════════════════════════════════════════════════════════════
#  REUSABLE WIDGETS
# ═══════════════════════════════════════════════════════════════════════════════

def _divider():
    d = QFrame()
    d.setFrameShape(QFrame.Shape.HLine)
    d.setStyleSheet(f"color: {C['border']}; margin: 4px 0;")
    return d

def _label(text, color=None, bold=False, size=None):
    lbl = QLabel(text)
    style = f"color: {color or C['parch']};"
    if bold:
        style += " font-weight: bold;"
    if size:
        style += f" font-size: {size}px;"
    lbl.setStyleSheet(style)
    return lbl

def _log_panel():
    t = QTextEdit()
    t.setReadOnly(True)
    t.setMinimumHeight(200)
    return t

def _log_append(panel: QTextEdit, line: str):
    """Append a line to the log panel with colour based on prefix."""
    line_stripped = line
    # Strip ANSI codes for display
    import re
    line_clean = re.sub(r'\033\[[0-9;]*m', '', line_stripped)
    if not line_clean.strip():
        return
    if any(c in line_clean for c in ('✓', '✔', 'OK', 'ok', 'installed', 'complete', 'success')):
        color = C['teal']
    elif any(c in line_clean for c in ('✗', 'Error', 'error', 'fail', 'FAIL', 'not found')):
        color = C['red']
    elif any(c in line_clean for c in ('⚠', 'warn', 'Warning', 'warning')):
        color = C['gold']
    else:
        color = C['muted']
    panel.append(f'<span style="color:{color}; font-family:monospace;">{line_clean}</span>')
    panel.verticalScrollBar().setValue(panel.verticalScrollBar().maximum())


class StatusCard(QFrame):
    """Small status indicator card used on the Home tab."""
    def __init__(self, title: str, value: str, state: str = "ok"):
        super().__init__()
        self.setObjectName(f"card_{state}")
        self.setFixedHeight(78)
        self.setMinimumWidth(140)
        lay = QVBoxLayout(self)
        lay.setContentsMargins(14, 10, 14, 10)
        lay.setSpacing(4)
        dot_color = {"ok": C["teal"], "warn": C["gold"], "fail": C["red"]}.get(state, C["muted"])
        top = QHBoxLayout()
        dot = QLabel("●")
        dot.setStyleSheet(f"color: {dot_color}; font-size: 10px;")
        top.addWidget(dot)
        top.addWidget(_label(title, C["muted"], size=11))
        top.addStretch()
        lay.addLayout(top)
        self.val_lbl = _label(value, C["parch"], bold=True, size=13)
        lay.addWidget(self.val_lbl)

    def update(self, value: str, state: str):
        self.val_lbl.setText(value)
        self.setObjectName(f"card_{state}")
        self.style().unpolish(self)
        self.style().polish(self)


