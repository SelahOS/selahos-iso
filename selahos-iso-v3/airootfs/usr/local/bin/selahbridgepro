#  MAIN WINDOW
# ═══════════════════════════════════════════════════════════════════════════════

class SelahBridgeProWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle(f"SelahBridgePro  v{VERSION}")
        self.setMinimumSize(860, 600)
        self.resize(1000, 680)

        # Try to set icon (same selahbridge.png from existing icon set)
        icon_candidates = [
            "/usr/share/icons/hicolor/256x256/apps/selahbridge.png",
            "/usr/local/share/icons/selahbridge.png",
            str(Path(__file__).parent / "selahbridge.png"),
        ]
        for ic in icon_candidates:
            if Path(ic).exists():
                self.setWindowIcon(QIcon(ic))
                break

        tabs = QTabWidget()
        tabs.setDocumentMode(True)

        self.home_tab     = HomeTab()
        self.daws_tab     = DawsTab()
        self.audio_tab    = AudioTab()
        self.midi_tab     = MidiTab()
        self.diagnose_tab = DiagnoseTab()
        self.apps_tab     = WindowsAppsTab()
        self.license_tab  = LicenseTab()

        tabs.addTab(self.home_tab,     "  Home  ")
        tabs.addTab(self.daws_tab,     "  DAWs  ")
        tabs.addTab(self.apps_tab,     "  Windows Apps  ")
        tabs.addTab(self.audio_tab,    "  Audio  ")
        tabs.addTab(self.midi_tab,     "  MIDI  ")
        tabs.addTab(self.diagnose_tab, "  Diagnose  ")
        tabs.addTab(self.license_tab,  "  License  ")

        self.setCentralWidget(tabs)

        # Wire Home tab quick-launch → switch to DAWs tab and trigger launch
        self.home_tab.launch_requested.connect(self._quick_launch)

    def _quick_launch(self, daw_key: str):
        for i, d in enumerate(KNOWN_DAWS):
            if d["key"] == daw_key:
                # Switch to DAWs tab, select the DAW, launch
                self.centralWidget().setCurrentIndex(1)
                self.daws_tab.daw_combo.setCurrentIndex(i)
                self.daws_tab._do_launch()
                return


# ═══════════════════════════════════════════════════════════════════════════════
#  ENTRY POINT
# ═══════════════════════════════════════════════════════════════════════════════

def main():
    app = QApplication(sys.argv)
    app.setApplicationName("SelahBridgePro")
    app.setOrganizationName("Selah Technologies")
    app.setStyleSheet(STYLESHEET)

    # Start trial on first run if not yet licensed
    status, _ = _license_status()
    if status == "notstarted":
        LIC_DIR.mkdir(parents=True, exist_ok=True)
        TRIAL_FILE.write_text(datetime.date.today().isoformat())
        os.chmod(TRIAL_FILE, 0o600)

    win = SelahBridgeProWindow()
    win.show()
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
