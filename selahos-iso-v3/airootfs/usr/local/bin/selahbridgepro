        self.btn_remove.setObjectName("secondary")
        self.btn_remove.setFixedHeight(32)
        btn_row.addWidget(self.btn_add)
        btn_row.addWidget(self.btn_remove)
        left.addLayout(btn_row)
        body.addLayout(left)

