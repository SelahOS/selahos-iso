        left.setSpacing(8)
        left.addWidget(_label("Registered Apps", C["muted"], size=11))
        self.app_list = QListWidget()
        self.app_list.setMinimumWidth(200)
        self.app_list.setMaximumWidth(260)
        left.addWidget(self.app_list, stretch=1)
