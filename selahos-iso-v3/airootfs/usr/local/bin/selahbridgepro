class HomeTab(QWidget):
    launch_requested = pyqtSignal(str)

    def __init__(self):
        super().__init__()
        root = QVBoxLayout(self)
        root.setContentsMargins(28, 24, 28, 24)
        root.setSpacing(20)

        # Brand header
        hdr = QHBoxLayout()
        brand = _label(f"SelahBridgePro™", C["gold"], bold=True, size=22)
        ver   = _label(f"v{VERSION}", C["muted"], size=13)
        hdr.addWidget(brand)
        hdr.addSpacing(10)
        hdr.addWidget(ver)
        hdr.addStretch()
        self.lic_badge = _label("●  Checking…", C["muted"], size=12)
        hdr.addWidget(self.lic_badge)
        root.addLayout(hdr)

        root.addWidget(_divider())

        # Status cards row
        root.addWidget(_label("System Status", C["muted"], size=11))
        cards_row = QHBoxLayout()
        cards_row.setSpacing(10)
        self.card_wine    = StatusCard("Wine",      "Checking…", "warn")
        self.card_asio    = StatusCard("SelahASIO", "Checking…", "warn")
        self.card_pw      = StatusCard("PipeWire",  "Checking…", "warn")
        self.card_midi    = StatusCard("MIDI",      "Checking…", "warn")
        self.card_dxvk    = StatusCard("DXVK",      "Checking…", "warn")
        for card in (self.card_wine, self.card_asio, self.card_pw, self.card_midi, self.card_dxvk):
            cards_row.addWidget(card)
        cards_row.addStretch()
        root.addLayout(cards_row)

        root.addWidget(_divider())

        # Quick launch
        root.addWidget(_label("Quick Launch", C["muted"], size=11))
        launch_row = QHBoxLayout()
        launch_row.setSpacing(10)
        for daw in KNOWN_DAWS:
            btn = QPushButton(daw["name"])
            btn.setObjectName("launch")
            btn.setFixedHeight(38)
            btn.clicked.connect(lambda _, k=daw["key"]: self.launch_requested.emit(k))
            launch_row.addWidget(btn)
        launch_row.addStretch()
        root.addLayout(launch_row)

        root.addWidget(_divider())

        # Audio summary
        self.audio_lbl = _label("Audio: not configured", C["muted"], size=12)
        root.addWidget(self.audio_lbl)

        root.addStretch()

        # Footer
        foot = _label(
            f"SelahOS · Selah Technologies LLC · support: {SUPPORT}",
            C["muted"], size=11
        )
        foot.setAlignment(Qt.AlignmentFlag.AlignCenter)
        root.addWidget(foot)

        QTimer.singleShot(200, self._check_system)

    def _check_system(self):
        # Wine
        if shutil.which("wine"):
            self.card_wine.update("Ready", "ok")
        else:
            self.card_wine.update("Not found", "fail")

        # WineASIO
        r = subprocess.run(
            ["find", "/usr/lib", "/usr/lib32", "-name", "wineasio.dll.so"],
            capture_output=True)
        self.card_asio.update("Ready" if r.stdout.strip() else "Not installed",
                              "ok" if r.stdout.strip() else "fail")

        # PipeWire
        r2 = subprocess.run(["pgrep", "pipewire"], capture_output=True)
        self.card_pw.update("Running" if r2.returncode == 0 else "Not running",
                            "ok" if r2.returncode == 0 else "fail")

        # MIDI
        midi_nodes = list(Path("/dev/snd").glob("midiC*D*")) if Path("/dev/snd").exists() else []
        self.card_midi.update(f"{len(midi_nodes)} device(s)" if midi_nodes else "None",
                              "ok" if midi_nodes else "warn")

        # DXVK
        r3 = subprocess.run(
            ["find", "/usr/share", "-name", "dxgi.dll"],
            capture_output=True)
        self.card_dxvk.update("Ready" if r3.stdout.strip() else "Not found",
                              "ok" if r3.stdout.strip() else "fail")

        # License
        status, detail = _license_status()
        colors = {"licensed": C["teal"], "trial": C["gold"],
                  "expired": C["red"], "notstarted": C["muted"]}
        labels = {"licensed": "●  Licensed", "trial": f"●  Trial  ({detail})",
                  "expired": "●  Trial Expired", "notstarted": "●  No trial"}
        self.lic_badge.setText(labels.get(status, "●  Unknown"))
        self.lic_badge.setStyleSheet(f"color: {colors.get(status, C['muted'])}; font-size: 12px;")

        # Audio summary
        cfg = Path.home() / ".config/pipewire/pipewire.conf.d/selah-asio-rt.conf"
        if cfg.exists():
            text = cfg.read_text()
            import re
            buf  = re.search(r"clock\.quantum\s*=\s*(\d+)", text)
            rate = re.search(r"clock\.rate\s*=\s*(\d+)", text)
            if buf and rate:
                b, r = int(buf.group(1)), int(rate.group(1))
                ms = (b / r) * 1000
                self.audio_lbl.setText(
                    f"Audio: {rate.group(1)} Hz  ·  {buf.group(1)} samples  ·  {ms:.2f} ms latency")
                return
        self.audio_lbl.setText("Audio: run 'selahpro audio config' to configure")


class DawsTab(QWidget):
    def __init__(self):
        super().__init__()
        root = QVBoxLayout(self)
        root.setContentsMargins(28, 24, 28, 24)
        root.setSpacing(16)

        root.addWidget(_label("DAW Setup & Launch", C["gold"], bold=True, size=15))
        root.addWidget(_label(
            "Install Wine prefix + dependencies for each DAW, then launch directly.",
            C["muted"], size=12))
        root.addWidget(_divider())

        # DAW selector row
        sel_row = QHBoxLayout()
        sel_row.addWidget(_label("DAW:", C["muted"]))
        self.daw_combo = QComboBox()
        for d in KNOWN_DAWS:
            self.daw_combo.addItem(f"{d['name']}  ({d['ver']})", d["key"])
        sel_row.addWidget(self.daw_combo)
        sel_row.addSpacing(16)

        self.btn_install = QPushButton("Install / Setup")
        self.btn_install.setFixedWidth(160)
        self.btn_launch  = QPushButton("Launch DAW")
        self.btn_launch.setObjectName("launch")
        self.btn_launch.setFixedWidth(140)
        self.btn_auth    = QPushButton("Authorize…")
        self.btn_auth.setObjectName("secondary")
        self.btn_auth.setFixedWidth(120)

        sel_row.addWidget(self.btn_install)
        sel_row.addSpacing(6)
        sel_row.addWidget(self.btn_launch)
        sel_row.addSpacing(6)
        sel_row.addWidget(self.btn_auth)
        sel_row.addStretch()
        root.addLayout(sel_row)

        # Prefix info
        self.prefix_lbl = _label("", C["muted"], size=11)
        root.addWidget(self.prefix_lbl)
        self.daw_combo.currentIndexChanged.connect(self._update_prefix_label)
        self._update_prefix_label()

        # Log output
        root.addWidget(_label("Output", C["muted"], size=11))
        self.log = _log_panel()
        root.addWidget(self.log, stretch=1)

        # Status bar
        self.status_lbl = _label("Ready.", C["muted"], size=11)
        root.addWidget(self.status_lbl)

        self.btn_install.clicked.connect(self._do_install)
        self.btn_launch.clicked.connect(self._do_launch)
        self.btn_auth.clicked.connect(self._do_auth)
        self._worker = None

    def _daw_key(self):
        return self.daw_combo.currentData()

    def _update_prefix_label(self):
        key = self._daw_key()
        prefix = Path.home() / f".wine-selah-{key}"
        exists = "exists" if prefix.exists() else "not yet created"
        self.prefix_lbl.setText(f"Prefix: {prefix}  ({exists})")

    def _set_busy(self, busy: bool):
        self.btn_install.setEnabled(not busy)
        self.btn_launch.setEnabled(not busy)
        self.btn_auth.setEnabled(not busy)
        self.daw_combo.setEnabled(not busy)

    def _run(self, cmd: list, done_msg: str):
        self._set_busy(True)
        self.log.clear()
        self.status_lbl.setText("Running…")
        self._worker = CommandWorker(cmd)
        self._worker.line_out.connect(lambda l: _log_append(self.log, l))
        self._worker.finished.connect(lambda rc: self._on_done(rc, done_msg))
        self._worker.start()

    def _on_done(self, rc: int, done_msg: str):
        self._set_busy(False)
        self._update_prefix_label()
        if rc == 0:
            self.status_lbl.setText(f"✓  {done_msg}")
            _log_append(self.log, f"✓  {done_msg}")
        else:
            self.status_lbl.setText(f"✗  Finished with errors (exit {rc})")
            _log_append(self.log, f"✗  Exit code {rc}")

    def _do_install(self):
        self._run(["selahpro", "install", self._daw_key()],
                  "Installation complete")

    def _do_launch(self):
        key = self._daw_key()
        self.status_lbl.setText(f"Launching {key}…")
        subprocess.Popen(["selahpro", "launch", key])

    def _do_auth(self):
        subprocess.Popen(["selahpro", "auth", self._daw_key()])


class AudioTab(QWidget):
    def __init__(self):
        super().__init__()
        root = QVBoxLayout(self)
        root.setContentsMargins(28, 24, 28, 24)
        root.setSpacing(18)

        root.addWidget(_label("SelahASIO Audio Configuration", C["gold"], bold=True, size=15))
        root.addWidget(_label(
            "Configure PipeWire sample rate and buffer size for DAW production.",
            C["muted"], size=12))
        root.addWidget(_divider())

        grid = QGridLayout()
        grid.setSpacing(14)
        grid.setColumnMinimumWidth(0, 140)

        # Sample rate
        grid.addWidget(_label("Sample Rate", C["muted"]), 0, 0)
        self.rate_combo = QComboBox()
        for r in SAMPLE_RATES:
            self.rate_combo.addItem(f"{r} Hz", r)
        self.rate_combo.setCurrentIndex(1)  # 48000
        grid.addWidget(self.rate_combo, 0, 1)

        # Buffer size
        grid.addWidget(_label("Buffer Size", C["muted"]), 1, 0)
        self.buf_combo = QComboBox()
        for b in BUFFER_SIZES:
            self.buf_combo.addItem(f"{b} samples", b)
        self.buf_combo.setCurrentIndex(3)  # 256
        grid.addWidget(self.buf_combo, 1, 1)

        # Latency readout
        grid.addWidget(_label("Latency", C["muted"]), 2, 0)
        self.latency_lbl = _label("5.33 ms", C["gold"], bold=True, size=16)
        grid.addWidget(self.latency_lbl, 2, 1)

        root.addLayout(grid)

        self.rate_combo.currentIndexChanged.connect(self._update_latency)
        self.buf_combo.currentIndexChanged.connect(self._update_latency)
        self._update_latency()

        # Apply button
        btn_row = QHBoxLayout()
        self.btn_apply = QPushButton("Apply & Restart PipeWire")
        self.btn_apply.setFixedWidth(240)
        btn_row.addWidget(self.btn_apply)
        btn_row.addStretch()
        root.addLayout(btn_row)

        root.addWidget(_divider())
        root.addWidget(_label("Output", C["muted"], size=11))
        self.log = _log_panel()
        self.log.setMaximumHeight(180)
        root.addWidget(self.log)
        root.addStretch()

        self.btn_apply.clicked.connect(self._do_apply)
        self._worker = None

    def _update_latency(self):
        rate = self.rate_combo.currentData()
        buf  = self.buf_combo.currentData()
        ms = (buf / rate) * 1000
        self.latency_lbl.setText(f"{ms:.2f} ms")
        color = C["teal"] if ms <= 5 else (C["gold"] if ms <= 10 else C["red"])
        self.latency_lbl.setStyleSheet(f"color: {color}; font-weight: bold; font-size: 16px;")

    def _do_apply(self):
        rate = self.rate_combo.currentData()
        buf  = self.buf_combo.currentData()
        self.btn_apply.setEnabled(False)
        self.log.clear()
        self._worker = CommandWorker(
            ["selahpro", "audio", "config", "--rate", str(rate), "--buffer", str(buf)])
        self._worker.line_out.connect(lambda l: _log_append(self.log, l))
        self._worker.finished.connect(lambda rc: self._on_done(rc))
        self._worker.start()

    def _on_done(self, rc: int):
        self.btn_apply.setEnabled(True)
        _log_append(self.log, "✓  Audio settings applied." if rc == 0 else f"✗  Exit {rc}")


class MidiTab(QWidget):
    def __init__(self):
        super().__init__()
        root = QVBoxLayout(self)
        root.setContentsMargins(28, 24, 28, 24)
        root.setSpacing(16)

        root.addWidget(_label("USB MIDI Devices", C["gold"], bold=True, size=15))
        root.addWidget(_label(
            "Connected MIDI devices detected by SelahBridgePro udev rules.",
            C["muted"], size=12))
        root.addWidget(_divider())

        # Device list
        list_row = QHBoxLayout()
        self.device_list = QListWidget()
        self.device_list.setMinimumHeight(200)
        list_row.addWidget(self.device_list, stretch=1)

        side = QVBoxLayout()
        side.setSpacing(8)
        self.btn_refresh    = QPushButton("Refresh")
        self.btn_passthrough = QPushButton("Enable\nPassthrough")
        self.btn_passthrough.setObjectName("secondary")
        self.btn_passthrough.setFixedHeight(54)
        for b in (self.btn_refresh, self.btn_passthrough):
            b.setFixedWidth(140)
            side.addWidget(b)
        side.addStretch()
        list_row.addLayout(side)
        root.addLayout(list_row)

        root.addWidget(_divider())
        root.addWidget(_label("ALSA Sequencer Ports", C["muted"], size=11))
        self.alsa_text = QTextEdit()
        self.alsa_text.setReadOnly(True)
        self.alsa_text.setMaximumHeight(130)
        root.addWidget(self.alsa_text)
        root.addStretch()

        self.btn_refresh.clicked.connect(self._refresh)
        self.btn_passthrough.clicked.connect(self._passthrough)
        self._refresh()

    def _refresh(self):
        self.device_list.clear()
        # SelahBridgePro symlinks
        midi_dir = Path("/dev/selah-midi")
        if midi_dir.exists():
            for p in sorted(midi_dir.iterdir()):
                item = QListWidgetItem(f"  {p.name}")
                item.setForeground(QColor(C["parch"]))
                self.device_list.addItem(item)
        # lsusb Akai devices
        r = subprocess.run(["lsusb", "-d", "09e8:"], capture_output=True, text=True, check=False)
        for line in r.stdout.strip().splitlines():
            item = QListWidgetItem(f"  {line.strip()}")
            item.setForeground(QColor(C["teal"]))
            self.device_list.addItem(item)
        if self.device_list.count() == 0:
            item = QListWidgetItem("  No devices detected — connect a USB MIDI controller")
            item.setForeground(QColor(C["muted"]))
            self.device_list.addItem(item)
        # ALSA ports
        r2 = subprocess.run(["aconnect", "-l"], capture_output=True, text=True, check=False)
        self.alsa_text.setPlainText(r2.stdout.strip() if r2.returncode == 0
                                    else "(aconnect not available — install alsa-utils)")

    def _passthrough(self):
        sel = self.device_list.currentItem()
        if not sel:
            return
        device = sel.text().strip().split()[0]
        subprocess.Popen(["selahpro", "midi", "passthrough", device])


