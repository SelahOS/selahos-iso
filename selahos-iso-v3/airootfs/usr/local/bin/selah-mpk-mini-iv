  min-width:32px;min-height:32px;color:#80c0ff;font-weight:bold}
QCheckBox{color:#ccc}
QCheckBox::indicator:checked{background:#c0a0ff;border:1px solid #c0a0ff;border-radius:2px}
QStatusBar{background:#111;color:#888;font-size:11px}
"""


def _run_gui():
    try:
        from PyQt6.QtWidgets import (
            QApplication, QMainWindow, QWidget, QVBoxLayout, QHBoxLayout,
            QGridLayout, QLabel, QComboBox, QSpinBox, QCheckBox, QPushButton,
            QGroupBox, QTabWidget, QStatusBar, QMessageBox, QFileDialog, QLineEdit,
        )
        from PyQt6.QtCore import Qt, QThread, pyqtSignal, pyqtSlot
    except ImportError:
        sys.exit("Error: python-pyqt6 not installed.\n  sudo pacman -S python-pyqt6")

    CONFIG_DIR = Path.home() / ".config" / "selah" / "mpk-mini-iv"
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)

    class DevThread(QThread):
        connected    = pyqtSignal(str)
        disconnected = pyqtSignal()
        sysex_rx     = pyqtSignal(list)

        def __init__(self, dev, parent=None):
            super().__init__(parent)
            self._dev = dev; self._running = True; self._conn = False

        def run(self):
            self._dev.set_sysex_callback(lambda d: self.sysex_rx.emit(d))
            while self._running:
                ins, outs = MPKDevice.find_ports(prefer_sysex=True)
                if ins and outs and not self._conn:
                    self._dev.connect(ins[0][0], outs[0][0])
                    self._conn = True
                    self.connected.emit(ins[0][1].split(":")[0])
                elif not ins and self._conn:
                    self._dev.disconnect(); self._conn = False
                    self.disconnected.emit()
                self.msleep(1500)

        def stop(self): self._running = False; self.wait()

    def make_pad_widget(label: str):
        """Returns (widget, {note_spin, type_lbl, get(), load()})"""
        grp = QGroupBox(label)
        g = QGridLayout(grp); g.setSpacing(3)
        lbl = QLabel(label, objectName="pad"); lbl.setAlignment(Qt.AlignmentFlag.AlignCenter)
        g.addWidget(lbl, 0, 0, 1, 2)
        g.addWidget(QLabel("Note"), 1, 0)
        note = QSpinBox(); note.setRange(0, 127); g.addWidget(note, 1, 1)
        type_lbl = QLabel(""); type_lbl.setStyleSheet("color:#666;font-size:10px;")
        g.addWidget(type_lbl, 2, 0, 1, 2)

        def load(c: PadConfig):
            note.blockSignals(True); note.setValue(c.note); note.blockSignals(False)
            lbl.setToolTip(f"{nn(c.note)} ({c.note})")
            type_lbl.setText(f"b3={c.type_b3:02X} b4={c.type_b4:02X}")

        def get() -> PadConfig:
            return PadConfig(note=note.value())  # type bytes preserved via _raw

        grp.load = load; grp.get = get
        return grp

    def make_knob_widget(idx: int):
        grp = QGroupBox(f"K{idx+1}")
        g = QGridLayout(grp); g.setSpacing(3)
        lbl = QLabel(f"K{idx+1}", objectName="knob"); lbl.setAlignment(Qt.AlignmentFlag.AlignCenter)
        g.addWidget(lbl, 0, 0, 1, 2)
        g.addWidget(QLabel("CC"), 1, 0)
        cc = QSpinBox(); cc.setRange(0, 127); g.addWidget(cc, 1, 1)
        g.addWidget(QLabel("Min"), 2, 0)
        mn = QSpinBox(); mn.setRange(0, 127); g.addWidget(mn, 2, 1)
        g.addWidget(QLabel("Max"), 3, 0)
        mx = QSpinBox(); mx.setRange(0, 127); mx.setValue(127); g.addWidget(mx, 3, 1)
        mod = QComboBox(); mod.addItems(KNOB_MODES); g.addWidget(mod, 4, 0, 1, 2)
        g.addWidget(QLabel("Name"), 5, 0)
        name = QLineEdit(); name.setMaxLength(16); g.addWidget(name, 5, 1)

        def load(k: KnobConfig):
            for w in [cc, mn, mx, mod]: w.blockSignals(True)
            cc.setValue(k.cc); mn.setValue(k.min_val); mx.setValue(k.max_val)
            mod.setCurrentIndex(k.mode); name.setText(k.name)
            for w in [cc, mn, mx, mod]: w.blockSignals(False)

        def get() -> KnobConfig:
            return KnobConfig(cc=cc.value(), min_val=mn.value(), max_val=mx.value(),
                              mode=mod.currentIndex(), name=name.text())
        grp.load = load; grp.get = get
        return grp

    class Win(QMainWindow):
        def __init__(self):
            super().__init__()
            self.setWindowTitle("MPK mini IV Editor — SelahOS")
            self.setMinimumSize(980, 720)
            self._dev     = MPKDevice()
            self._presets = [Preset(index=i) for i in range(4)]
            self._cur     = 0
            self._thread  = DevThread(self._dev)
            self._vport   = None
            self._load_local()
            self._build()
            self.setStyleSheet(STYLE)
            self._thread.connected.connect(self._on_conn)
            self._thread.disconnected.connect(self._on_disc)
            self._thread.sysex_rx.connect(self._on_sysex)
            self._thread.start()
            self._load_ui(0)

        def _build(self):
            cw = QWidget(); self.setCentralWidget(cw)
            root = QVBoxLayout(cw); root.setSpacing(6); root.setContentsMargins(8,8,8,6)

            # Top bar
            top = QHBoxLayout()
            self._clbl = QLabel("● Not connected")
            self._clbl.setStyleSheet("color:#f44;font-weight:bold;")
            top.addWidget(self._clbl); top.addStretch()

            top.addWidget(QLabel("Preset:"))
            self._psel = QComboBox(); self._psel.addItems(["1","2","3","4"])
            self._psel.currentIndexChanged.connect(self._on_pchg)
            top.addWidget(self._psel)
            self._name_edit = QLineEdit(); self._name_edit.setMaxLength(16)
            self._name_edit.setPlaceholderText("Preset name"); self._name_edit.setFixedWidth(100)
            top.addWidget(self._name_edit)
            self._gbtn = QPushButton("← Get from Device")
            self._sbtn = QPushButton("→ Send to Device", objectName="sync")
            self._gbtn.clicked.connect(self._on_get)
            self._sbtn.clicked.connect(self._on_send)
            top.addWidget(self._gbtn); top.addWidget(self._sbtn)
            root.addLayout(top)

            tabs = QTabWidget()

            # ── Pad Bank A
            bank_a = QWidget(); lay_a = QVBoxLayout(bank_a); lay_a.setSpacing(4)
            lay_a.addWidget(QLabel("Bank A (pads 1-8)", styleSheet="color:#c0a0ff;font-weight:bold;"))
            grid_a = QGridLayout(); grid_a.setSpacing(4)
            self._pads_a = [make_pad_widget(f"A{i+1}") for i in range(8)]
            for i,pw in enumerate(self._pads_a): grid_a.addWidget(pw, 0, i)
            lay_a.addLayout(grid_a); lay_a.addStretch()
            tabs.addTab(bank_a, "Pads — Bank A")

            # ── Pad Bank B
            bank_b = QWidget(); lay_b = QVBoxLayout(bank_b); lay_b.setSpacing(4)
            lay_b.addWidget(QLabel("Bank B (pads 1-8)", styleSheet="color:#c0a0ff;font-weight:bold;"))
            grid_b = QGridLayout(); grid_b.setSpacing(4)
            self._pads_b = [make_pad_widget(f"B{i+1}") for i in range(8)]
            for i,pw in enumerate(self._pads_b): grid_b.addWidget(pw, 0, i)
            lay_b.addLayout(grid_b); lay_b.addStretch()
            tabs.addTab(bank_b, "Pads — Bank B")

            # ── Knobs
            knob_w = QWidget(); knob_lay = QGridLayout(knob_w); knob_lay.setSpacing(4)
            self._knobs = [make_knob_widget(i) for i in range(8)]
            for i,kw in enumerate(self._knobs): knob_lay.addWidget(kw, 0, i)
            tabs.addTab(knob_w, "Knobs")

            # ── Arp
            arp_w = QWidget(); ag = QGridLayout(arp_w); ag.setSpacing(6)
            self._arp_on = QCheckBox("Arpeggiator Enabled")
            self._arp_on.setStyleSheet("font-size:13px;font-weight:bold;")
            ag.addWidget(self._arp_on, 0, 0, 1, 4)
            self._arp_mode = QComboBox(); self._arp_mode.addItems(ARP_MODES)
            self._arp_div  = QComboBox(); self._arp_div.addItems(ARP_DIVS)
            self._arp_oct  = QComboBox(); self._arp_oct.addItems(ARP_OCTS)
            self._arp_bpm  = QSpinBox();  self._arp_bpm.setRange(20, 127)
            self._arp_clk  = QComboBox(); self._arp_clk.addItems(["Internal","External"])
            for row, (lbl, w) in enumerate([("Mode",self._arp_mode),("Division",self._arp_div),
                                             ("Octaves",self._arp_oct),("Tempo (BPM)",self._arp_bpm),
                                             ("Clock",self._arp_clk)], start=1):
                ag.addWidget(QLabel(lbl), row, 0); ag.addWidget(w, row, 1)
            ag.setRowStretch(7, 1)
            tabs.addTab(arp_w, "Arpeggiator")

            # ── Global
            gl_w = QWidget(); gg = QGridLayout(gl_w); gg.setSpacing(6)
            self._gl_ch = QSpinBox(); self._gl_ch.setRange(1,16)
            gg.addWidget(QLabel("MIDI Channel"), 0, 0); gg.addWidget(self._gl_ch, 0, 1)
            gg.setRowStretch(2, 1)
            tabs.addTab(gl_w, "Global")

            # ── MIDI Routing
            rt_w = QWidget(); rt_lay = QVBoxLayout(rt_w)
            rt_lay.addWidget(QLabel(
                "MPK mini IV is class-compliant — appears in PipeWire/ALSA automatically on plug-in.\n\n"
                "SelahBridgePro: Wine DAWs see MIDI via WineASIO → PipeWire bridge.\n"
                "No extra routing needed.\n\n"
                "Note: 'Send to Device' updates the device RAM config (affects live play).\n"
                "Preset saves to flash via power-cycle or on-device button hold.",
                styleSheet="color:#aaa;padding:8px;", wordWrap=True))
            self._vbtn = QPushButton("Create Virtual Port: 'MPK mini IV (SelahOS)'")
            self._vbtn.clicked.connect(self._on_vport)
            self._vstatus = QLabel("Virtual port: not created", styleSheet="color:#888;")
            rt_lay.addWidget(self._vbtn); rt_lay.addWidget(self._vstatus); rt_lay.addStretch()
            tabs.addTab(rt_w, "MIDI Routing")

            root.addWidget(tabs)

            bot = QHBoxLayout()
            sf = QPushButton("Save Preset File…"); lf = QPushButton("Load Preset File…")
            sf.clicked.connect(self._save_file); lf.clicked.connect(self._load_file)
            bot.addWidget(sf); bot.addWidget(lf); bot.addStretch()
            root.addLayout(bot)
            self.setStatusBar(QStatusBar())
            self.statusBar().showMessage("Ready — plug in MPK mini IV to connect")

        @pyqtSlot(str)
        def _on_conn(self, name):
            self._clbl.setText(f"● {name}"); self._clbl.setStyleSheet("color:#44ff88;font-weight:bold;")
            self.statusBar().showMessage(f"Connected: {name} — click '← Get' to load presets from device")

        @pyqtSlot()
        def _on_disc(self):
            self._clbl.setText("● Not connected"); self._clbl.setStyleSheet("color:#f44;font-weight:bold;")
            self.statusBar().showMessage("MPK mini IV disconnected")

        @pyqtSlot(list)
        def _on_sysex(self, data: list):
            preset = self._dev.parse_response(data)
            if preset:
                idx = preset.index if preset.index < 4 else self._cur
                self._presets[idx] = preset
                if idx == self._cur: self._load_ui(idx)
                self.statusBar().showMessage(f"Received preset {idx+1} '{preset.name}' from device")
                self._save_local()

        def _on_pchg(self, i: int):
            self._save_ui(self._cur); self._cur = i; self._load_ui(i)

        def _load_ui(self, i: int):
            p = self._presets[i]
            self._name_edit.setText(p.name)
            for j,pw in enumerate(self._pads_a): pw.load(p.pads_a[j])
            for j,pw in enumerate(self._pads_b): pw.load(p.pads_b[j])
            for j,kw in enumerate(self._knobs):  kw.load(p.knobs[j])
            for w in [self._arp_on,self._arp_mode,self._arp_div,self._arp_oct,self._arp_bpm,self._arp_clk,self._gl_ch]:
                w.blockSignals(True)
            self._arp_on.setChecked(p.arp_enabled)
            self._arp_mode.setCurrentIndex(p.arp_mode)
            self._arp_div.setCurrentIndex(p.arp_division)
            self._arp_oct.setCurrentIndex(p.arp_octave)
            self._arp_bpm.setValue(p.arp_tempo)
            self._arp_clk.setCurrentIndex(p.clock_source)
            self._gl_ch.setValue(p.midi_channel)
            for w in [self._arp_on,self._arp_mode,self._arp_div,self._arp_oct,self._arp_bpm,self._arp_clk,self._gl_ch]:
                w.blockSignals(False)

        def _save_ui(self, i: int):
            p = self._presets[i]
            p.name = self._name_edit.text() or p.name
            for j,pw in enumerate(self._pads_a):
                pad = pw.get(); pad.type_b3 = p.pads_a[j].type_b3; pad.type_b4 = p.pads_a[j].type_b4
                p.pads_a[j] = pad
            for j,pw in enumerate(self._pads_b):
                pad = pw.get(); pad.type_b3 = p.pads_b[j].type_b3; pad.type_b4 = p.pads_b[j].type_b4
                p.pads_b[j] = pad
            for j,kw in enumerate(self._knobs): p.knobs[j] = kw.get()
            p.arp_enabled = self._arp_on.isChecked()
            p.arp_mode = self._arp_mode.currentIndex()
            p.arp_division = self._arp_div.currentIndex()
            p.arp_octave = self._arp_oct.currentIndex()
            p.arp_tempo = self._arp_bpm.value()
            p.clock_source = self._arp_clk.currentIndex()
            p.midi_channel = self._gl_ch.value()

        def _on_get(self):
            if not self._dev.is_connected():
                QMessageBox.warning(self, "Not Connected", "Plug in MPK mini IV first."); return
            self._dev.request_preset(self._cur)
            self.statusBar().showMessage(f"Requesting preset {self._cur+1} from device…")

        def _on_send(self):
            if not self._dev.is_connected():
                QMessageBox.warning(self, "Not Connected", "Plug in MPK mini IV first."); return
            self._save_ui(self._cur)
            self._dev.send_preset(self._presets[self._cur])
            self._save_local()
            self.statusBar().showMessage(
                f"Sent preset {self._cur+1} to device (active RAM). "
                "Power-cycle device to save to flash permanently.")

        def _on_vport(self):
            if self._vport: self._vstatus.setText("Already active"); return
            self._vport = self._dev.create_virtual_port()
            self._vstatus.setText("✓ Active: 'MPK mini IV (SelahOS)'")
            self._vstatus.setStyleSheet("color:#44ff88;")

        def _save_file(self):
            self._save_ui(self._cur)
            path, _ = QFileDialog.getSaveFileName(self, "Save Preset", str(CONFIG_DIR),
                                                   "MPK Preset (*.mpkpreset)")
            if not path: return
            if not path.endswith(".mpkpreset"): path += ".mpkpreset"
            Path(path).write_text(json.dumps(self._presets[self._cur].to_dict(), indent=2))
            self.statusBar().showMessage(f"Saved: {path}")

        def _load_file(self):
            path, _ = QFileDialog.getOpenFileName(self, "Load Preset", str(CONFIG_DIR),
                                                   "MPK Preset (*.mpkpreset)")
            if not path: return
            try:
                p = Preset.from_dict(json.loads(Path(path).read_text()))
                p.index = self._cur; self._presets[self._cur] = p
                self._load_ui(self._cur)
                self.statusBar().showMessage(f"Loaded: {path}")
            except Exception as e:
                QMessageBox.critical(self, "Load Error", str(e))

        def _local_path(self): return CONFIG_DIR / "presets.json"

        def _save_local(self):
            self._save_ui(self._cur)
            Path(self._local_path()).write_text(json.dumps([p.to_dict() for p in self._presets], indent=2))

        def _load_local(self):
            p = self._local_path()
            if not p.exists(): return
            try:
                for i,d in enumerate(json.loads(p.read_text())[:4]):
                    self._presets[i] = Preset.from_dict(d); self._presets[i].index = i
            except Exception: pass

        def closeEvent(self, e):
            self._save_local(); self._thread.stop(); self._dev.disconnect(); super().closeEvent(e)

    app = QApplication(sys.argv)
    app.setApplicationName("MPK mini IV Editor")
    app.setOrganizationName("Selah Technologies")
    win = Win(); win.show()
    sys.exit(app.exec())


# ══════════════════════════════════════════════════════════════════════════════
#  MAIN
# ══════════════════════════════════════════════════════════════════════════════

def main():
    ap = argparse.ArgumentParser(description="selah-mpk-mini-iv — MPK mini IV Editor for SelahOS")
    ap.add_argument("--ports",   action="store_true", help="List MIDI ports and exit")
    ap.add_argument("--monitor", action="store_true", help="Print incoming MIDI messages")
    args = ap.parse_args()
    if args.ports:   cmd_ports()
    elif args.monitor: cmd_monitor()
    else:              _run_gui()

if __name__ == "__main__":
    main()
