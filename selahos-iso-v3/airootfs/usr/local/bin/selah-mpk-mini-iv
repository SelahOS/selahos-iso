import sys, os, json, time, signal, argparse, contextlib
from dataclasses import dataclass, field
from pathlib import Path
from typing import Optional, Callable

# rtmidi prints ALSA errors to stderr even when PipeWire handles MIDI correctly.
# Silence the fd-level noise so it doesn't pollute the log or kill a pipe.
@contextlib.contextmanager
def _quiet_alsa():
    devnull=os.open(os.devnull,os.O_WRONLY)
    saved=os.dup(2)
    os.dup2(devnull,2)
    try: yield
    finally: os.dup2(saved,2);os.close(saved);os.close(devnull)

try:
    import rtmidi
except ImportError:
    sys.exit("Error: python-rtmidi not installed.\n  sudo pacman -S python-rtmidi")


# ══════════════════════════════════════════════════════════════════════════════
#  PROTOCOL CONSTANTS
# ══════════════════════════════════════════════════════════════════════════════

AKAI_MFR_ID   = 0x47
MPK_DEVICE_ID = 0x5D
CMD_GET       = 0x66
CMD_SET       = 0x67
PAYLOAD_LEN   = 276
ARP_MODES     = ["Up", "Down", "Inclusive", "Exclusive", "Order", "Random"]
ARP_DIVS      = ["1/4", "1/4T", "1/8", "1/8T", "1/16", "1/16T", "1/32", "1/32T"]
ARP_OCTS      = ["1 Oct", "2 Oct", "3 Oct", "4 Oct"]
KNOB_MODES    = ["Relative", "Absolute"]
NOTE_NAMES    = ["C","C#","D","D#","E","F","F#","G","G#","A","A#","B"]
MMC_CMDS      = {1:"STOP", 2:"PLAY", 3:"PLAY", 4:"FFWD", 5:"REW", 6:"REC", 9:"PAUSE"}
IS_WHITE      = [True,False,True,False,True,True,False,True,False,True,False,True]

def nn(n): return f"{NOTE_NAMES[n%12]}{n//12-1}"


# ══════════════════════════════════════════════════════════════════════════════
#  DATA CLASSES
# ══════════════════════════════════════════════════════════════════════════════

@dataclass
class PadConfig:
    note: int=36; type_b3: int=0x05; type_b4: int=0x21

@dataclass
class KnobConfig:
    cc: int=24; min_val: int=0; max_val: int=127; mode: int=1; name: str=""

@dataclass
class Preset:
    index: int=0; name: str="USER"; midi_channel: int=1
    arp_enabled: bool=False; arp_mode: int=0; arp_division: int=2
    arp_octave: int=0; arp_tempo: int=120; clock_source: int=0
    pads_a: list=field(default_factory=lambda:[PadConfig(note=36+i) for i in range(8)])
    pads_b: list=field(default_factory=lambda:[PadConfig(note=44+i) for i in range(8)])
    knobs:  list=field(default_factory=lambda:[KnobConfig(cc=24+i,name=f"KNOB{i+1}") for i in range(8)])
    _raw: Optional[bytes]=field(default=None, repr=False)

    def to_payload(self):
        d=bytearray(self._raw) if (self._raw and len(self._raw)==PAYLOAD_LEN) else bytearray(PAYLOAD_LEN)
        if not self._raw or len(self._raw)!=PAYLOAD_LEN:
            d[17]=0;d[18]=9;d[19]=0;d[26]=0;d[27]=0x7F;d[28]=0
            for i in range(8):
                d[30+i*5+1]=0x20+i;d[30+i*5+2]=i;d[70+i*5+1]=0x28+i;d[70+i*5+2]=8+i
        d[0]=self.index;d[1:17]=self.name.encode('ascii','replace')[:16].ljust(16,b'\x00')
        d[20]=max(20,min(127,self.arp_tempo));d[21]=self.arp_division&7;d[22]=self.arp_mode&7
        d[23]=int(self.arp_enabled);d[24]=self.arp_octave&3;d[25]=self.clock_source&1
        d[29]=max(1,min(16,self.midi_channel))
        for i,p in enumerate(self.pads_a[:8]):
            o=30+i*5;d[o]=p.note&0x7F;d[o+3]=p.type_b3;d[o+4]=p.type_b4
        for i,p in enumerate(self.pads_b[:8]):
            o=70+i*5;d[o]=p.note&0x7F;d[o+3]=p.type_b3;d[o+4]=p.type_b4
        for i,k in enumerate(self.knobs[:8]):
            o=110+i*20;d[o]=k.cc&0x7F;d[o+1]=k.min_val&0x7F;d[o+2]=k.max_val&0x7F;d[o+3]=k.mode&1
            d[o+4:o+20]=k.name.encode('ascii','replace')[:16].ljust(16,b'\x00')
        return list(d)

    @classmethod
    def from_payload(cls, payload):
        if len(payload)<PAYLOAD_LEN: return cls()
        d=payload;p=cls(index=d[0]);p._raw=bytes(d[:PAYLOAD_LEN])
        p.name=bytes(d[1:17]).rstrip(b'\x00').decode('ascii','replace')
        p.arp_tempo=d[20];p.arp_division=d[21]&7;p.arp_mode=d[22]&7
        p.arp_enabled=bool(d[23]);p.arp_octave=d[24]&3;p.clock_source=d[25]&1
        p.midi_channel=max(1,min(16,d[29]))
        p.pads_a=[PadConfig(note=d[30+i*5],type_b3=d[30+i*5+3],type_b4=d[30+i*5+4]) for i in range(8)]
        p.pads_b=[PadConfig(note=d[70+i*5],type_b3=d[70+i*5+3],type_b4=d[70+i*5+4]) for i in range(8)]
        p.knobs=[KnobConfig(cc=d[110+i*20],min_val=d[110+i*20+1],max_val=d[110+i*20+2],
                            mode=d[110+i*20+3],
                            name=bytes(d[110+i*20+4:110+i*20+20]).rstrip(b'\x00').decode('ascii','replace'))
                 for i in range(8)]
        return p

    def to_dict(self):
        return {"index":self.index,"name":self.name,"midi_channel":self.midi_channel,
                "arp_enabled":self.arp_enabled,"arp_mode":self.arp_mode,"arp_division":self.arp_division,
                "arp_octave":self.arp_octave,"arp_tempo":self.arp_tempo,"clock_source":self.clock_source,
                "pads_a":[{"note":p.note,"type_b3":p.type_b3,"type_b4":p.type_b4} for p in self.pads_a],
                "pads_b":[{"note":p.note,"type_b3":p.type_b3,"type_b4":p.type_b4} for p in self.pads_b],
                "knobs":[{"cc":k.cc,"min_val":k.min_val,"max_val":k.max_val,"mode":k.mode,"name":k.name}
                         for k in self.knobs],
                "_raw":list(self._raw) if self._raw else None}

    @classmethod
    def from_dict(cls, d):
        p=cls(index=d.get("index",0));p.name=d.get("name","USER")
        p.midi_channel=d.get("midi_channel",1);p.arp_enabled=d.get("arp_enabled",False)
        p.arp_mode=d.get("arp_mode",0);p.arp_division=d.get("arp_division",2)
        p.arp_octave=d.get("arp_octave",0);p.arp_tempo=d.get("arp_tempo",120)
        p.clock_source=d.get("clock_source",0)
        p.pads_a=[PadConfig(**x) for x in d.get("pads_a",[])] or p.pads_a
        p.pads_b=[PadConfig(**x) for x in d.get("pads_b",[])] or p.pads_b
        p.knobs=[KnobConfig(**x) for x in d.get("knobs",[])] or p.knobs
        raw=d.get("_raw");p._raw=bytes(raw) if raw else None
        return p


# ══════════════════════════════════════════════════════════════════════════════
#  MIDI DEVICE
# ══════════════════════════════════════════════════════════════════════════════

class MPKDevice:
    PAT = ["mpk mini iv","mpk mini","mpk"]
    def __init__(self):
        self._in=rtmidi.MidiIn();self._out=rtmidi.MidiOut()
        self._in.ignore_types(sysex=False);self._buf=[];self._sysex_cb=None

    @classmethod
    def find_ctrl_ports(cls):
        with _quiet_alsa():
            mi=rtmidi.MidiIn();mo=rtmidi.MidiOut()
            def mpk(p): return [(i,n) for i,n in enumerate(p) if any(x in n.lower() for x in cls.PAT)]
            ins=[x for x in mpk(mi.get_ports()) if "software control" in x[1].lower()]
            outs=[x for x in mpk(mo.get_ports()) if "software control" in x[1].lower()]
            if not ins:  ins=mpk(mi.get_ports())[:1]
            if not outs: outs=mpk(mo.get_ports())[:1]
            del mi,mo
        return ins,outs

    @classmethod
    def find_live_ports(cls):
        with _quiet_alsa():
            mi=rtmidi.MidiIn()
            r=[(i,n) for i,n in enumerate(mi.get_ports())
               if any(x in n.lower() for x in cls.PAT) and "software control" not in n.lower()]
            del mi
        return r

    @classmethod
    def list_all_ports(cls):
        with _quiet_alsa():
            mi=rtmidi.MidiIn();mo=rtmidi.MidiOut()
            r=list(enumerate(mi.get_ports())),list(enumerate(mo.get_ports()))
            del mi,mo
        return r

    def connect(self,inp,out):
        self._in.open_port(inp);self._out.open_port(out)
        self._in.set_callback(self._on_midi)

    def disconnect(self):
        if self._in.is_port_open():  self._in.close_port()
        if self._out.is_port_open(): self._out.close_port()

    def is_connected(self): return self._in.is_port_open() and self._out.is_port_open()
    def set_sysex_callback(self,cb): self._sysex_cb=cb

    def _on_midi(self,msg,_=None):
        raw,_=msg
        if not raw: return
        if raw[0]==0xF0:
            if 0xF7 in raw: self._sysex_cb and self._sysex_cb(list(raw))
            else: self._buf=list(raw)
        elif self._buf:
            self._buf.extend(raw)
            if 0xF7 in self._buf:
                d=self._buf[:];self._buf=[]
                self._sysex_cb and self._sysex_cb(d)

    def _sx(self,cmd,data):
        n=len(data)
        return [0xF0,AKAI_MFR_ID,0x00,MPK_DEVICE_ID,cmd,(n>>7)&0x7F,n&0x7F]+data+[0xF7]

    def request_preset(self,i):
        self._out.is_port_open() and self._out.send_message(self._sx(CMD_GET,[i&3]))

    def send_preset(self,p):
        self._out.is_port_open() and self._out.send_message(self._sx(CMD_SET,p.to_payload()))

    def parse_response(self,data):
        if (len(data)>=7+PAYLOAD_LEN and data[0]==0xF0 and data[1]==AKAI_MFR_ID
                and data[3]==MPK_DEVICE_ID and data[4]==CMD_SET):
            return Preset.from_payload(data[7:-1])
        return None

    def create_virtual_port(self,name="MPK mini IV (SelahOS)"):
        v=rtmidi.MidiOut();v.open_virtual_port(name);return v


# ══════════════════════════════════════════════════════════════════════════════
#  CLI MODES
# ══════════════════════════════════════════════════════════════════════════════

def cmd_ports():
    ins,outs=MPKDevice.list_all_ports()
    print("MIDI Inputs:")
    for i,n in ins: print(f"  [{i}] {n}")
    print("\nMIDI Outputs:")
    for i,n in outs: print(f"  [{i}] {n}")

def cmd_monitor():
    dev=MPKDevice();ci,co=MPKDevice.find_ctrl_ports()
    if not ci: print("No MPK found."); return
    dev.set_sysex_callback(lambda d:print(f"SysEx({len(d)}): {' '.join(f'{b:02X}' for b in d[:20])}..."))
    dev.connect(ci[0][0],co[0][0] if co else ci[0][0])
    hs=[]
    for idx,name in MPKDevice.find_live_ports():
        mi=rtmidi.MidiIn();mi.ignore_types(sysex=True);mi.open_port(idx)
        mi.set_callback(lambda m,_,n=name:print(f"[{n.split(':')[-1].strip()}] {' '.join(f'{b:02X}' for b in m[0])}"))
        hs.append(mi)
    try:
        while True: time.sleep(0.1)
    except KeyboardInterrupt: pass
    dev.disconnect()
    for mi in hs:
        try: mi.close_port()
        except: pass


