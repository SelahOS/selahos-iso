def _run_gui():
    try:
        from PyQt6.QtWidgets import (
            QApplication, QMainWindow, QWidget, QVBoxLayout, QHBoxLayout,
            QGridLayout, QLabel, QComboBox, QSpinBox, QCheckBox, QPushButton,
            QGroupBox, QTabWidget, QStatusBar, QMessageBox, QFileDialog,
            QLineEdit, QFrame, QTextEdit, QSizePolicy, QScrollArea,
        )
        from PyQt6.QtCore import Qt, QThread, QTimer, pyqtSignal, pyqtSlot, QRectF
        from PyQt6.QtGui import QFont, QPainter, QColor, QPen, QBrush, QLinearGradient
    except ImportError:
        sys.exit("Error: python-pyqt6 not installed.\n  sudo pacman -S python-pyqt6")

    CONFIG_DIR=Path.home()/".config"/"selah"/"mpk-mini-iv"
    CONFIG_DIR.mkdir(parents=True,exist_ok=True)

    # ══════════════════════════════════════════════════════════════════════════
    #  Virtual OLED display widget
    # ══════════════════════════════════════════════════════════════════════════

    class OLEDWidget(QWidget):
        """Simulates the MPK mini IV 128×32 OLED — updates from MIDI events."""

        def __init__(self, parent=None):
            super().__init__(parent)
            self._l1="MPK mini IV"   # line 1 (large)
            self._l2=""               # line 2 (small)
            self._l3=""               # line 3 (value bar or extra)
            self._mode="idle"         # idle|pad|knob|transport|note|octave
            self._vel=0
            self.setFixedSize(300, 76)
            self._reset=QTimer();self._reset.setSingleShot(True)
            self._reset.timeout.connect(self._go_idle)

        def show_home(self, num, name):
            self._l1=f"PRESET {num}"; self._l2=name; self._l3=""
            self._mode="idle"; self._reset.stop(); self.update()

        def show_pad(self, bank, pad, note, vel):
            self._l1=f"PAD  {bank}{pad}"
            self._l2=f"{nn(note)}   vel: {vel}"
            self._l3=self._bar(vel,127)
            self._vel=vel; self._mode="pad"
            self._reset.start(2200); self.update()

        def show_knob(self, name, cc, val, mn=0, mx=127):
            k=name[:12] if name else f"CC {cc}"
            self._l1=k.upper(); self._l2=f"CC: {cc:03d}   val: {val:03d}"
            span=mx-mn if mx!=mn else 127
            self._l3=self._bar(val-mn, span)
            self._mode="knob"; self._reset.start(2200); self.update()

        def show_note(self, note, vel, ch):
            self._l1=nn(note).ljust(4)+f"  ch {ch:02d}"
            self._l2=f"vel: {vel:03d}"
            self._l3=self._bar(vel,127)
            self._vel=vel; self._mode="note"
            self._reset.start(2200); self.update()

        def show_transport(self, action):
            self._l1=action; self._l2=""; self._l3=""
            self._mode="transport"; self._reset.start(2200); self.update()

        def show_octave(self, offset):
            s="+" if offset>=0 else ""
            self._l1=f"OCTAVE  {s}{offset}"
            self._l2="OCT- / OCT+  controls pitch"
            self._l3=""; self._mode="octave"; self._reset.start(2200); self.update()

        def _bar(self, val, total):
            filled=int(val/max(1,total)*16)
            return "▮"*filled+"▯"*(16-filled)

        def _go_idle(self): self.update()   # parent calls show_home periodically

        def paintEvent(self, _):
            p=QPainter(self)
            p.setRenderHint(QPainter.RenderHint.Antialiasing)
            W,H=self.width(),self.height()

            # Housing
            p.setBrush(QBrush(QColor(8,10,16)))
            p.setPen(QPen(QColor(30,50,90),2))
            p.drawRoundedRect(1,1,W-2,H-2,6,6)

            # Inner glow at top edge (like OLED backlight)
            g=QLinearGradient(0,2,0,14)
            g.setColorAt(0,QColor(40,100,200,35))
            g.setColorAt(1,QColor(0,0,0,0))
            p.fillRect(4,3,W-8,12,g)

            # Mode-dependent accent strip on left edge
            mode_colors={"pad":(0,200,184),"knob":(126,200,227),
                         "transport":(214,168,90),"note":(129,178,154),"octave":(192,115,90)}
            mc=QColor(*mode_colors.get(self._mode,(40,80,140)))
            p.fillRect(3,6,3,H-12,mc)

            # Line 1 — large bright text
            p.setPen(QPen(QColor(C['oled_text'])))
            p.setFont(QFont("JetBrains Mono, Noto Mono, Courier",13,QFont.Weight.Bold))
            p.drawText(12,26,self._l1)

            # Line 2 — secondary text
            p.setFont(QFont("JetBrains Mono, Noto Mono, Courier",10))
            p.setPen(QPen(QColor(C['oled_dim'])))
            p.drawText(12,44,self._l2)

            # Line 3 — value bar or extra
            if self._l3:
                p.setFont(QFont("JetBrains Mono, Noto Mono, Courier",9))
                bar_color=mc
                bar_color.setAlpha(200)
                p.setPen(QPen(bar_color))
                p.drawText(12,62,self._l3)
            p.end()

    # ══════════════════════════════════════════════════════════════════════════
    #  Piano keyboard widget
    # ══════════════════════════════════════════════════════════════════════════

    class PianoWidget(QWidget):
        def __init__(self,start=24,end=84,parent=None):
            super().__init__(parent)
            self._start=start;self._end=end;self._active={}
            self.setMinimumHeight(72)
            self.setSizePolicy(QSizePolicy.Policy.Expanding,QSizePolicy.Policy.Fixed)

        def note_on(self,note,vel):
            if not (self._start<=note<=self._end): return
            if vel>0: self._active[note]=vel
            else:     self._active.pop(note,None)
            self.update()

        def clear(self): self._active.clear();self.update()

        def paintEvent(self,_):
            p=QPainter(self);p.setRenderHint(QPainter.RenderHint.Antialiasing,False)
            W,H=self.width(),self.height()
            wn=[n for n in range(self._start,self._end+1) if IS_WHITE[n%12]]
            if not wn: return
            kw=W/len(wn);bw=kw*0.58;bh=H*0.60
            wx={note:int(i*kw) for i,note in enumerate(wn)}
            p.fillRect(0,0,W,H,QColor(0x1D,0x23,0x33))
            for note in wn:
                x=wx[note];kpx=max(1,int(kw)-1)
                if note in self._active:
                    v=self._active[note]
                    p.setBrush(QBrush(QColor(214,168,90,180+int(v/127*75))))
                else:
                    p.setBrush(QBrush(QColor(210,205,192)))
                p.setPen(QPen(QColor(60,65,85),1))
                p.drawRect(x+1,0,kpx-1,H-1)
                if note%12==0 and kw>=14:
                    p.setPen(QPen(QColor(80,85,100)));p.setFont(QFont("Inter",7))
                    p.drawText(x+2,H-4,nn(note))
            for note in range(self._start,self._end+1):
                if IS_WHITE[note%12]: continue
                prev=note-1
                while prev>=self._start and not IS_WHITE[prev%12]: prev-=1
                if prev<self._start or prev not in wx: continue
                bx=int(wx[prev]+kw*0.62)
                if note in self._active:
                    v=self._active[note]
                    p.setBrush(QBrush(QColor(214,168,90,200+int(v/127*55))))
                else:
                    p.setBrush(QBrush(QColor(22,26,38)))
                p.setPen(QPen(QColor(10,12,18),1))
                p.drawRect(bx,0,int(bw),int(bh))
            p.end()

    # ══════════════════════════════════════════════════════════════════════════
    #  Controller schematic widget — top-down device view
    # ══════════════════════════════════════════════════════════════════════════

    class DeviceWidget(QWidget):
        """Paints a schematic of the MPK mini IV. Call flash_* methods on events."""

        # Layout grid (fractions of widget size)
        # Right section (55% width): pads top, OLED/buttons mid, knobs bottom
        # Left section (45% width): keyboard

        def __init__(self,parent=None):
            super().__init__(parent)
            self.setMinimumSize(760,280)
            self.setSizePolicy(QSizePolicy.Policy.Expanding,QSizePolicy.Policy.Fixed)
            # State: active elements
            self._pads_a={i:0 for i in range(8)}   # 0=off, 1..127=velocity
            self._pads_b={i:0 for i in range(8)}
            self._knobs=[0]*8
            self._transport={}   # label->flash
            self._oct=0          # octave offset
            self._bank='A'       # active bank
            self._key_note=None  # last key press
            self._timers=[]

        def _flash_timer(self,setter,ms=200):
            t=QTimer();t.setSingleShot(True);t.setInterval(ms)
            t.timeout.connect(setter)
            self._timers.append(t)
            t.start()
            return t

        def flash_pad(self,bank,idx,vel):
            if bank=='A': self._pads_a[idx]=vel
            else:         self._pads_b[idx]=vel
            self.update()
            def off():
                if bank=='A': self._pads_a[idx]=0
                else:         self._pads_b[idx]=0
                self.update()
            self._flash_timer(off,200)

        def flash_knob(self,idx):
            self._knobs[idx]=1;self.update()
            def off(): self._knobs[idx]=0;self.update()
            self._flash_timer(off,300)

        def flash_transport(self,label):
            self._transport[label]=1;self.update()
            def off(): self._transport.pop(label,None);self.update()
            self._flash_timer(off,250)

        def set_octave(self,offset): self._oct=offset;self.update()
        def set_bank(self,b):        self._bank=b;self.update()
        def flash_key(self,note):    self._key_note=note;self.update()

        def paintEvent(self,_):
            p=QPainter(self)
            p.setRenderHint(QPainter.RenderHint.Antialiasing)
            W,H=self.width(),self.height()

            # ── Body ────────────────────────────────────────────────────────
            p.setBrush(QBrush(QColor(58,60,66)))
            p.setPen(QPen(QColor(30,32,38),2))
            p.drawRoundedRect(2,2,W-4,H-4,12,12)

            # Divider between keyboard and controls
            KW=int(W*0.43)   # keyboard width
            CX=KW+8          # controls start x

            # ── Keyboard area label ─────────────────────────────────────────
            p.setFont(QFont("Inter",8))
            p.setPen(QPen(QColor(120,120,130)))
            p.drawText(10,H-10,"25-KEY  MIDI KEYBOARD")

            # Simplified keyboard graphic (bottom strip)
            KB_H=int(H*0.28);KB_Y=H-KB_H-4
            for wi in range(25):
                note=(wi+36)  # C2-C4
                x=12+wi*(KW//26)
                kw_=max(1,KW//26-1)
                white=IS_WHITE[note%12]
                active=self._key_note==note
                if white:
                    color=QColor(214,168,90,200) if active else QColor(195,192,182)
                    p.fillRect(x,KB_Y,kw_,KB_H,color)
                    p.setPen(QPen(QColor(60,62,70),1));p.drawRect(x,KB_Y,kw_,KB_H)
            for wi in range(25):
                note=36+wi
                if IS_WHITE[note%12]: continue
                x=12+wi*(KW//26)+int(KW//26*0.6)
                p.fillRect(x,KB_Y,max(1,KW//30),int(KB_H*0.6),QColor(22,24,30))
                p.setPen(QPen(QColor(10,10,15),1))
                p.drawRect(x,KB_Y,max(1,KW//30),int(KB_H*0.6))

            # ── Controls section ─────────────────────────────────────────────
            # Pad grid — 2 banks of 4×2 pads
            PAD_SIZE=int(H*0.16)
            PAD_GAP=4
            # Bank A (left)
            def _draw_pads(bank_dict,start_x,start_y,label):
                p.setFont(QFont("Inter",7,QFont.Weight.Bold))
                p.setPen(QPen(QColor(150,150,160)))
                p.drawText(start_x,start_y-4,f"BANK {label}")
                for row in range(2):
                    for col in range(4):
                        idx=(1-row)*4+col  # pads 0-3 bottom row, 4-7 top row
                        x=start_x+col*(PAD_SIZE+PAD_GAP)
                        y=start_y+row*(PAD_SIZE+PAD_GAP)
                        vel=bank_dict.get(idx,0)
                        if vel:
                            alpha=min(255,150+int(vel/127*105))
                            color=QColor(0,200,184,alpha)
                        else:
                            color=QColor(22,36,48)
                        p.setBrush(QBrush(color))
                        p.setPen(QPen(QColor(10,20,30),1))
                        p.drawRoundedRect(x,y,PAD_SIZE,PAD_SIZE,3,3)
                        p.setFont(QFont("Inter",6))
                        p.setPen(QPen(QColor(80,120,120) if not vel else QColor(0,0,0)))
                        p.drawText(x+2,y+PAD_SIZE-3,f"{label}{idx+1}")

            PY=16
            _draw_pads(self._pads_a,CX,PY,"A")
            _draw_pads(self._pads_b,CX+4*(PAD_SIZE+PAD_GAP)+12,PY,"B")

            # ── OLED placeholder box (actual widget overlaid by caller) ──────
            MID_Y=PY+2*(PAD_SIZE+PAD_GAP)+10
            OLED_X=CX; OLED_W=220; OLED_H=60
            p.setBrush(QBrush(QColor(5,8,14)))
            p.setPen(QPen(QColor(30,60,110),1))
            p.drawRoundedRect(OLED_X,MID_Y,OLED_W,OLED_H,4,4)
            # encoder
            ENC_X=OLED_X+OLED_W+10; ENC_CY=MID_Y+OLED_H//2; ENC_R=16
            p.setBrush(QBrush(QColor(40,42,50)))
            p.setPen(QPen(QColor(80,84,96),1))
            p.drawEllipse(ENC_X,ENC_CY-ENC_R,ENC_R*2,ENC_R*2)
            p.setPen(QPen(QColor(120,124,136)))
            p.setFont(QFont("Inter",6));p.drawText(ENC_X+4,ENC_CY+3,"ENC")

            # ── Transport buttons ─────────────────────────────────────────────
            TRANS_Y=MID_Y+OLED_H+10
            trans_labels=["<<",">>","■","▶","●","↺"]
            trans_keys  =["REW","FFWD","STOP","PLAY","REC","LOOP"]
            BTN_W=28;BTN_H=20;BTN_GAP=4
            for i,(lbl,key) in enumerate(zip(trans_labels,trans_keys)):
                bx=CX+i*(BTN_W+BTN_GAP);by=TRANS_Y
                active=key in self._transport
                if active:
                    p.setBrush(QBrush(QColor(214,168,90)))
                    p.setPen(QPen(QColor(160,120,40),1))
                else:
                    p.setBrush(QBrush(QColor(35,40,50)))
                    p.setPen(QPen(QColor(60,68,80),1))
                p.drawRoundedRect(bx,by,BTN_W,BTN_H,3,3)
                p.setFont(QFont("Inter",8,QFont.Weight.Bold))
                p.setPen(QPen(QColor(10,10,10) if active else QColor(160,160,180)))
                p.drawText(bx+2,by+BTN_H-5,lbl)

            # OCT buttons
            OCT_X=CX+6*(BTN_W+BTN_GAP)+10
            for i,(lbl,dy) in enumerate([("OCT-",0),("OCT+",BTN_H+4)]):
                p.setBrush(QBrush(QColor(30,36,46)))
                p.setPen(QPen(QColor(60,70,90),1))
                p.drawRoundedRect(OCT_X,TRANS_Y+dy,BTN_W+4,BTN_H,3,3)
                p.setFont(QFont("Inter",7,QFont.Weight.Bold))
                p.setPen(QPen(QColor(140,160,180)))
                p.drawText(OCT_X+2,TRANS_Y+dy+BTN_H-5,lbl)
            # Octave display
            sign="+" if self._oct>=0 else ""
            p.setFont(QFont("JetBrains Mono,Noto Mono",8,QFont.Weight.Bold))
            p.setPen(QPen(QColor(C['gold'])))
            p.drawText(OCT_X,TRANS_Y+2*(BTN_H+4)+8,f"oct {sign}{self._oct}")

            # ARP / TAP buttons
            ARP_X=OCT_X+BTN_W+14
            for i,(lbl,col) in enumerate([("ARP",QColor(80,60,140)),("TAP",QColor(50,50,60))]):
                p.setBrush(QBrush(col))
                p.setPen(QPen(QColor(40,40,50)))
                p.drawRoundedRect(ARP_X,TRANS_Y+i*(BTN_H+4),BTN_W+4,BTN_H,3,3)
                p.setFont(QFont("Inter",7,QFont.Weight.Bold))
                p.setPen(QPen(QColor(180,180,220)))
                p.drawText(ARP_X+4,TRANS_Y+i*(BTN_H+4)+BTN_H-5,lbl)

            # ── Knobs 2×4 grid ────────────────────────────────────────────────
            KNOB_Y=TRANS_Y+2*BTN_H+18
            KR=12;KGAP=8
            for i in range(8):
                row=i//4;col=i%4
                cx=CX+col*(KR*2+KGAP)+KR
                cy=KNOB_Y+row*(KR*2+KGAP+8)+KR
                active=self._knobs[i]
                p.setBrush(QBrush(QColor(0,180,220,180) if active else QColor(40,44,54)))
                p.setPen(QPen(QColor(20,120,180) if active else QColor(60,66,78),1))
                p.drawEllipse(cx-KR,cy-KR,KR*2,KR*2)
                p.setFont(QFont("Inter",6))
                p.setPen(QPen(QColor(100,180,210) if active else QColor(80,86,100)))
                p.drawText(cx-7,cy+3,f"K{i+1}")

            p.end()

        def oled_rect(self):
            """Returns the rectangle where the OLED widget should be placed (in parent coords)."""
            W,H=self.width(),self.height()
            KW=int(W*0.43);CX=KW+8
            PAD_SIZE=int(H*0.16);PAD_GAP=4;PY=16
            MID_Y=PY+2*(PAD_SIZE+PAD_GAP)+10
            return CX,MID_Y,220,60

    # ══════════════════════════════════════════════════════════════════════════
    #  Device watcher thread
    # ══════════════════════════════════════════════════════════════════════════

    class DevThread(QThread):
        connected    = pyqtSignal(str)
        disconnected = pyqtSignal()
        sysex_rx     = pyqtSignal(list)
        raw_midi     = pyqtSignal(list, str)

        def __init__(self,dev,parent=None):
            super().__init__(parent)
            self._dev=dev;self._running=True;self._conn=False;self._live={}

        def _make_cb(self,label):
            def cb(msg,_=None):
                raw,_=msg
                if raw: self.raw_midi.emit(list(raw),label)
            return cb

        def run(self):
            self._dev.set_sysex_callback(lambda d:self.sysex_rx.emit(d))
            while self._running:
                try:
                    ci,co=MPKDevice.find_ctrl_ports()
                    if ci and co and not self._conn:
                        self._dev.connect(ci[0][0],co[0][0]);self._conn=True
                        self.connected.emit(ci[0][1].split(":")[0].strip())
                    elif not ci and self._conn:
                        self._dev.disconnect();self._conn=False;self.disconnected.emit()
                    live_now={f"{i}:{n}":(i,self._plbl(n)) for i,n in MPKDevice.find_live_ports()}
                    for key,(idx,lbl) in live_now.items():
                        if key not in self._live:
                            with _quiet_alsa():
                                mi=rtmidi.MidiIn();mi.ignore_types(sysex=True)
                                mi.open_port(idx)
                            mi.set_callback(self._make_cb(lbl))
                            self._live[key]=mi
                    for key in list(self._live):
                        if key not in live_now:
                            try: self._live[key].close_port()
                            except: pass
                            del self._live[key]
                except Exception: pass
                self.msleep(1500)
            for mi in self._live.values():
                try: mi.close_port()
                except: pass

        @staticmethod
        def _plbl(n):
            n=n.lower()
            if "daw"    in n: return "DAW"
            if "plugin" in n: return "PLUGIN"
            if "din"    in n: return "DIN"
            return "MIDI"

        def stop(self): self._running=False;self.wait()

    # ══════════════════════════════════════════════════════════════════════════
    #  Helpers
    # ══════════════════════════════════════════════════════════════════════════

    def hsep():
        f=QFrame();f.setFixedHeight(1)
        f.setStyleSheet(f"background:{C['border2']};border:none;");return f

    def slbl(text):
        l=QLabel(text);l.setFont(QFont("Inter",12,QFont.Weight.Medium))
        l.setStyleSheet(f"color:{C['gold']};margin-bottom:4px;");return l

    def flbl(text):
        l=QLabel(text)
        l.setStyleSheet(f"color:{C['muted']};font-size:11px;font-weight:600;");return l

    def make_pad(label):
        grp=QGroupBox(label)
        g=QGridLayout(grp);g.setSpacing(4);g.setContentsMargins(8,14,8,8)
        note=QSpinBox();note.setRange(0,127)
        nn_lbl=QLabel("C2");nn_lbl.setAlignment(Qt.AlignmentFlag.AlignCenter)
        nn_lbl.setStyleSheet(f"color:{C['gold']};font-size:11px;font-weight:700;"
                             f"background:rgba(214,168,90,0.08);border-radius:4px;padding:2px 4px;")
        note.valueChanged.connect(lambda v:nn_lbl.setText(nn(v)))
        g.addWidget(flbl("NOTE"),0,0,1,2);g.addWidget(note,1,0,1,2);g.addWidget(nn_lbl,2,0,1,2)
        _t=QTimer();_t.setSingleShot(True);_t.setInterval(180)
        def _off(): grp.setProperty("active","false");grp.style().unpolish(grp);grp.style().polish(grp)
        _t.timeout.connect(_off)
        def flash(vel=127):
            grp.setProperty("active","true");grp.style().unpolish(grp);grp.style().polish(grp);_t.start()
        def load(c): note.blockSignals(True);note.setValue(c.note);note.blockSignals(False);nn_lbl.setText(nn(c.note))
        def get(): return PadConfig(note=note.value())
        grp.flash=flash;grp.load=load;grp.get=get;grp._t=_t
        return grp

    def make_knob(idx):
        grp=QGroupBox(f"K{idx+1}")
        g=QGridLayout(grp);g.setSpacing(4);g.setContentsMargins(8,14,8,8)
        cc=QSpinBox();cc.setRange(0,127)
        mn=QSpinBox();mn.setRange(0,127)
        mx=QSpinBox();mx.setRange(0,127);mx.setValue(127)
        mod=QComboBox();mod.addItems(KNOB_MODES)
        name=QLineEdit();name.setMaxLength(16);name.setPlaceholderText("Name")
        val_lbl=QLabel("—")
        val_lbl.setAlignment(Qt.AlignmentFlag.AlignCenter)
        val_lbl.setStyleSheet(f"color:{C['gold_lt']};font-size:13px;font-weight:700;"
                              f"background:rgba(214,168,90,0.10);border-radius:4px;padding:2px 0;")
        g.addWidget(flbl("CC"),0,0);g.addWidget(cc,0,1)
        g.addWidget(flbl("MIN"),1,0);g.addWidget(mn,1,1)
        g.addWidget(flbl("MAX"),2,0);g.addWidget(mx,2,1)
        g.addWidget(mod,3,0,1,2);g.addWidget(flbl("NAME"),4,0);g.addWidget(name,4,1)
        g.addWidget(val_lbl,5,0,1,2)
        _t=QTimer();_t.setSingleShot(True);_t.setInterval(300)
        def _off(): grp.setProperty("knob_active","false");grp.style().unpolish(grp);grp.style().polish(grp)
        _t.timeout.connect(_off)
        def flash(v=None):
            if v is not None: val_lbl.setText(str(v))
            grp.setProperty("knob_active","true");grp.style().unpolish(grp);grp.style().polish(grp);_t.start()
        def load(k):
            for w in [cc,mn,mx,mod]: w.blockSignals(True)
            cc.setValue(k.cc);mn.setValue(k.min_val);mx.setValue(k.max_val)
            mod.setCurrentIndex(k.mode);name.setText(k.name)
            for w in [cc,mn,mx,mod]: w.blockSignals(False)
            val_lbl.setText("—")
        def get(): return KnobConfig(cc=cc.value(),min_val=mn.value(),max_val=mx.value(),
                                     mode=mod.currentIndex(),name=name.text())
        grp.flash=flash;grp.load=load;grp.get=get;grp._t=_t;grp.val_lbl=val_lbl
        return grp

    # ══════════════════════════════════════════════════════════════════════════
    #  Main window
