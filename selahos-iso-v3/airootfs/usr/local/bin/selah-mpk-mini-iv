            self._clbl.setStyleSheet(f"color:{C['red']};")
            hl.addWidget(brand);hl.addWidget(title);hl.addStretch()
            hl.addWidget(self._dot);hl.addWidget(self._clbl)
            root.addWidget(hdr)

            # Toolbar
            tbar=QWidget();tbar.setFixedHeight(52)
            tbar.setStyleSheet(f"background:{C['bg']};border-bottom:1px solid {C['border2']};")
            tl=QHBoxLayout(tbar);tl.setContentsMargins(20,8,20,8);tl.setSpacing(10)
            tl.addWidget(flbl("PRESET"))
            self._psel=QComboBox()
            self._psel.addItems(["1 — Preset 1","2 — Preset 2","3 — Preset 3","4 — Preset 4"])
            self._psel.setFixedWidth(160);self._psel.currentIndexChanged.connect(self._on_pchg)
            self._name_edit=QLineEdit();self._name_edit.setMaxLength(16)
            self._name_edit.setPlaceholderText("Preset name");self._name_edit.setFixedWidth(130)
            self._gbtn=QPushButton("Get Preset",objectName="action")
            self._sbtn=QPushButton("Send Preset",objectName="action")
            self._syncbtn=QPushButton("Sync All  ↺",objectName="action")
            self._gbtn.clicked.connect(self._on_get);self._sbtn.clicked.connect(self._on_send)
            self._syncbtn.clicked.connect(self._sync_all)
            tl.addWidget(self._psel);tl.addSpacing(4);tl.addWidget(self._name_edit)
            tl.addStretch();tl.addWidget(self._syncbtn);tl.addWidget(self._gbtn);tl.addWidget(self._sbtn)
            root.addWidget(tbar)

            # Tabs
            body=QWidget();body.setStyleSheet(f"background:{C['bg']};")
            bl=QVBoxLayout(body);bl.setContentsMargins(14,14,14,8);bl.setSpacing(0)
            tabs=QTabWidget()

            # ── Controller tab ──────────────────────────────────────────────
            wctl=QWidget();lctl=QVBoxLayout(wctl);lctl.setContentsMargins(8,8,8,8);lctl.setSpacing(8)
            lctl.addWidget(slbl("MPK mini IV  —  Live Controller View"))

            # Device schematic
            self._device=DeviceWidget()
            lctl.addWidget(self._device)

            # OLED + octave row (below schematic)
            oled_row=QHBoxLayout();oled_row.setSpacing(20)
            self._oled=OLEDWidget()
            oled_row.addWidget(self._oled)

            # Octave controls (same row as OLED)
            oled_row.addSpacing(24)
            oct_vbox=QVBoxLayout();oct_vbox.setSpacing(6)
            oct_vbox.addWidget(slbl("Octave"))
            oct_inner=QHBoxLayout();oct_inner.setSpacing(6)
            oct_dn=QPushButton("OCT  −",objectName="action")
            oct_up=QPushButton("OCT  +",objectName="action")
            self._oct_lbl=QLabel("0");self._oct_lbl.setFixedWidth(30)
            self._oct_lbl.setFont(QFont("Inter",14,QFont.Weight.Bold))
            self._oct_lbl.setStyleSheet(f"color:{C['gold']};")
            oct_dn.setFixedWidth(90);oct_up.setFixedWidth(90)
            oct_dn.clicked.connect(lambda:self._adj_oct(-1))
            oct_up.clicked.connect(lambda:self._adj_oct(+1))
            oct_inner.addWidget(oct_dn);oct_inner.addWidget(self._oct_lbl);oct_inner.addWidget(oct_up)
            oct_vbox.addLayout(oct_inner)
            oled_row.addLayout(oct_vbox)
            oled_row.addStretch()
            lctl.addLayout(oled_row)
            lctl.addStretch()
            tabs.addTab(wctl,"Controller")

            # ── Pad tabs
            def _pad_tab(label,pads_list):
                w=QWidget();l=QVBoxLayout(w);l.setContentsMargins(12,12,12,12);l.setSpacing(8)
                l.addWidget(slbl(label))
                g=QGridLayout();g.setSpacing(8)
                for i,pw in enumerate(pads_list): g.addWidget(pw,0,i)
                l.addLayout(g);l.addStretch();return w

            self._pads_a=[make_pad(f"A{i+1}") for i in range(8)]
            self._pads_b=[make_pad(f"B{i+1}") for i in range(8)]
            tabs.addTab(_pad_tab("Bank A  —  Pads 1–8",self._pads_a),"Pads — Bank A")
            tabs.addTab(_pad_tab("Bank B  —  Pads 1–8",self._pads_b),"Pads — Bank B")

            # ── Knob tab
            wk=QWidget();lk=QVBoxLayout(wk);lk.setContentsMargins(12,12,12,12);lk.setSpacing(8)
