def _run_gui():
    try:
        from PyQt6.QtWidgets import (
            QApplication, QMainWindow, QWidget, QVBoxLayout, QHBoxLayout,
            QGridLayout, QLabel, QComboBox, QSpinBox, QCheckBox, QPushButton,
            QGroupBox, QTabWidget, QStatusBar, QMessageBox, QFileDialog,
            QLineEdit, QFrame,
        )
        from PyQt6.QtCore import Qt, QThread, QTimer, pyqtSignal, pyqtSlot
        from PyQt6.QtGui import QFont
    except ImportError:
        sys.exit("Error: python-pyqt6 not installed.\n  sudo pacman -S python-pyqt6")

    CONFIG_DIR = Path.home() / ".config" / "selah" / "mpk-mini-iv"
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)

    # ── Device + live MIDI watcher thread ────────────────────────────────────

    class DevThread(QThread):
        connected    = pyqtSignal(str)
        disconnected = pyqtSignal()
        sysex_rx     = pyqtSignal(list)
        note_on      = pyqtSignal(int, int)   # note, velocity
        cc_change    = pyqtSignal(int, int)   # cc, value

        def __init__(self, dev, parent=None):
            super().__init__(parent)
            self._dev=dev; self._running=True; self._conn=False
            self._live_mi=None

        def _on_live(self, msg, _=None):
            raw,_ = msg
            if not raw: return
            status = raw[0] & 0xF0
            if len(raw) >= 3:
                if status == 0x90:   # Note On
                    self.note_on.emit(raw[1], raw[2])
                elif status == 0x80: # Note Off
                    self.note_on.emit(raw[1], 0)
                elif status == 0xB0: # CC
                    self.cc_change.emit(raw[1], raw[2])

        def run(self):
            self._dev.set_sysex_callback(lambda d: self.sysex_rx.emit(d))
            while self._running:
                try:
                    ins_ctrl,outs_ctrl = MPKDevice.find_ports(prefer_sysex=True)
                    ins_live,_         = MPKDevice.find_ports(prefer_sysex=False)

                    # SysEx / editor connection
                    if ins_ctrl and outs_ctrl and not self._conn:
                        self._dev.connect(ins_ctrl[0][0], outs_ctrl[0][0])
                        self._conn=True
                        self.connected.emit(ins_ctrl[0][1].split(":")[0].strip())
                    elif not ins_ctrl and self._conn:
                        self._dev.disconnect(); self._conn=False
                        self.disconnected.emit()

                    # Live MIDI connection (MIDI Port — notes + CC)
                    if ins_live and self._live_mi is None:
                        mi = rtmidi.MidiIn()
                        mi.ignore_types(sysex=True)
                        mi.open_port(ins_live[0][0])
                        mi.set_callback(self._on_live)
                        self._live_mi = mi
                    elif not ins_live and self._live_mi is not None:
                        try: self._live_mi.close_port()
                        except: pass
                        self._live_mi = None

                except Exception:
                    pass
                self.msleep(1500)

            # Cleanup
            if self._live_mi:
                try: self._live_mi.close_port()
                except: pass

        def stop(self):
            self._running=False
            self.wait()

    # ── Helpers ──────────────────────────────────────────────────────────────

    def hsep():
        f=QFrame(); f.setFixedHeight(1)
        f.setStyleSheet(f"background:{C['border2']};border:none;"); return f

    def section_lbl(text):
        l=QLabel(text); l.setFont(QFont("Inter",12,QFont.Weight.Medium))
        l.setStyleSheet(f"color:{C['gold']};margin-bottom:4px;"); return l

    def field_lbl(text):
        l=QLabel(text)
        l.setStyleSheet(f"color:{C['muted']};font-size:11px;font-weight:600;"); return l

    # ── Pad widget with flash ─────────────────────────────────────────────────

    def make_pad(label: str):
        grp=QGroupBox(label)
        g=QGridLayout(grp); g.setSpacing(4); g.setContentsMargins(8,14,8,8)

        note=QSpinBox(); note.setRange(0,127)
        nn_lbl=QLabel("C2")
        nn_lbl.setAlignment(Qt.AlignmentFlag.AlignCenter)
        nn_lbl.setStyleSheet(
            f"color:{C['gold']};font-size:11px;font-weight:700;"
            f"background:rgba(214,168,90,0.08);border-radius:4px;padding:2px 4px;")

        def _upd(v): nn_lbl.setText(nn(v))
        note.valueChanged.connect(_upd)

        g.addWidget(field_lbl("NOTE"),0,0,1,2)
        g.addWidget(note,1,0,1,2)
        g.addWidget(nn_lbl,2,0,1,2)

        # Flash timer — lights up on pad hit
        _timer=QTimer(); _timer.setSingleShot(True); _timer.setInterval(200)
        def _flash_off():
            grp.setProperty("active","false")
            grp.style().unpolish(grp); grp.style().polish(grp)
        _timer.timeout.connect(_flash_off)

        def flash(velocity=127):
            grp.setProperty("active","true")
            grp.style().unpolish(grp); grp.style().polish(grp)
            _timer.start()

        def load(c: PadConfig):
            note.blockSignals(True); note.setValue(c.note); note.blockSignals(False)
            nn_lbl.setText(nn(c.note))

        def get() -> PadConfig:
            return PadConfig(note=note.value())

        grp.flash=flash; grp.load=load; grp.get=get
        grp._timer=_timer  # keep alive
        return grp

    # ── Knob widget with flash ────────────────────────────────────────────────

    def make_knob(idx: int):
        grp=QGroupBox(f"K{idx+1}")
        g=QGridLayout(grp); g.setSpacing(4); g.setContentsMargins(8,14,8,8)

        cc=QSpinBox();  cc.setRange(0,127)
        mn=QSpinBox();  mn.setRange(0,127)
        mx=QSpinBox();  mx.setRange(0,127); mx.setValue(127)
        mod=QComboBox(); mod.addItems(KNOB_MODES)
        name=QLineEdit(); name.setMaxLength(16); name.setPlaceholderText("Name")

        g.addWidget(field_lbl("CC"),  0,0); g.addWidget(cc,  0,1)
        g.addWidget(field_lbl("MIN"), 1,0); g.addWidget(mn,  1,1)
        g.addWidget(field_lbl("MAX"), 2,0); g.addWidget(mx,  2,1)
        g.addWidget(mod,3,0,1,2)
        g.addWidget(field_lbl("NAME"),4,0); g.addWidget(name,4,1)

        # Flash timer — lights up on knob turn
        _timer=QTimer(); _timer.setSingleShot(True); _timer.setInterval(300)
        def _flash_off():
            grp.setProperty("knob_active","false")
            grp.style().unpolish(grp); grp.style().polish(grp)
        _timer.timeout.connect(_flash_off)

        def flash():
            grp.setProperty("knob_active","true")
            grp.style().unpolish(grp); grp.style().polish(grp)
            _timer.start()

        def load(k: KnobConfig):
            for w in [cc,mn,mx,mod]: w.blockSignals(True)
            cc.setValue(k.cc); mn.setValue(k.min_val); mx.setValue(k.max_val)
            mod.setCurrentIndex(k.mode); name.setText(k.name)
            for w in [cc,mn,mx,mod]: w.blockSignals(False)

        def get() -> KnobConfig:
            return KnobConfig(cc=cc.value(),min_val=mn.value(),max_val=mx.value(),
                              mode=mod.currentIndex(),name=name.text())
        grp.flash=flash; grp.load=load; grp.get=get
        grp._timer=_timer
        return grp

    # ── Main window ──────────────────────────────────────────────────────────

    class Win(QMainWindow):
        def __init__(self):
            super().__init__()
            self.setWindowTitle("MPK mini IV — SelahOS")
            self.setMinimumSize(1020, 740)
            self._dev     = MPKDevice()
            self._presets = [Preset(index=i) for i in range(4)]
            self._cur     = 0
            self._thread  = DevThread(self._dev)
            self._vport   = None
            self._load_local()
            self._build()
            self.setStyleSheet(QSS)
            self._thread.connected.connect(self._on_conn)
            self._thread.disconnected.connect(self._on_disc)
            self._thread.sysex_rx.connect(self._on_sysex)
            self._thread.note_on.connect(self._on_note)
            self._thread.cc_change.connect(self._on_cc)
            self._thread.start()
            self._load_ui(0)

        def _build(self):
            root_w=QWidget(); self.setCentralWidget(root_w)
            root=QVBoxLayout(root_w); root.setSpacing(0); root.setContentsMargins(0,0,0,0)

            # Header
            hdr=QWidget(); hdr.setFixedHeight(56)
            hdr.setStyleSheet(f"background:{C['bg2']};border-bottom:1px solid {C['border2']};")
            hl=QHBoxLayout(hdr); hl.setContentsMargins(20,0,20,0); hl.setSpacing(0)
            brand=QLabel("SELAH"); brand.setFont(QFont("Inter",15,QFont.Weight.Bold))
            brand.setStyleSheet(f"color:{C['gold']};letter-spacing:4px;")
            title=QLabel("  MPK mini IV Editor"); title.setFont(QFont("Inter",13))
            title.setStyleSheet(f"color:rgba(255,255,255,0.65);")
            self._dot=QLabel("●  "); self._dot.setStyleSheet(f"color:{C['red']};font-size:10px;")
            self._clbl=QLabel("Not connected"); self._clbl.setFont(QFont("Inter",11))
            self._clbl.setStyleSheet(f"color:{C['red']};")
            hl.addWidget(brand); hl.addWidget(title); hl.addStretch()
            hl.addWidget(self._dot); hl.addWidget(self._clbl)
            root.addWidget(hdr)

            # Toolbar
            tbar=QWidget(); tbar.setFixedHeight(52)
            tbar.setStyleSheet(f"background:{C['bg']};border-bottom:1px solid {C['border2']};")
            tl=QHBoxLayout(tbar); tl.setContentsMargins(20,8,20,8); tl.setSpacing(10)
            tl.addWidget(field_lbl("PRESET"))
            self._psel=QComboBox()
            self._psel.addItems(["1 — Preset 1","2 — Preset 2","3 — Preset 3","4 — Preset 4"])
            self._psel.setFixedWidth(160)
            self._psel.currentIndexChanged.connect(self._on_pchg)
            self._name_edit=QLineEdit(); self._name_edit.setMaxLength(16)
            self._name_edit.setPlaceholderText("Preset name"); self._name_edit.setFixedWidth(130)
            self._gbtn=QPushButton("Get from Device",objectName="action")
            self._sbtn=QPushButton("Send to Device",objectName="action")
            self._gbtn.clicked.connect(self._on_get); self._sbtn.clicked.connect(self._on_send)
            tl.addWidget(self._psel); tl.addSpacing(4); tl.addWidget(self._name_edit)
            tl.addStretch(); tl.addWidget(self._gbtn); tl.addWidget(self._sbtn)
            root.addWidget(tbar)

            # Tabs
            body=QWidget(); body.setStyleSheet(f"background:{C['bg']};")
            bl=QVBoxLayout(body); bl.setContentsMargins(16,16,16,8); bl.setSpacing(0)
            tabs=QTabWidget()

            def _pad_tab(bank_label, pads_list):
                w=QWidget(); l=QVBoxLayout(w); l.setContentsMargins(12,12,12,12); l.setSpacing(8)
                l.addWidget(section_lbl(bank_label))
                g=QGridLayout(); g.setSpacing(8)
                for i,pw in enumerate(pads_list): g.addWidget(pw,0,i)
                l.addLayout(g); l.addStretch(); return w

            self._pads_a=[make_pad(f"A{i+1}") for i in range(8)]
            self._pads_b=[make_pad(f"B{i+1}") for i in range(8)]
            tabs.addTab(_pad_tab("Bank A  —  Pads 1–8",self._pads_a),"Pads — Bank A")
            tabs.addTab(_pad_tab("Bank B  —  Pads 1–8",self._pads_b),"Pads — Bank B")

            wk=QWidget(); lk=QVBoxLayout(wk); lk.setContentsMargins(12,12,12,12); lk.setSpacing(8)
            lk.addWidget(section_lbl("Knobs 1–8  —  CC Assignments & Range"))
            gk=QGridLayout(); gk.setSpacing(8)
            self._knobs=[make_knob(i) for i in range(8)]
            for i,kw in enumerate(self._knobs): gk.addWidget(kw,0,i)
            lk.addLayout(gk); lk.addStretch()
            tabs.addTab(wk,"Knobs")

            # Arp tab
            war=QWidget(); lar=QVBoxLayout(war); lar.setContentsMargins(20,16,20,16); lar.setSpacing(12)
            lar.addWidget(section_lbl("Arpeggiator"))
            self._arp_on=QCheckBox("Arpeggiator Enabled")
            self._arp_on.setFont(QFont("Inter",13,QFont.Weight.Medium))
            lar.addWidget(self._arp_on); lar.addWidget(hsep())
            ag=QWidget(); agl=QGridLayout(ag); agl.setSpacing(10); agl.setColumnMinimumWidth(0,120)
            self._arp_mode=QComboBox(); self._arp_mode.addItems(ARP_MODES)
            self._arp_div =QComboBox(); self._arp_div.addItems(ARP_DIVS)
            self._arp_oct =QComboBox(); self._arp_oct.addItems(ARP_OCTS)
            self._arp_bpm =QSpinBox();  self._arp_bpm.setRange(20,127)
            self._arp_clk =QComboBox(); self._arp_clk.addItems(["Internal","External"])
            for r,(l,w) in enumerate([("Mode",self._arp_mode),("Division",self._arp_div),
                                       ("Octave",self._arp_oct),("Tempo (BPM)",self._arp_bpm),
                                       ("Clock Source",self._arp_clk)]):
                agl.addWidget(field_lbl(l),r,0); agl.addWidget(w,r,1)
            agl.setRowStretch(5,1)
            lar.addWidget(ag); lar.addStretch()
            tabs.addTab(war,"Arpeggiator")

            # Global tab
            wgl=QWidget(); lgl=QVBoxLayout(wgl); lgl.setContentsMargins(20,16,20,16); lgl.setSpacing(12)
            lgl.addWidget(section_lbl("Global Settings"))
            gg=QWidget(); ggl=QGridLayout(gg); ggl.setSpacing(10); ggl.setColumnMinimumWidth(0,120)
            self._gl_ch=QSpinBox(); self._gl_ch.setRange(1,16)
            ggl.addWidget(field_lbl("MIDI Channel"),0,0); ggl.addWidget(self._gl_ch,0,1)
            ggl.setRowStretch(1,1)
            lgl.addWidget(gg); lgl.addStretch()
            tabs.addTab(wgl,"Global")

            # Routing tab
            wrt=QWidget(); lrt=QVBoxLayout(wrt); lrt.setContentsMargins(20,16,20,16); lrt.setSpacing(12)
            lrt.addWidget(section_lbl("MIDI Routing"))
            info=QLabel(
                "MPK mini IV is USB class-compliant — ALSA and PipeWire detect it automatically on plug-in.\n"
                "No additional routing is required for native SelahOS apps (Ardour, Bitwig, Qtractor, etc.).\n\n"
                "SelahBridgePro: Wine DAWs (Digital Performer, etc.) receive MIDI via the WineASIO bridge.\n\n"
                "Note: 'Send to Device' writes to the active preset in device RAM — takes effect immediately.\n"
                "Power-cycle the controller after sending to commit changes to flash permanently."
            )
            info.setWordWrap(True)
            info.setStyleSheet(f"color:rgba(255,255,255,0.6);font-size:12px;")
            lrt.addWidget(info); lrt.addWidget(hsep())
            self._vbtn=QPushButton("Create Virtual MIDI Port  —  'MPK mini IV (SelahOS)'",objectName="action")
            self._vbtn.clicked.connect(self._on_vport)
            self._vstatus=QLabel("Virtual port: not active")
            self._vstatus.setStyleSheet(f"color:{C['muted']};font-size:11px;")
            lrt.addWidget(self._vbtn); lrt.addWidget(self._vstatus); lrt.addStretch()
            tabs.addTab(wrt,"MIDI Routing")

            bl.addWidget(tabs)

            # Bottom bar
            bbar=QWidget(); bbar.setFixedHeight(44)
            bbar.setStyleSheet(f"background:{C['bg2']};border-top:1px solid {C['border2']};")
            bbl=QHBoxLayout(bbar); bbl.setContentsMargins(16,0,16,0); bbl.setSpacing(8)
            sf=QPushButton("Save Preset…"); lf=QPushButton("Load Preset…")
            sf.clicked.connect(self._save_file); lf.clicked.connect(self._load_file)
            copy=QLabel("Selah Technologies LLC  ·  SelahBridgePro")
            copy.setStyleSheet(f"color:{C['dim']};font-size:10px;letter-spacing:0.5px;")
            bbl.addWidget(sf); bbl.addWidget(lf); bbl.addStretch(); bbl.addWidget(copy)

            root.addWidget(body,1); root.addWidget(bbar)
            self.setStatusBar(QStatusBar())
            self.statusBar().showMessage("Waiting for MPK mini IV — plug in to connect")

        # ── Live MIDI feedback ────────────────────────────────────────────────

        @pyqtSlot(int, int)
        def _on_note(self, note: int, velocity: int):
            p = self._presets[self._cur]
            for j,pw in enumerate(self._pads_a):
                if p.pads_a[j].note == note:
                    pw.flash(velocity); return
            for j,pw in enumerate(self._pads_b):
                if p.pads_b[j].note == note:
                    pw.flash(velocity); return

        @pyqtSlot(int, int)
        def _on_cc(self, cc: int, value: int):
            p = self._presets[self._cur]
            for j,kw in enumerate(self._knobs):
                if p.knobs[j].cc == cc:
                    kw.flash(); return

        # ── Device connection ─────────────────────────────────────────────────

        @pyqtSlot(str)
        def _on_conn(self,name):
            self._dot.setStyleSheet(f"color:{C['green']};font-size:10px;")
            self._clbl.setText(name); self._clbl.setStyleSheet(f"color:{C['green']};")
            self.statusBar().showMessage(f"Connected: {name}  —  click 'Get from Device' to load presets")

        @pyqtSlot()
        def _on_disc(self):
            self._dot.setStyleSheet(f"color:{C['red']};font-size:10px;")
            self._clbl.setText("Not connected"); self._clbl.setStyleSheet(f"color:{C['red']};")
            self.statusBar().showMessage("MPK mini IV disconnected")

        @pyqtSlot(list)
        def _on_sysex(self,data):
            preset=self._dev.parse_response(data)
            if preset:
                idx=preset.index if preset.index<4 else self._cur
                self._presets[idx]=preset
                if idx==self._cur: self._load_ui(idx)
                self._psel.setItemText(idx,f"{idx+1} — {preset.name}")
                self.statusBar().showMessage(f"Preset {idx+1}  '{preset.name}'  loaded from device")
                self._save_local()

        def _on_pchg(self,i):
            self._save_ui(self._cur); self._cur=i; self._load_ui(i)

        def _load_ui(self,i):
            p=self._presets[i]; self._name_edit.setText(p.name)
            for j,pw in enumerate(self._pads_a): pw.load(p.pads_a[j])
            for j,pw in enumerate(self._pads_b): pw.load(p.pads_b[j])
            for j,kw in enumerate(self._knobs):  kw.load(p.knobs[j])
            for w in [self._arp_on,self._arp_mode,self._arp_div,
                      self._arp_oct,self._arp_bpm,self._arp_clk,self._gl_ch]:
                w.blockSignals(True)
            self._arp_on.setChecked(p.arp_enabled); self._arp_mode.setCurrentIndex(p.arp_mode)
            self._arp_div.setCurrentIndex(p.arp_division); self._arp_oct.setCurrentIndex(p.arp_octave)
            self._arp_bpm.setValue(p.arp_tempo); self._arp_clk.setCurrentIndex(p.clock_source)
            self._gl_ch.setValue(p.midi_channel)
            for w in [self._arp_on,self._arp_mode,self._arp_div,
                      self._arp_oct,self._arp_bpm,self._arp_clk,self._gl_ch]:
                w.blockSignals(False)

        def _save_ui(self,i):
            p=self._presets[i]; p.name=self._name_edit.text() or p.name
            for j,pw in enumerate(self._pads_a):
                pad=pw.get(); pad.type_b3=p.pads_a[j].type_b3; pad.type_b4=p.pads_a[j].type_b4
                p.pads_a[j]=pad
            for j,pw in enumerate(self._pads_b):
                pad=pw.get(); pad.type_b3=p.pads_b[j].type_b3; pad.type_b4=p.pads_b[j].type_b4
                p.pads_b[j]=pad
            for j,kw in enumerate(self._knobs): p.knobs[j]=kw.get()
            p.arp_enabled=self._arp_on.isChecked(); p.arp_mode=self._arp_mode.currentIndex()
            p.arp_division=self._arp_div.currentIndex(); p.arp_octave=self._arp_oct.currentIndex()
            p.arp_tempo=self._arp_bpm.value(); p.clock_source=self._arp_clk.currentIndex()
            p.midi_channel=self._gl_ch.value()

        def _on_get(self):
            if not self._dev.is_connected():
                QMessageBox.warning(self,"Not Connected","Plug in the MPK mini IV first."); return
            self._dev.request_preset(self._cur)
            self.statusBar().showMessage(f"Requesting preset {self._cur+1} from device…")

        def _on_send(self):
            if not self._dev.is_connected():
                QMessageBox.warning(self,"Not Connected","Plug in the MPK mini IV first."); return
            self._save_ui(self._cur); self._dev.send_preset(self._presets[self._cur])
            self._save_local()
            self.statusBar().showMessage(
                f"Preset {self._cur+1} sent to device  —  power-cycle to save permanently to flash")

        def _on_vport(self):
            if self._vport: return
            self._vport=self._dev.create_virtual_port()
            self._vstatus.setText("Active:  MPK mini IV (SelahOS)")
            self._vstatus.setStyleSheet(f"color:{C['green']};font-size:11px;")

        def _save_file(self):
            self._save_ui(self._cur)
            path,_=QFileDialog.getSaveFileName(self,"Save Preset",str(CONFIG_DIR),"MPK Preset (*.mpkpreset)")
            if not path: return
            if not path.endswith(".mpkpreset"): path+=".mpkpreset"
            Path(path).write_text(json.dumps(self._presets[self._cur].to_dict(),indent=2))
            self.statusBar().showMessage(f"Saved:  {path}")

        def _load_file(self):
            path,_=QFileDialog.getOpenFileName(self,"Load Preset",str(CONFIG_DIR),"MPK Preset (*.mpkpreset)")
            if not path: return
            try:
                p=Preset.from_dict(json.loads(Path(path).read_text()))
                p.index=self._cur; self._presets[self._cur]=p; self._load_ui(self._cur)
                self.statusBar().showMessage(f"Loaded:  {path}")
            except Exception as e:
                QMessageBox.critical(self,"Load Error",str(e))

        def _save_local(self):
            self._save_ui(self._cur)
            (CONFIG_DIR/"presets.json").write_text(json.dumps([p.to_dict() for p in self._presets],indent=2))

        def _load_local(self):
            p=CONFIG_DIR/"presets.json"
            if not p.exists(): return
            try:
                for i,d in enumerate(json.loads(p.read_text())[:4]):
                    self._presets[i]=Preset.from_dict(d); self._presets[i].index=i
            except Exception: pass

        def closeEvent(self,e):
            self._save_local(); self._thread.stop(); self._dev.disconnect(); super().closeEvent(e)

    # Ignore SIGHUP so the app survives terminal close
    signal.signal(signal.SIGHUP, signal.SIG_IGN)

    app=QApplication(sys.argv)
    app.setApplicationName("MPK mini IV Editor")
    app.setOrganizationName("Selah Technologies")
    win=Win(); win.show()
    sys.exit(app.exec())


# ══════════════════════════════════════════════════════════════════════════════
#  MAIN
# ══════════════════════════════════════════════════════════════════════════════

def main():
    ap=argparse.ArgumentParser(description="selah-mpk-mini-iv — MPK mini IV Editor for SelahOS")
    ap.add_argument("--ports",   action="store_true",help="List MIDI ports and exit")
    ap.add_argument("--monitor", action="store_true",help="Print incoming MIDI messages")
    args=ap.parse_args()
    if args.ports:     cmd_ports()
    elif args.monitor: cmd_monitor()
    else:              _run_gui()

if __name__=="__main__":
    main()
