            self._cur=0
            self._thread=DevThread(self._dev)
            self._vport=None
            self._oct_offset=0      # software-tracked octave
            self._last_cc_vals={}   # cc -> last value (for knob flash accuracy)
            self._load_local()
            self._build()
            self.setStyleSheet(QSS)
            self._thread.connected.connect(self._on_conn)
            self._thread.disconnected.connect(self._on_disc)
            self._thread.sysex_rx.connect(self._on_sysex)
            self._thread.raw_midi.connect(self._on_raw)
            self._thread.start()
            self._load_ui(0)
