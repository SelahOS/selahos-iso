            lk.addLayout(gk);lk.addStretch()
            tabs.addTab(wk,"Knobs")

            # ── Keyboard tab
            wkb=QWidget();lkb=QVBoxLayout(wkb);lkb.setContentsMargins(12,12,12,12);lkb.setSpacing(10)
            lkb.addWidget(slbl("MIDI Keyboard  —  C1 to C5"))
            self._piano=PianoWidget(24,84)
            lkb.addWidget(self._piano);lkb.addWidget(hsep())
            nr=QHBoxLayout()
            self._note_lbl=QLabel("—");self._note_lbl.setFont(QFont("Inter",26,QFont.Weight.Bold))
            self._note_lbl.setStyleSheet(f"color:{C['gold']};")
            self._vel_lbl=QLabel("");self._vel_lbl.setStyleSheet(f"color:{C['muted']};font-size:13px;")
            self._ch_lbl=QLabel("");self._ch_lbl.setStyleSheet(f"color:{C['muted']};font-size:13px;")
            nr.addWidget(self._note_lbl);nr.addSpacing(16);nr.addWidget(self._vel_lbl)
            nr.addSpacing(12);nr.addWidget(self._ch_lbl);nr.addStretch()
            lkb.addLayout(nr);lkb.addStretch()
            tabs.addTab(wkb,"Keyboard")

            # ── Controls tab
            wct2=QWidget();lct2=QVBoxLayout(wct2);lct2.setContentsMargins(12,12,12,12);lct2.setSpacing(10)
            lct2.addWidget(slbl("Transport & Controls  —  Live MIDI Log"))
            ind_row=QHBoxLayout();ind_row.setSpacing(8)
            self._indicators={}
            for lbl in ["SUSTAIN","REW","FFWD","STOP","PLAY","REC","LOOP"]:
                btn=QLabel(lbl);btn.setAlignment(Qt.AlignmentFlag.AlignCenter)
                btn.setFixedHeight(30)
                btn.setStyleSheet(f"color:{C['muted']};background:{C['bg3']};"
                                  f"border:1px solid {C['border']};border-radius:5px;"
                                  f"font-size:10px;font-weight:700;letter-spacing:1px;padding:0 8px;")
                ind_row.addWidget(btn);self._indicators[lbl]=btn
            ind_row.addStretch();lct2.addLayout(ind_row);lct2.addWidget(hsep())
            lct2.addWidget(flbl("MIDI LOG  —  all ports"))
            self._log=QTextEdit();self._log.setReadOnly(True);self._log.setFixedHeight(260)
            lct2.addWidget(self._log)
            clr=QPushButton("Clear Log");clr.clicked.connect(self._log.clear)
            lct2.addWidget(clr);lct2.addStretch()
            tabs.addTab(wct2,"Controls")

            # ── Arp tab
            war=QWidget();lar=QVBoxLayout(war);lar.setContentsMargins(20,16,20,16);lar.setSpacing(12)
            lar.addWidget(slbl("Arpeggiator"))
            self._arp_on=QCheckBox("Arpeggiator Enabled")
            self._arp_on.setFont(QFont("Inter",13,QFont.Weight.Medium))
            lar.addWidget(self._arp_on);lar.addWidget(hsep())
            ag=QWidget();agl=QGridLayout(ag);agl.setSpacing(10);agl.setColumnMinimumWidth(0,120)
            self._arp_mode=QComboBox();self._arp_mode.addItems(ARP_MODES)
            self._arp_div=QComboBox();self._arp_div.addItems(ARP_DIVS)
            self._arp_oct=QComboBox();self._arp_oct.addItems(ARP_OCTS)
            self._arp_bpm=QSpinBox();self._arp_bpm.setRange(20,127)
            self._arp_clk=QComboBox();self._arp_clk.addItems(["Internal","External"])
            for r,(l,w) in enumerate([("Mode",self._arp_mode),("Division",self._arp_div),
                                       ("Octave",self._arp_oct),("Tempo (BPM)",self._arp_bpm),
                                       ("Clock Source",self._arp_clk)]):
                agl.addWidget(flbl(l),r,0);agl.addWidget(w,r,1)
            agl.setRowStretch(5,1);lar.addWidget(ag);lar.addStretch()
            tabs.addTab(war,"Arpeggiator")

            # ── Global tab
            wgl=QWidget();lgl=QVBoxLayout(wgl);lgl.setContentsMargins(20,16,20,16);lgl.setSpacing(12)
            lgl.addWidget(slbl("Global Settings"))
            gg=QWidget();ggl=QGridLayout(gg);ggl.setSpacing(10);ggl.setColumnMinimumWidth(0,120)
            self._gl_ch=QSpinBox();self._gl_ch.setRange(1,16)
            ggl.addWidget(flbl("MIDI Channel"),0,0);ggl.addWidget(self._gl_ch,0,1)
            ggl.setRowStretch(1,1);lgl.addWidget(gg);lgl.addStretch()
            tabs.addTab(wgl,"Global")

            # ── MIDI Routing tab
            wrt=QWidget();lrt=QVBoxLayout(wrt);lrt.setContentsMargins(20,16,20,16);lrt.setSpacing(12)
            lrt.addWidget(slbl("MIDI Routing"))
            info=QLabel("MPK mini IV is USB class-compliant — ALSA and PipeWire detect it automatically.\n"
                        "No routing needed for native SelahOS apps.\n\n"
                        "SelahBridgePro: Wine DAWs receive MIDI via the WineASIO bridge.\n\n"
                        "'Send to Device' writes to device RAM — power-cycle to save to flash.\n\n"
                        "Note: The hardware OLED encoder activates in 'host mode' which requires\n"
                        "a USB HID handshake from the Akai software. Once we capture that\n"
                        "handshake via USB sniffing from Windows, full encoder/screen control\n"
                        "will be added to this editor.")
            info.setWordWrap(True)
            info.setStyleSheet(f"color:rgba(255,255,255,0.6);font-size:12px;")
            lrt.addWidget(info);lrt.addWidget(hsep())
            self._vbtn=QPushButton("Create Virtual MIDI Port  —  'MPK mini IV (SelahOS)'",objectName="action")
            self._vbtn.clicked.connect(self._on_vport)
            self._vstatus=QLabel("Virtual port: not active")
            self._vstatus.setStyleSheet(f"color:{C['muted']};font-size:11px;")
            lrt.addWidget(self._vbtn);lrt.addWidget(self._vstatus);lrt.addStretch()
            tabs.addTab(wrt,"MIDI Routing")

            bl.addWidget(tabs)

            # Bottom bar
            bbar=QWidget();bbar.setFixedHeight(44)
            bbar.setStyleSheet(f"background:{C['bg2']};border-top:1px solid {C['border2']};")
            bbl=QHBoxLayout(bbar);bbl.setContentsMargins(16,0,16,0);bbl.setSpacing(8)
            sf=QPushButton("Save Preset…");lf=QPushButton("Load Preset…")
            sf.clicked.connect(self._save_file);lf.clicked.connect(self._load_file)
            copy=QLabel("Selah Technologies LLC  ·  SelahBridgePro")
            copy.setStyleSheet(f"color:{C['dim']};font-size:10px;letter-spacing:0.5px;")
            bbl.addWidget(sf);bbl.addWidget(lf);bbl.addStretch();bbl.addWidget(copy)
            root.addWidget(body,1);root.addWidget(bbar)
            self.setStatusBar(QStatusBar())
            self.statusBar().showMessage("Waiting for MPK mini IV — plug in to connect")

            # Transport flash timers
            self._ind_timers={}
            for name,btn in self._indicators.items():
                t=QTimer();t.setSingleShot(True);t.setInterval(250)
                def _off(b=btn):
                    b.setStyleSheet(f"color:{C['muted']};background:{C['bg3']};"
                                    f"border:1px solid {C['border']};border-radius:5px;"
                                    f"font-size:10px;font-weight:700;letter-spacing:1px;padding:0 8px;")
                t.timeout.connect(_off);self._ind_timers[name]=t



        def _adj_oct(self,delta):
            self._oct_offset=max(-3,min(3,self._oct_offset+delta))
            self._oct_lbl.setText(str(self._oct_offset))
            self._device.set_octave(self._oct_offset)
            self._oled.show_octave(self._oct_offset)
            self._oled_home_timer.start()
            self.statusBar().showMessage(f"Octave: {'+' if self._oct_offset>=0 else ''}{self._oct_offset}")

        # ── Raw MIDI dispatcher ─────────────────────────────────────────────

        @pyqtSlot(list,str)
        def _on_raw(self,raw,port):
            if not raw: return
            status=raw[0]&0xF0;ch=(raw[0]&0x0F)+1
            if status in (0x90,0x80) and len(raw)>=3:
                note=raw[1];vel=raw[2] if status==0x90 else 0
                self._dispatch_note(note,vel,ch,port)
                self._log_midi(port,f"Note {'On' if vel else 'Off'}  {nn(note)}  vel={vel}",C['gold'] if vel else C['muted'])
            elif status==0xB0 and len(raw)>=3:
                cc=raw[1];val=raw[2]
                self._dispatch_cc(cc,val,ch)
                self._log_midi(port,f"CC {cc:3d}  val={val:3d}",C['cyan'])
            elif status==0xC0 and len(raw)>=2:
                pc=raw[1]%4
                self._log_midi(port,f"Program Change  {raw[1]}  →  Preset {pc+1}",C['gold'])
                self._switch_preset(pc)
            elif status==0xE0 and len(raw)>=3:
                v=((raw[2]<<7)|raw[1])-8192
                self._log_midi(port,f"Pitch Bend  {v:+d}",C['muted'])
            elif raw[0]==0xF0 and len(raw)>=6 and raw[1]==0x7F and len(raw)>5 and raw[4]==0x06:
                cmd=MMC_CMDS.get(raw[5] if len(raw)>5 else 0,f"MMC={raw[5]:02X}" if len(raw)>5 else "MMC")
                self._device.flash_transport(cmd)
                self._oled.show_transport(cmd)
                self._flash_ind(cmd);self._oled_home_timer.start()
                self._log_midi(port,f"MMC  {cmd}",C['green'])
            else:
                self._log_midi(port,' '.join(f'{b:02X}' for b in raw[:10]),C['dim'])

        def _dispatch_note(self,note,vel,ch,port):
            self._piano.note_on(note,vel)
            if vel:
                self._note_lbl.setText(nn(note))
                self._vel_lbl.setText(f"vel {vel}")
                self._ch_lbl.setText(f"ch {ch}")
            p=self._presets[self._cur]
            # Check pads
            for j,pw in enumerate(self._pads_a):
                if p.pads_a[j].note==note:
                    pw.flash(vel);self._device.flash_pad('A',j,vel)
                    self._oled.show_pad('A',j+1,note,vel);self._oled_home_timer.start()
                    return
            for j,pw in enumerate(self._pads_b):
                if p.pads_b[j].note==note:
                    pw.flash(vel);self._device.flash_pad('B',j,vel)
                    self._oled.show_pad('B',j+1,note,vel);self._oled_home_timer.start()
                    return
            # Keyboard key
            if vel:
                self._oled.show_note(note,vel,ch);self._oled_home_timer.start()

        def _dispatch_cc(self,cc,val,ch):
            self._last_cc_vals[cc]=val
            p=self._presets[self._cur]
            # sustain
            if cc==64:
                self._flash_ind("SUSTAIN");return
            # match knob
            for j,kw in enumerate(self._knobs):
                if p.knobs[j].cc==cc:
                    kw.flash(val);self._device.flash_knob(j)
                    self._oled.show_knob(p.knobs[j].name,cc,val,p.knobs[j].min_val,p.knobs[j].max_val)
                    self._oled_home_timer.start();return
            # fallback: CC 24-31 → knob by index
            if 24<=cc<=31:
                j=cc-24
                self._knobs[j].flash(val);self._device.flash_knob(j)
                self._oled.show_knob(f"KNOB {j+1}",cc,val)
                self._oled_home_timer.start()

        def _flash_ind(self,name):
            if name not in self._indicators: return
            btn=self._indicators[name]
            btn.setStyleSheet(f"color:{C['bg']};background:{C['gold']};"
                              f"border:1px solid {C['gold']};border-radius:5px;"
                              f"font-size:10px;font-weight:700;letter-spacing:1px;padding:0 8px;")
            self._ind_timers[name].start()

        def _oled_go_home(self):
            p=self._presets[self._cur]
            self._oled.show_home(self._cur+1,p.name)

        def _log_midi(self,port,desc,color):
            self._log.append(f'<span style="color:{C["dim"]};">[{port}]</span> '
                             f'<span style="color:{color};">{desc}</span>')
            sb=self._log.verticalScrollBar();sb.setValue(sb.maximum())
            doc=self._log.document()
            while doc.blockCount()>60:
                cur=self._log.textCursor()
                cur.movePosition(cur.MoveOperation.Start)
                cur.select(cur.SelectionType.LineUnderCursor)
                cur.removeSelectedText();cur.deleteChar()

        # ── Device slots ────────────────────────────────────────────────────

        def _switch_preset(self,idx):
            """Switch UI to preset idx and request its data from the device."""
            if idx==self._cur and self._presets[idx]._raw: return
            self._psel.blockSignals(True)
            self._psel.setCurrentIndex(idx)
            self._psel.blockSignals(False)
            self._save_ui(self._cur);self._cur=idx
            self._load_ui(idx)
            if self._dev.is_connected():
                QTimer.singleShot(80,lambda:self._dev.request_preset(idx))
            self.statusBar().showMessage(f"Preset {idx+1} — syncing from device…")

        def _sync_all(self):
            """Request all 4 presets from device sequentially."""
            if not self._dev.is_connected():
                self.statusBar().showMessage("Not connected — plug in device first");return
            self.statusBar().showMessage("Syncing all 4 presets from device…")
            for i in range(4):
                QTimer.singleShot(200+i*550,lambda idx=i:self._dev.request_preset(idx))

        @pyqtSlot(str)
        def _on_conn(self,name):
            self._dot.setStyleSheet(f"color:{C['green']};font-size:10px;")
            self._clbl.setText(name);self._clbl.setStyleSheet(f"color:{C['green']};")
            self.statusBar().showMessage(f"Connected: {name}  —  syncing presets…")
            # Auto-load all presets on connect
            for i in range(4):
                QTimer.singleShot(400+i*600,lambda idx=i:self._dev.request_preset(idx))

        @pyqtSlot()
        def _on_disc(self):
            self._dot.setStyleSheet(f"color:{C['red']};font-size:10px;")
            self._clbl.setText("Not connected");self._clbl.setStyleSheet(f"color:{C['red']};")
            self.statusBar().showMessage("MPK mini IV disconnected")

        @pyqtSlot(list)
        def _on_sysex(self,data):
            preset=self._dev.parse_response(data)
            if preset:
                idx=preset.index if preset.index<4 else self._cur
                self._presets[idx]=preset
                if idx==self._cur: self._load_ui(idx)
                self._psel.setItemText(idx,f"{idx+1} — {preset.name}")
                self._oled.show_home(idx+1,preset.name)
                self.statusBar().showMessage(f"Preset {idx+1}  '{preset.name}'  loaded from device")
                self._save_local()

        def _on_pchg(self,i):
            if i==self._cur: return
            self._save_ui(self._cur);self._cur=i;self._load_ui(i)
            if self._dev.is_connected():
                QTimer.singleShot(80,lambda:self._dev.request_preset(i))

        def _load_ui(self,i):
            p=self._presets[i];self._name_edit.setText(p.name)
            for j,pw in enumerate(self._pads_a): pw.load(p.pads_a[j])
            for j,pw in enumerate(self._pads_b): pw.load(p.pads_b[j])
            for j,kw in enumerate(self._knobs):  kw.load(p.knobs[j])
            for w in [self._arp_on,self._arp_mode,self._arp_div,
                      self._arp_oct,self._arp_bpm,self._arp_clk,self._gl_ch]:
                w.blockSignals(True)
            self._arp_on.setChecked(p.arp_enabled);self._arp_mode.setCurrentIndex(p.arp_mode)
            self._arp_div.setCurrentIndex(p.arp_division);self._arp_oct.setCurrentIndex(p.arp_octave)
            self._arp_bpm.setValue(p.arp_tempo);self._arp_clk.setCurrentIndex(p.clock_source)
            self._gl_ch.setValue(p.midi_channel)
            for w in [self._arp_on,self._arp_mode,self._arp_div,
                      self._arp_oct,self._arp_bpm,self._arp_clk,self._gl_ch]:
                w.blockSignals(False)
            self._oled.show_home(i+1,p.name)

        def _save_ui(self,i):
            p=self._presets[i];p.name=self._name_edit.text() or p.name
            for j,pw in enumerate(self._pads_a):
                pad=pw.get();pad.type_b3=p.pads_a[j].type_b3;pad.type_b4=p.pads_a[j].type_b4
                p.pads_a[j]=pad
            for j,pw in enumerate(self._pads_b):
                pad=pw.get();pad.type_b3=p.pads_b[j].type_b3;pad.type_b4=p.pads_b[j].type_b4
                p.pads_b[j]=pad
            for j,kw in enumerate(self._knobs): p.knobs[j]=kw.get()
            p.arp_enabled=self._arp_on.isChecked();p.arp_mode=self._arp_mode.currentIndex()
            p.arp_division=self._arp_div.currentIndex();p.arp_octave=self._arp_oct.currentIndex()
            p.arp_tempo=self._arp_bpm.value();p.clock_source=self._arp_clk.currentIndex()
            p.midi_channel=self._gl_ch.value()

        def _on_get(self):
            if not self._dev.is_connected():
                QMessageBox.warning(self,"Not Connected","Plug in the MPK mini IV first.");return
            self._dev.request_preset(self._cur)
            self.statusBar().showMessage(f"Requesting preset {self._cur+1}…")

        def _on_send(self):
            if not self._dev.is_connected():
                QMessageBox.warning(self,"Not Connected","Plug in the MPK mini IV first.");return
            self._save_ui(self._cur);self._dev.send_preset(self._presets[self._cur])
            self._save_local()
            self.statusBar().showMessage(f"Preset {self._cur+1} sent  —  power-cycle to save permanently")

        def _on_vport(self):
            if self._vport: return
            self._vport=self._dev.create_virtual_port()
            self._vstatus.setText("Active:  MPK mini IV (SelahOS)")
            self._vstatus.setStyleSheet(f"color:{C['green']};font-size:11px;")

        def _save_file(self):
            self._save_ui(self._cur)
            path,_=QFileDialog.getSaveFileName(self,"Save Preset",str(CONFIG_DIR),"MPK Preset (*.mpkpreset)")
            if not path: return
            if not path.endswith(".mpkpreset"): path+=".mpkpreset"
            Path(path).write_text(json.dumps(self._presets[self._cur].to_dict(),indent=2))
            self.statusBar().showMessage(f"Saved:  {path}")

        def _load_file(self):
            path,_=QFileDialog.getOpenFileName(self,"Load Preset",str(CONFIG_DIR),"MPK Preset (*.mpkpreset)")
            if not path: return
            try:
                p=Preset.from_dict(json.loads(Path(path).read_text()))
                p.index=self._cur;self._presets[self._cur]=p;self._load_ui(self._cur)
                self.statusBar().showMessage(f"Loaded:  {path}")
            except Exception as e:
                QMessageBox.critical(self,"Load Error",str(e))

        def _save_local(self):
            self._save_ui(self._cur)
            (CONFIG_DIR/"presets.json").write_text(json.dumps([p.to_dict() for p in self._presets],indent=2))

        def _load_local(self):
            p=CONFIG_DIR/"presets.json"
            if not p.exists(): return
            try:
                for i,d in enumerate(json.loads(p.read_text())[:4]):
                    self._presets[i]=Preset.from_dict(d);self._presets[i].index=i
            except Exception: pass

        def closeEvent(self,e):
            self._save_local();self._thread.stop();self._dev.disconnect();super().closeEvent(e)

    signal.signal(signal.SIGHUP,signal.SIG_IGN)
    app=QApplication(sys.argv)
    app.setApplicationName("MPK mini IV Editor")
    app.setOrganizationName("Selah Technologies")
    win=Win();win.show()
    sys.exit(app.exec())


# ══════════════════════════════════════════════════════════════════════════════
#  MAIN
# ══════════════════════════════════════════════════════════════════════════════

def main():
    ap=argparse.ArgumentParser(description="selah-mpk-mini-iv — MPK mini IV Editor for SelahOS")
    ap.add_argument("--ports",  action="store_true")
    ap.add_argument("--monitor",action="store_true")
    args=ap.parse_args()
    if args.ports:     cmd_ports()
    elif args.monitor: cmd_monitor()
    else:              _run_gui()

if __name__=="__main__":
    main()
