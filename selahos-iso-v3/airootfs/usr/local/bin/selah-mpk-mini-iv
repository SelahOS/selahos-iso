def _run_gui():
    try:
        from PyQt6.QtWidgets import (
            QApplication, QMainWindow, QWidget, QVBoxLayout, QHBoxLayout,
            QGridLayout, QLabel, QComboBox, QSpinBox, QCheckBox, QPushButton,
            QGroupBox, QTabWidget, QStatusBar, QMessageBox, QFileDialog,
            QLineEdit, QFrame, QTextEdit, QSizePolicy,
        )
        from PyQt6.QtCore import Qt, QThread, QTimer, pyqtSignal, pyqtSlot
        from PyQt6.QtGui import QFont, QPainter, QColor, QPen, QBrush
    except ImportError:
        sys.exit("Error: python-pyqt6 not installed.\n  sudo pacman -S python-pyqt6")

    CONFIG_DIR = Path.home() / ".config" / "selah" / "mpk-mini-iv"
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)

    # ── Piano keyboard widget ─────────────────────────────────────────────────

    class PianoWidget(QWidget):
        """Visual piano — highlights pressed keys in gold."""
        IS_WHITE = [True,False,True,False,True,True,False,True,False,True,False,True]

        def __init__(self, start=24, end=84, parent=None):
            super().__init__(parent)
            self._start  = start
            self._end    = end
            self._active = {}   # note → velocity
            self.setMinimumHeight(80)
            self.setSizePolicy(QSizePolicy.Policy.Expanding, QSizePolicy.Policy.Fixed)

        def note_on(self, note, velocity):
            if not (self._start <= note <= self._end): return
            if velocity > 0: self._active[note] = velocity
            else:            self._active.pop(note, None)
            self.update()

        def clear(self):
            self._active.clear(); self.update()

        def paintEvent(self, _):
            p = QPainter(self)
            p.setRenderHint(QPainter.RenderHint.Antialiasing, False)
            W, H = self.width(), self.height()

            white_notes = [n for n in range(self._start, self._end+1) if self.IS_WHITE[n%12]]
            if not white_notes: return

            kw = W / len(white_notes)
            bw = kw * 0.58
            bh = H * 0.60

            # map white note → x
            wx = {note: int(i*kw) for i,note in enumerate(white_notes)}

            # background
            p.fillRect(0,0,W,H, QColor(0x1D,0x23,0x33))

            # white keys
            for note in white_notes:
                x = wx[note]; kpx = max(1, int(kw)-1)
                if note in self._active:
                    vel = self._active[note]
                    a   = 180 + int(vel/127*75)
                    p.setBrush(QBrush(QColor(214,168,90,a)))
                else:
                    p.setBrush(QBrush(QColor(210,205,192)))
                p.setPen(QPen(QColor(60,65,85),1))
                p.drawRect(x+1, 0, kpx-1, H-1)

                # C note label
                if note % 12 == 0 and kw >= 14:
                    p.setPen(QPen(QColor(80,85,100),1))
                    p.setFont(QFont("Inter",7))
                    p.drawText(x+2, H-4, nn(note))

            # black keys
            for note in range(self._start, self._end+1):
                if self.IS_WHITE[note%12]: continue
                prev = note-1
                while prev >= self._start and not self.IS_WHITE[prev%12]: prev -= 1
                if prev < self._start or prev not in wx: continue
                bx = int(wx[prev] + kw*0.62)
                if note in self._active:
                    vel = self._active[note]
                    p.setBrush(QBrush(QColor(214,168,90, 200+int(vel/127*55))))
                else:
                    p.setBrush(QBrush(QColor(22,26,38)))
                p.setPen(QPen(QColor(10,12,18),1))
                p.drawRect(bx, 0, int(bw), int(bh))
            p.end()

    # ── Device + live MIDI watcher (monitors ALL MPK ports) ──────────────────

    class DevThread(QThread):
        connected    = pyqtSignal(str)
        disconnected = pyqtSignal()
        sysex_rx     = pyqtSignal(list)
        raw_midi     = pyqtSignal(list, str)   # bytes, port_label

        def __init__(self, dev, parent=None):
            super().__init__(parent)
            self._dev=dev; self._running=True; self._conn=False
            self._live: dict = {}   # "idx:name" → rtmidi.MidiIn

        def _make_live_cb(self, label):
            def cb(msg, _=None):
                raw,_ = msg
                if raw: self.raw_midi.emit(list(raw), label)
            return cb

        def run(self):
            self._dev.set_sysex_callback(lambda d: self.sysex_rx.emit(d))
            while self._running:
                try:
                    # SysEx / editor connection
                    ins_c,outs_c = MPKDevice.find_ctrl_ports()
                    if ins_c and outs_c and not self._conn:
                        self._dev.connect(ins_c[0][0], outs_c[0][0])
                        self._conn = True
                        self.connected.emit(ins_c[0][1].split(":")[0].strip())
                    elif not ins_c and self._conn:
                        self._dev.disconnect(); self._conn=False; self.disconnected.emit()

                    # Live ports — open any new, close any gone
                    live_now = {f"{i}:{n}": (i, self._port_label(n))
                                for i,n in MPKDevice.find_live_ports()}
                    for key,(idx,lbl) in live_now.items():
                        if key not in self._live:
                            mi=rtmidi.MidiIn(); mi.ignore_types(sysex=True)
                            mi.open_port(idx); mi.set_callback(self._make_live_cb(lbl))
                            self._live[key]=mi
                    for key in list(self._live):
                        if key not in live_now:
                            try: self._live[key].close_port()
                            except: pass
                            del self._live[key]
                except Exception:
                    pass
                self.msleep(1500)

            for mi in self._live.values():
                try: mi.close_port()
                except: pass

        @staticmethod
        def _port_label(name):
            n = name.lower()
            if "daw"     in n: return "DAW"
            if "plugin"  in n: return "PLUGIN"
            if "din"     in n: return "DIN"
            return "MIDI"

        def stop(self): self._running=False; self.wait()

    # ── Helpers ──────────────────────────────────────────────────────────────

    def hsep():
        f=QFrame(); f.setFixedHeight(1)
        f.setStyleSheet(f"background:{C['border2']};border:none;"); return f

    def section_lbl(text):
        l=QLabel(text); l.setFont(QFont("Inter",12,QFont.Weight.Medium))
        l.setStyleSheet(f"color:{C['gold']};margin-bottom:4px;"); return l

    def field_lbl(text):
        l=QLabel(text)
        l.setStyleSheet(f"color:{C['muted']};font-size:11px;font-weight:600;"); return l

    # ── Pad widget with flash ─────────────────────────────────────────────────

    def make_pad(label):
        grp=QGroupBox(label)
        g=QGridLayout(grp); g.setSpacing(4); g.setContentsMargins(8,14,8,8)
        note=QSpinBox(); note.setRange(0,127)
        nn_lbl=QLabel("C2"); nn_lbl.setAlignment(Qt.AlignmentFlag.AlignCenter)
        nn_lbl.setStyleSheet(f"color:{C['gold']};font-size:11px;font-weight:700;"
                             f"background:rgba(214,168,90,0.08);border-radius:4px;padding:2px 4px;")
        note.valueChanged.connect(lambda v: nn_lbl.setText(nn(v)))
        g.addWidget(field_lbl("NOTE"),0,0,1,2)
        g.addWidget(note,1,0,1,2); g.addWidget(nn_lbl,2,0,1,2)

        _t=QTimer(); _t.setSingleShot(True); _t.setInterval(180)
        def _off():
            grp.setProperty("active","false")
            grp.style().unpolish(grp); grp.style().polish(grp)
        _t.timeout.connect(_off)

        def flash(vel=127):
            grp.setProperty("active","true")
            grp.style().unpolish(grp); grp.style().polish(grp); _t.start()

        def load(c):
            note.blockSignals(True); note.setValue(c.note); note.blockSignals(False)
            nn_lbl.setText(nn(c.note))

        def get(): return PadConfig(note=note.value())

        grp.flash=flash; grp.load=load; grp.get=get; grp._t=_t
        return grp

    # ── Knob widget with flash ────────────────────────────────────────────────

    def make_knob(idx):
        grp=QGroupBox(f"K{idx+1}")
        g=QGridLayout(grp); g.setSpacing(4); g.setContentsMargins(8,14,8,8)
        cc=QSpinBox();  cc.setRange(0,127)
        mn=QSpinBox();  mn.setRange(0,127)
        mx=QSpinBox();  mx.setRange(0,127); mx.setValue(127)
        mod=QComboBox(); mod.addItems(KNOB_MODES)
        name=QLineEdit(); name.setMaxLength(16); name.setPlaceholderText("Name")
        g.addWidget(field_lbl("CC"),  0,0); g.addWidget(cc,  0,1)
        g.addWidget(field_lbl("MIN"), 1,0); g.addWidget(mn,  1,1)
        g.addWidget(field_lbl("MAX"), 2,0); g.addWidget(mx,  2,1)
        g.addWidget(mod,3,0,1,2)
        g.addWidget(field_lbl("NAME"),4,0); g.addWidget(name,4,1)

        _t=QTimer(); _t.setSingleShot(True); _t.setInterval(300)
        def _off():
            grp.setProperty("knob_active","false")
            grp.style().unpolish(grp); grp.style().polish(grp)
        _t.timeout.connect(_off)

        def flash():
            grp.setProperty("knob_active","true")
            grp.style().unpolish(grp); grp.style().polish(grp); _t.start()

        def load(k):
            for w in [cc,mn,mx,mod]: w.blockSignals(True)
            cc.setValue(k.cc); mn.setValue(k.min_val); mx.setValue(k.max_val)
            mod.setCurrentIndex(k.mode); name.setText(k.name)
            for w in [cc,mn,mx,mod]: w.blockSignals(False)

        def get(): return KnobConfig(cc=cc.value(),min_val=mn.value(),max_val=mx.value(),
                                     mode=mod.currentIndex(),name=name.text())
        grp.flash=flash; grp.load=load; grp.get=get; grp._t=_t
        return grp

    # ── Main window ──────────────────────────────────────────────────────────

