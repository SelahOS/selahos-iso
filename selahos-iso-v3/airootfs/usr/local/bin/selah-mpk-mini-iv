#!/usr/bin/env python3
# ═══════════════════════════════════════════════════════════════════════════════
#  selah-mpk-mini-iv — MPK mini IV Editor for SelahOS
#  Selah Technologies LLC — Part of the SelahBridgePro suite
#
#  Native replacement for the Windows 'Akai Professional MPK mini IV' editor.
#  Protocol confirmed from live hardware (USB PID 09e8:005d):
#    SysEx READ:  F0 47 00 5D 66 00 01 [idx] F7  → device responds with 0x67
#    SysEx DATA:  F0 47 00 5D 67 02 14 [276 bytes] F7
#    276-byte layout: [0]=preset_idx [1:17]=name [18]=const [20]=tempo
#    [21]=arp_div [22]=arp_mode [23]=arp_on [24]=arp_oct [25]=clock
#    [29]=MIDI_ch [30:70]=bank_A_pads(8×5) [70:110]=bank_B_pads(8×5)
#    [110:270]=knobs(8×20: CC,min,max,mode,name[16]) [270:276]=footer
#
#  Usage:
#    selah-mpk-mini-iv              # launch GUI editor
#    selah-mpk-mini-iv --ports      # list MIDI ports and exit
#    selah-mpk-mini-iv --monitor    # print raw MIDI messages
#
#  Requires: python-rtmidi, python-pyqt6  (both in Arch extra repo)
# ═══════════════════════════════════════════════════════════════════════════════

import sys
import json
import time
import threading
import argparse
from dataclasses import dataclass, field
from pathlib import Path
from typing import Optional, Callable

try:
    import rtmidi
except ImportError:
    sys.exit("Error: python-rtmidi not installed.\n  sudo pacman -S python-rtmidi")

# ══════════════════════════════════════════════════════════════════════════════
#  PROTOCOL CONSTANTS  (confirmed from live device)
# ══════════════════════════════════════════════════════════════════════════════

AKAI_MFR_ID   = 0x47
MPK_DEVICE_ID = 0x5D          # USB PID 005d
CMD_GET       = 0x66
CMD_SET       = 0x67
PAYLOAD_LEN   = 276

ARP_MODES     = ["Up", "Down", "Inclusive", "Exclusive", "Order", "Random"]
ARP_DIVS      = ["1/4", "1/4T", "1/8", "1/8T", "1/16", "1/16T", "1/32", "1/32T"]
ARP_OCTS      = ["1 oct", "2 oct", "3 oct", "4 oct"]
KNOB_MODES    = ["Relative", "Absolute"]

NOTES = ["C","C#","D","D#","E","F","F#","G","G#","A","A#","B"]
def nn(n): return f"{NOTES[n%12]}{n//12-1}"


# ══════════════════════════════════════════════════════════════════════════════
#  DATA CLASSES
# ══════════════════════════════════════════════════════════════════════════════

@dataclass
class PadConfig:
    note:    int = 36
    type_b3: int = 0x05  # velocity/mode byte — preserved from device
    type_b4: int = 0x21

@dataclass
class KnobConfig:
    cc:      int = 24
    min_val: int = 0
    max_val: int = 127
    mode:    int = 1    # 1=Absolute
    name:    str = ""

@dataclass
class Preset:
    index:        int  = 0
    name:         str  = "USER"
    midi_channel: int  = 1
    arp_enabled:  bool = False
    arp_mode:     int  = 0
    arp_division: int  = 2
    arp_octave:   int  = 0
    arp_tempo:    int  = 120
    clock_source: int  = 0
    pads_a: list = field(default_factory=lambda: [PadConfig(note=36+i) for i in range(8)])
    pads_b: list = field(default_factory=lambda: [PadConfig(note=44+i) for i in range(8)])
    knobs:  list = field(default_factory=lambda: [KnobConfig(cc=24+i, name=f"KNOB{i+1}") for i in range(8)])
    _raw: Optional[bytes] = field(default=None, repr=False)

    def to_payload(self) -> list:
        d = bytearray(self._raw) if (self._raw and len(self._raw) == PAYLOAD_LEN) else bytearray(PAYLOAD_LEN)
        if not self._raw or len(self._raw) != PAYLOAD_LEN:
            # fill structural constants
            d[17]=0x00; d[18]=0x09; d[19]=0x00; d[26]=0x00; d[27]=0x7F; d[28]=0x00
            for i in range(8):
                d[30+i*5+1]=0x20+i; d[30+i*5+2]=i
                d[70+i*5+1]=0x28+i; d[70+i*5+2]=8+i
        d[0] = self.index
        name_b = self.name.encode('ascii','replace')[:16].ljust(16, b'\x00')
        d[1:17] = name_b
        d[20] = max(20, min(127, self.arp_tempo))
        d[21] = self.arp_division & 0x07
        d[22] = self.arp_mode & 0x07
        d[23] = int(self.arp_enabled)
        d[24] = self.arp_octave & 0x03
        d[25] = self.clock_source & 0x01
        d[29] = max(1, min(16, self.midi_channel))
        for i, p in enumerate(self.pads_a[:8]):
            off = 30+i*5; d[off]=p.note&0x7F; d[off+3]=p.type_b3; d[off+4]=p.type_b4
        for i, p in enumerate(self.pads_b[:8]):
            off = 70+i*5; d[off]=p.note&0x7F; d[off+3]=p.type_b3; d[off+4]=p.type_b4
        for i, k in enumerate(self.knobs[:8]):
            off=110+i*20; d[off]=k.cc&0x7F; d[off+1]=k.min_val&0x7F; d[off+2]=k.max_val&0x7F
            d[off+3]=k.mode&0x01
            d[off+4:off+20] = k.name.encode('ascii','replace')[:16].ljust(16, b'\x00')
        return list(d)

    @classmethod
    def from_payload(cls, payload: list) -> "Preset":
        if len(payload) < PAYLOAD_LEN:
            return cls()
        d = payload
        p = cls(index=d[0])
        p._raw = bytes(d[:PAYLOAD_LEN])
        p.name         = bytes(d[1:17]).rstrip(b'\x00').decode('ascii','replace')
        p.arp_tempo    = d[20]
        p.arp_division = d[21] & 0x07
        p.arp_mode     = d[22] & 0x07
        p.arp_enabled  = bool(d[23])
        p.arp_octave   = d[24] & 0x03
        p.clock_source = d[25] & 0x01
        p.midi_channel = max(1, min(16, d[29]))
        p.pads_a = [PadConfig(note=d[30+i*5], type_b3=d[30+i*5+3], type_b4=d[30+i*5+4]) for i in range(8)]
        p.pads_b = [PadConfig(note=d[70+i*5], type_b3=d[70+i*5+3], type_b4=d[70+i*5+4]) for i in range(8)]
        p.knobs = [KnobConfig(cc=d[110+i*20], min_val=d[110+i*20+1], max_val=d[110+i*20+2],
                              mode=d[110+i*20+3],
                              name=bytes(d[110+i*20+4:110+i*20+20]).rstrip(b'\x00').decode('ascii','replace'))
                   for i in range(8)]
        return p

    def to_dict(self) -> dict:
        return {"index":self.index,"name":self.name,"midi_channel":self.midi_channel,
                "arp_enabled":self.arp_enabled,"arp_mode":self.arp_mode,"arp_division":self.arp_division,
                "arp_octave":self.arp_octave,"arp_tempo":self.arp_tempo,"clock_source":self.clock_source,
                "pads_a":[{"note":p.note,"type_b3":p.type_b3,"type_b4":p.type_b4} for p in self.pads_a],
                "pads_b":[{"note":p.note,"type_b3":p.type_b3,"type_b4":p.type_b4} for p in self.pads_b],
                "knobs":[{"cc":k.cc,"min_val":k.min_val,"max_val":k.max_val,"mode":k.mode,"name":k.name}
                         for k in self.knobs],
                "_raw": list(self._raw) if self._raw else None}

    @classmethod
    def from_dict(cls, d: dict) -> "Preset":
        p = cls(index=d.get("index",0)); p.name=d.get("name","USER")
        p.midi_channel=d.get("midi_channel",1); p.arp_enabled=d.get("arp_enabled",False)
        p.arp_mode=d.get("arp_mode",0); p.arp_division=d.get("arp_division",2)
        p.arp_octave=d.get("arp_octave",0); p.arp_tempo=d.get("arp_tempo",120)
        p.clock_source=d.get("clock_source",0)
        p.pads_a=[PadConfig(**x) for x in d.get("pads_a",[])] or p.pads_a
        p.pads_b=[PadConfig(**x) for x in d.get("pads_b",[])] or p.pads_b
        p.knobs=[KnobConfig(**x) for x in d.get("knobs",[])] or p.knobs
        raw = d.get("_raw"); p._raw = bytes(raw) if raw else None
        return p


# ══════════════════════════════════════════════════════════════════════════════
#  MIDI DEVICE
# ══════════════════════════════════════════════════════════════════════════════

class MPKDevice:
    MPK_PATTERNS = ["mpk mini iv", "mpk mini", "mpk"]

    def __init__(self):
        self._in  = rtmidi.MidiIn()
        self._out = rtmidi.MidiOut()
        self._in.ignore_types(sysex=False)
        self._buf: list = []
        self._sysex_cb: Optional[Callable] = None
        self._midi_cb:  Optional[Callable] = None

    @classmethod
    def find_ports(cls, prefer_sysex: bool = True):
        mi = rtmidi.MidiIn(); mo = rtmidi.MidiOut()
        def _match(ports):
            all_m = [(i,n) for i,n in enumerate(ports) if any(p in n.lower() for p in cls.MPK_PATTERNS)]
            if not all_m: return []
            if prefer_sysex:
                ctrl = [(i,n) for i,n in all_m if "software control" in n.lower()]
                return ctrl if ctrl else [all_m[0]]
            else:
                midi = [(i,n) for i,n in all_m if "midi port" in n.lower()]
                return midi if midi else [all_m[0]]
        ins = _match(mi.get_ports()); outs = _match(mo.get_ports())
        del mi, mo; return ins, outs

    @classmethod
    def list_all_ports(cls):
        mi = rtmidi.MidiIn(); mo = rtmidi.MidiOut()
        r = list(enumerate(mi.get_ports())), list(enumerate(mo.get_ports()))
        del mi, mo; return r

    def connect(self, in_port: int, out_port: int):
        self._in.open_port(in_port); self._out.open_port(out_port)
        self._in.set_callback(self._on_midi)

    def disconnect(self):
        if self._in.is_port_open():  self._in.close_port()
        if self._out.is_port_open(): self._out.close_port()

    def is_connected(self): return self._in.is_port_open() and self._out.is_port_open()
    def set_sysex_callback(self, cb): self._sysex_cb = cb
    def set_midi_callback(self, cb):  self._midi_cb  = cb

    def _on_midi(self, msg, _=None):
        raw, _ = msg
        if not raw: return
        if raw[0] == 0xF0:
            if 0xF7 in raw:
                if self._sysex_cb: self._sysex_cb(list(raw))
            else:
                self._buf = list(raw)
        elif self._buf:
            self._buf.extend(raw)
            if 0xF7 in self._buf:
                data = self._buf[:]; self._buf = []
                if self._sysex_cb: self._sysex_cb(data)
        else:
            if self._midi_cb: self._midi_cb(raw)

    def _sx(self, cmd, data):
        n = len(data)
        return [0xF0, AKAI_MFR_ID, 0x00, MPK_DEVICE_ID, cmd, (n>>7)&0x7F, n&0x7F] + data + [0xF7]

    def request_preset(self, index: int):
        if self._out.is_port_open():
            self._out.send_message(self._sx(CMD_GET, [index & 0x03]))

    def send_preset(self, preset: Preset):
        if self._out.is_port_open():
            self._out.send_message(self._sx(CMD_SET, preset.to_payload()))

    def parse_response(self, data: list) -> Optional[Preset]:
        if (len(data) >= 7+PAYLOAD_LEN and data[0]==0xF0 and data[1]==AKAI_MFR_ID
                and data[3]==MPK_DEVICE_ID and data[4]==CMD_SET):
            return Preset.from_payload(data[7:-1])
        return None

    def create_virtual_port(self, name="MPK mini IV (SelahOS)") -> rtmidi.MidiOut:
        vo = rtmidi.MidiOut(); vo.open_virtual_port(name); return vo


# ══════════════════════════════════════════════════════════════════════════════
#  CLI MODES
# ══════════════════════════════════════════════════════════════════════════════

def cmd_ports():
    ins, outs = MPKDevice.list_all_ports()
    print("MIDI Input ports:")
    for i,n in ins: print(f"  [{i}] {n}")
    print("\nMIDI Output ports:")
    for i,n in outs: print(f"  [{i}] {n}")
    mpk_in, _ = MPKDevice.find_ports()
    if mpk_in: print(f"\n✓ MPK mini IV detected: {mpk_in[0][1]}")
    else:       print("\n  (No MPK mini IV detected)")

def cmd_monitor():
    dev = MPKDevice()
    ins, outs = MPKDevice.find_ports(prefer_sysex=False)
    if not ins: print("No MPK mini IV found. Plug in and retry."); return
    dev.set_midi_callback(lambda m: print(f"MIDI: {' '.join(f'{b:02X}' for b in m)}"))
    dev.set_sysex_callback(lambda d: print(f"SysEx({len(d)}B): {' '.join(f'{b:02X}' for b in d[:20])}..."))
    dev.connect(ins[0][0], outs[0][0] if outs else ins[0][0])
    print(f"Monitoring {ins[0][1]} — Ctrl-C to stop")
    try:
        while True: time.sleep(0.1)
    except KeyboardInterrupt: pass
    dev.disconnect()


