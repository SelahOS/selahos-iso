import argparse
import hashlib
import json
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path

VERSION = "1.0.0"
PRODUCT = "SelahBridgePro"
SUPPORT = "support@selahtechnologies.com"

PROFILE_DIR  = Path("/etc/selahbridgepro/profiles")
LIC_DIR      = Path("/etc/selahbridgepro")
LIC_FILE     = LIC_DIR / "license"
# Per-user data (trial start) lives in ~/.local so regular users can write it.
# System license file stays in /etc (written by root via --activate).
_USER_DATA_DIR = Path.home() / ".local/share/selahbridgepro"
TRIAL_FILE   = _USER_DATA_DIR / "trial.conf"
TRIAL_DAYS   = 14

# License secret loaded at runtime from /etc/selahbridgepro/.keydata
# That file is NOT in source control — it is deployed at ISO build time.
# Without .keydata the license system operates in trial-only mode.
def _load_secret() -> str:
    kf = Path("/etc/selahbridgepro/.keydata")
    try:
        return kf.read_text().strip() if kf.exists() else ""
    except OSError:
        return ""

_SECRET = _load_secret()

# ── ANSI palette ──────────────────────────────────────────────────────────────
