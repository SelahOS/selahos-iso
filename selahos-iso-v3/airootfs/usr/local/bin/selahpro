def ok(msg):    print(f"  {TEAL}✓{RESET} {PARCH}{msg}{RESET}")
def info(msg):  print(f"  {MUTED}→ {msg}{RESET}")
def warn(msg):  print(f"  {RED}⚠  {PARCH}{msg}{RESET}")
def die(msg):   print(f"\n{RED}✗  {msg}{RESET}", file=sys.stderr); sys.exit(1)
def hdr(msg):   print(f"\n{GOLD}{BOLD}══  {msg}  ══{RESET}")

def _lsusb(*args):
    """Run lsusb, returning None if usbutils is not installed (PC hardware often lacks it)."""
    try:
        return subprocess.run(["lsusb", *args], capture_output=True, text=True, check=False)
    except FileNotFoundError:
        return None


# ═══════════════════════════════════════════════════════════════════════════════
#  LICENSE SYSTEM
# ═══════════════════════════════════════════════════════════════════════════════

def _machine_id() -> str:
    for p in [Path("/etc/machine-id"), Path("/var/lib/dbus/machine-id")]:
        if p.exists():
            return p.read_text().strip()
    import socket
    return hashlib.sha256(socket.gethostname().encode()).hexdigest()[:32]

def _expected_key(mid: str) -> str:
    raw = hashlib.sha256((mid + _SECRET).encode()).hexdigest()[:16].upper()
    return f"SELAHPRO-{raw[0:4]}-{raw[4:8]}-{raw[8:12]}-{raw[12:16]}"

def _check_license() -> bool:
    """Return True if licensed or in valid trial. Die if expired."""
    import datetime

    if LIC_FILE.exists():
        try:
            stored = LIC_FILE.read_text().strip()
        except PermissionError:
            warn("Cannot read license file — run: sudo selahpro --activate <KEY>")
            stored = ""
        expected = _expected_key(_machine_id())
        if stored and stored == expected:
            return True
        elif stored:
            warn("License key does not match this machine.")

    # Trial logic
    now = datetime.date.today()
    if TRIAL_FILE.exists():
        try:
            first_run = datetime.date.fromisoformat(TRIAL_FILE.read_text().strip())
            days_used = (now - first_run).days
            remaining = TRIAL_DAYS - days_used
            if remaining > 0:
                info(f"Trial: {remaining} day(s) remaining")
                return True
            else:
                print(f"\n{RED}{BOLD}SelahBridgePro trial has expired.{RESET}")
                print(f"  Get your Machine ID:  {GOLD}selahpro --machine-id{RESET}")
                print(f"  Email it to:          {GOLD}{SUPPORT}{RESET}")
                print(f"  Activate:             {GOLD}selahpro --activate <KEY>{RESET}\n")
                sys.exit(1)
        except (ValueError, OSError):
            pass

    # First run — write trial start to user-writable dir
    _USER_DATA_DIR.mkdir(parents=True, exist_ok=True, mode=0o755)
    TRIAL_FILE.write_text(now.isoformat())
    os.chmod(TRIAL_FILE, 0o644)
    info(f"Trial started — {TRIAL_DAYS} days free. Machine ID: {_machine_id()}")
    return True

def cmd_activate(key: str):
    """Activate SelahBridgePro with a license key."""
    key = key.strip().upper()
    expected = _expected_key(_machine_id())
    if key != expected:
        die(f"Invalid license key for this machine.\nExpected format: SELAHPRO-XXXX-XXXX-XXXX-XXXX\nYour Machine ID: {_machine_id()}")
    LIC_DIR.mkdir(parents=True, exist_ok=True)
    try:
        LIC_FILE.write_text(key)
    except PermissionError:
        die(f"Permission denied writing license.\nRun: sudo selahpro --activate {key}")
    os.chmod(LIC_FILE, 0o640)
    try:
        import grp
        audio_gid = grp.getgrnam("audio").gr_gid
        os.chown(LIC_FILE, 0, audio_gid)
    except Exception:
        pass
    ok(f"{PRODUCT} activated successfully!")
    ok("You have lifetime access on this machine.")


# ═══════════════════════════════════════════════════════════════════════════════
#  INSTALL
# ═══════════════════════════════════════════════════════════════════════════════

def _run_cmd(desc: str, *args, check=True, capture=False):
    info(desc)
    kwargs = {"check": check}
    if capture:
        kwargs["capture_output"] = True
        kwargs["text"] = True
    return subprocess.run(list(args), **kwargs)

def cmd_install(daw_name: str | None, existing_prefix: str | None = None, installer_path: str | None = None):
    """Install SelahBridgePro runtime and optionally scaffold a DAW Wine prefix."""
    hdr("SelahBridgePro Install")
    _check_license()

    # Delegate all system-level package installation to selahbridge-install,
    # which handles: multilib enable, Wine, Vulkan drivers, DXVK (dxvk-mingw),
    # VKD3D-Proton (vkd3d-proton-bin), PipeWire JACK, WineASIO, virtual MIDI.
    installer = shutil.which("selahbridge-install")
    if installer:
        info("Launching SelahBridgePro runtime installer...")
        result = subprocess.run([installer], check=False)
        if result.returncode != 0:
            warn("Runtime installer reported issues — see output above.")
    else:
        warn("selahbridge-install not found — running minimal fallback install")
        if not shutil.which("wine"):
            _run_cmd("Installing Wine runtime",
                     "sudo", "pacman", "-S", "--noconfirm",
                     "wine-staging", "wine-mono", "wine-gecko", "winetricks",
                     check=False)
        else:
            ok("Wine runtime present")

        if not _pyqt6_webengine_available():
            _run_cmd("Installing selahauth dependency (python-pyqt6-webengine)",
                     "sudo", "pacman", "-S", "--noconfirm",
                     "python-pyqt6-webengine", check=False)

    # Register WineASIO COM server in the user's Wine prefix
    _run_cmd("Configuring SelahASIO", "selah-asio-config", "--install", check=False)

    # 3. Apply udev rules (reload)
    if Path("/etc/udev/rules.d/99-selah-midi.rules").exists():
        _run_cmd("Reloading udev MIDI rules",
                 "sudo", "udevadm", "control", "--reload-rules", check=False)
        _run_cmd("Triggering USB subsystem",
                 "sudo", "udevadm", "trigger", "--subsystem-match=usb", check=False)
        ok("USB MIDI udev rules active")
    else:
        warn("udev rules not found at /etc/udev/rules.d/99-selah-midi.rules")

    # 4. Realtime privileges
    limits_line = "@audio  -  rtprio   88\n@audio  -  memlock  unlimited\n"
    limits_path = Path("/etc/security/limits.conf")
    if limits_path.exists():
        content = limits_path.read_text()
        if "@audio" not in content:
            try:
                with limits_path.open("a") as f:
                    f.write(limits_line)
                ok("Realtime limits written")
            except PermissionError:
                warn("Cannot write limits.conf — run as root or add manually")
    groups_result = subprocess.run(["groups"], capture_output=True, text=True)
    if "audio" not in groups_result.stdout and "realtime" not in groups_result.stdout:
        real_user = os.environ.get("SUDO_USER", os.environ.get("USER", ""))
        if real_user:
            _run_cmd("Adding user to audio/realtime groups",
                     "sudo", "usermod", "-aG", "audio,realtime", real_user, check=False)
            info("Re-login required for group changes to take effect")

    # 5. DAW-specific prefix scaffold
    if daw_name:
        daw_key = daw_name.lower()
        daw = KNOWN_DAWS.get(daw_key)
        if not daw:
            warn(f"Unknown DAW '{daw_name}'. Known: {', '.join(KNOWN_DAWS)}")
        else:
            _scaffold_prefix(daw, existing_prefix=existing_prefix, installer_path=installer_path)

    ok("SelahBridgePro installation complete")
    info("Launch a DAW: selahpro launch <daw>")
    info("Diagnose issues: selahpro diagnose")

def _scaffold_prefix(daw: dict, existing_prefix: str | None = None, installer_path: str | None = None):
    """Create or patch a DAW-specific Wine prefix with the correct profile applied."""
    name = daw["name"]
    profile_key = daw["profile"]

    if existing_prefix:
        prefix_path = Path(existing_prefix).expanduser().resolve()
        if not prefix_path.exists():
            die(f"Prefix path does not exist: {prefix_path}")
        hdr(f"Applying {name} Fixes to Existing Prefix")
        info(f"Prefix: {prefix_path}  (existing)")
    else:
        prefix_path = Path.home() / f".wine-selah-{profile_key}"
        hdr(f"Scaffolding {name} Wine Prefix")
        info(f"Prefix: {prefix_path}")

    profile_file = PROFILE_DIR / f"{profile_key}.profile"
    if not profile_file.exists():
        warn(f"Profile not found: {profile_file}")
        return

    env = _load_profile(profile_file)
    env["WINEPREFIX"] = str(prefix_path)
    env["WINEARCH"] = env.get("WINEARCH", "win64")

    if not prefix_path.exists():
        info(f"Initializing {name} Wine prefix...")
        subprocess.run(["wineboot", "--init"], env={**os.environ, **env},
                       check=False, capture_output=True)
    else:
        ok(f"Using existing prefix at {prefix_path}")

    # Apply registry defaults
    reg = Path("/usr/share/selahbridgepro/selahwine-defaults.reg")
    if reg.exists():
        subprocess.run(["wine", "regedit", str(reg)],
                       env={**os.environ, **env}, check=False, capture_output=True)
        ok(f"Registry defaults applied for {name}")

    # Apply DAW-specific registry fixes
    extra_reg_path = env.get("SELAH_REG_EXTRA", "")
    if extra_reg_path and Path(extra_reg_path).exists():
        subprocess.run(["wine", "regedit", extra_reg_path],
                       env={**os.environ, **env}, check=False, capture_output=True)
        ok(f"DAW-specific registry fixes applied for {name}")

    # Digital Performer: install native VC++ 2022 redistributable
    # This fixes the msvcp140 null vtable crash (motucorelibs ABI mismatch)
    if profile_key in ("digitalperformer",):
        info("Installing VC++ 2022 Redistributable (required for Digital Performer)...")
        result = subprocess.run(
            ["winetricks", "-q", "vcrun2022"],
            env={**os.environ, **env}, check=False, capture_output=True, text=True
        )
        if result.returncode == 0:
            ok("vcrun2022 installed — native msvcp140/vcruntime140 active")
        else:
            warn("vcrun2022 install failed — DP may crash on launch")
            warn("Manual fix: WINEPREFIX=~/.wine-selah-digitalperformer winetricks vcrun2022")

        # Run the DP installer if provided, then re-apply service-disable patches.
        # The DP installer overwrites the mDNSResponder/Bonjour service registry entries
        # it just created — re-applying dp-fixes.reg after install restores Start=4
        # (disabled) and the IFEO intercept that prevents the authorization hang.
        if installer_path:
            installer = Path(installer_path).expanduser().resolve()
            if not installer.exists():
                warn(f"Installer not found: {installer}")
            else:
                info(f"Running Digital Performer installer: {installer.name}")
                info("Complete the installer window, then close it to continue.")
                subprocess.run(
                    ["wine", str(installer)],
                    env={**os.environ, **env},
                    check=False
                )
                ok("Digital Performer installer finished")

                # Re-apply dp-fixes.reg: installer overwrote our Bonjour service
                # entries with Start=2 (auto) — put them back to Start=4 (disabled)
                # and restore the IFEO intercept for motuDNSResponder.exe.
                if extra_reg_path and Path(extra_reg_path).exists():
                    info("Re-applying post-install service patches...")
                    subprocess.run(
                        ["wine", "regedit", extra_reg_path],
                        env={**os.environ, **env}, check=False, capture_output=True
                    )
                    ok("motuDNSResponder disabled — authorization hang prevented")

    # MPC Software: install VC++ 2019, .NET 4.8, and DirectX 9 components
    if profile_key in ("mpc",):
        info("Installing MPC Software dependencies...")
        mpc_deps = [
            ("vcredist2019", "VC++ 2019 Redistributable"),
            ("dotnet48",     ".NET Framework 4.8"),
            ("d3dx9",        "DirectX 9 (D3DX9)"),
            ("directx9",     "DirectX 9 runtime"),
        ]
        for pkg, desc in mpc_deps:
            r = subprocess.run(
                ["winetricks", "-q", pkg],
                env={**os.environ, **env}, check=False, capture_output=True, text=True
            )
            if r.returncode == 0:
                ok(f"{desc} installed")
            else:
                warn(f"{desc} install failed — MPC Software may have issues")
        # Trigger hidraw udev rules so Wine can reach display/LED HID interface
        subprocess.run(["sudo", "udevadm", "trigger",
                        "--action=add", "--subsystem-match=hidraw"],
                       check=False, capture_output=True)
        ok("HID passthrough rules triggered for MPC Studio 2 display/LEDs")

    # Install WineASIO into this prefix
    subprocess.run(["selah-asio-config", "--install"],
                   env={**os.environ, **env}, check=False)

    ok(f"{name} prefix ready at {prefix_path}")


# ═══════════════════════════════════════════════════════════════════════════════
#  LAUNCH
# ═══════════════════════════════════════════════════════════════════════════════

def _load_profile(profile_file: Path) -> dict:
    """Source a shell profile file and return its exported variables."""
    env = {}
    for line in profile_file.read_text().splitlines():
        line = line.strip()
        if line.startswith("#") or "=" not in line:
            continue
        key, _, val = line.partition("=")
        key = key.strip()
        val = val.strip().strip('"').strip("'")
        if re.match(r'^[A-Z_][A-Z0-9_]*$', key):
            env[key] = val
    return env

def cmd_launch(daw_name: str, exe_override: str | None = None):
    """Launch a DAW under SelahWine with its profile."""
    _check_license()

    daw_key = daw_name.lower()
    daw = KNOWN_DAWS.get(daw_key)
    if not daw:
        die(f"Unknown DAW '{daw_name}'. Known: {', '.join(KNOWN_DAWS)}")

    hdr(f"Launching {daw['name']}")

    profile_file = PROFILE_DIR / f"{daw['profile']}.profile"
    if not profile_file.exists():
        warn(f"Profile not found: {profile_file} — using defaults")
        profile_file = PROFILE_DIR / "default.profile"

    profile_env = _load_profile(profile_file) if profile_file.exists() else {}

    # Build runtime environment
    rate   = int(profile_env.get("SELAH_AUDIO_RATE",   "48000"))
    buffer = int(profile_env.get("SELAH_AUDIO_BUFFER", "256"))
    latency_ms = (buffer / rate) * 1000

    # Allow per-app prefix override (e.g. Spark lives in ~/.wine, not ~/.wine-selah-apps)
    prefix_override = daw.get("_prefix")
    if prefix_override:
        prefix = Path(prefix_override).expanduser()
    else:
        prefix = Path.home() / f".wine-selah-{daw['profile']}"
        if not prefix.exists():
            prefix = Path.home() / ".wine-selah"

    launch_env = {
        **os.environ,
        **profile_env,
        "WINEPREFIX":            str(prefix),
        "PIPEWIRE_LATENCY":      f"{buffer}/{rate}",
        "WINEESYNC":             profile_env.get("WINEESYNC", "1"),
        "WINEFSYNC":             profile_env.get("WINEFSYNC", "1"),
        "WINE_DISABLE_CRASH_REPORT": "1",
        "WINEDEBUG":             profile_env.get("WINEDEBUG", "-all"),
        "DXVK_ASYNC":            profile_env.get("DXVK_ASYNC", "1"),
        "DXVK_LOG_LEVEL":        profile_env.get("DXVK_LOG_LEVEL", "none"),
        # Route DAW ShellExecute URL calls to selahauth
        "BROWSER":               "selahauth",
    }
    if "WINEDLLOVERRIDES" in profile_env:
        launch_env["WINEDLLOVERRIDES"] = (
            profile_env["WINEDLLOVERRIDES"] + ";winemenubuilder.exe=d"
        )

    # Profile may override DISPLAY/WAYLAND_DISPLAY; also honour env vars.
    if "DISPLAY" in profile_env:
        launch_env["DISPLAY"] = profile_env["DISPLAY"]
    if "WAYLAND_DISPLAY" in profile_env:
        launch_env["WAYLAND_DISPLAY"] = profile_env.get("WAYLAND_DISPLAY", "")

    exe = exe_override or daw["exe"]
    info(f"Profile:  {daw['profile']}.profile")
    info(f"Prefix:   {prefix}")
    info(f"Latency:  {latency_ms:.1f} ms  ({buffer} samples @ {rate} Hz)")
    info(f"Exe:      {exe}")

    # Reconfigure PipeWire for this session
    subprocess.run(["selah-asio-config", "--rate", str(rate), "--buffer", str(buffer)],
                   env=launch_env, check=False, capture_output=True)

    # Apply extra per-DAW registry file if the profile specifies one
    extra_reg = profile_env.get("SELAH_REG_EXTRA", "")
    if extra_reg and Path(extra_reg).exists():
        info(f"Applying DAW-specific registry fixes...")
        subprocess.run(
            ["wine", "regedit", extra_reg],
            env=launch_env, check=False, capture_output=True
        )

    # Pre-launch background services (e.g. LDSvc.exe for Digital Performer)
    prelaunches = profile_env.get("SELAH_PRELAUNCHES", "").split()
    prelaunch_wait = int(profile_env.get("SELAH_PRELAUNCH_WAIT", "0"))
    if prelaunches:
        selahwine_bin = shutil.which("selahwine") or "selahwine"
        for svc_exe in prelaunches:
            info(f"Pre-launching service: {svc_exe}")
            subprocess.Popen(
                [selahwine_bin, "--profile", daw["profile"],
                 "start", "/b", svc_exe],
                env=launch_env,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
        if prelaunch_wait > 0:
            import time
            info(f"Waiting {prelaunch_wait}s for services to register COM servers...")
            time.sleep(prelaunch_wait)

    # Launch via selahwine (which wraps wine-staging)
    selahwine = shutil.which("selahwine") or "selahwine"
    extra_args = daw.get("_args", [])
    cmd = [selahwine, "--profile", daw["profile"], exe] + extra_args
    info(f"Running: {' '.join(cmd)}")

    # Fix EBADF: when launched from a desktop environment (KDE app launcher),
    # fds 1 and 2 may be closed.  Electron/Node.js tries to wrap them as
    # sockets and throws "Error: open EBADF".  Redirect them to the app log
    # before exec so Wine inherits valid file descriptors.
    log_name = daw.get("_log", f"winapp-{daw['name'].replace(' ', '-')}.log")
    log_dir  = Path("/var/log/selahbridgepro")
    log_path = log_dir / log_name
    try:
        is_tty = os.isatty(1) and os.isatty(2)
    except OSError:
        is_tty = False
    if not is_tty:
        try:
            log_dir.mkdir(parents=True, exist_ok=True, mode=0o755)
            fd = os.open(str(log_path), os.O_WRONLY | os.O_CREAT | os.O_APPEND, 0o644)
            os.dup2(fd, 1)
            os.dup2(fd, 2)
            os.close(fd)
        except OSError:
            pass  # best-effort; proceed even if log redirect fails

    try:
        os.execve(selahwine, cmd, launch_env)
    except FileNotFoundError:
        die("selahwine not found. Run: selahpro install")


# ═══════════════════════════════════════════════════════════════════════════════
#  DIAGNOSE
# ═══════════════════════════════════════════════════════════════════════════════

def cmd_diagnose(verbose=False):
    """Run a system readiness check for DAW production."""
    hdr("SelahBridgePro System Diagnosis")

    checks = []

    def chk(label, ok_cond, ok_msg, fail_msg, fix=""):
        passed = ok_cond()
        sym = f"{TEAL}✓{RESET}" if passed else f"{RED}✗{RESET}"
        msg = ok_msg if passed else fail_msg
        print(f"  {sym} {PARCH}{label:<28}{RESET} {MUTED}{msg}{RESET}")
        if not passed and fix and verbose:
            print(f"    {DIM}fix: {fix}{RESET}")
        checks.append(passed)
        return passed

    # Wine
    chk("wine-staging",
        lambda: bool(shutil.which("wine")),
        "found", "NOT FOUND",
        "selahpro install")

    # WineASIO
    chk("wineasio",
        lambda: bool(subprocess.run(
            ["find", "/usr/lib", "/usr/lib32", "/usr/local/lib",
             "-name", "wineasio*.dll.so", "-o", "-name", "wineasio64.dll.so"],
            capture_output=True).stdout.strip()),
        "installed", "not installed",
        "yay -S wineasio")

    # PipeWire
    chk("PipeWire",
        lambda: bool(shutil.which("pipewire")),
        "found", "NOT FOUND",
        "sudo pacman -S pipewire pipewire-pulse")

    # pipewire-jack
    chk("pipewire-jack bridge",
        lambda: bool(subprocess.run(
            ["find", "/usr/lib", "/usr/lib32", "-name", "libjack*.so*"],
            capture_output=True).stdout.strip()),
        "found", "not found",
        "sudo pacman -S pipewire-jack lib32-pipewire-jack")

    # PipeWire running
    chk("PipeWire running",
        lambda: subprocess.run(["pgrep", "pipewire"],
                                capture_output=True).returncode == 0,
        "active", "not running",
        "systemctl --user start pipewire pipewire-pulse")

    # DXVK (D3D9/10/11 -> Vulkan)  — installed via AUR dxvk-mingw
    chk("DXVK (D3D9/10/11)",
        lambda: bool(subprocess.run(
            ["find", "/usr/share/dxvk", "/usr/share/dxvk-mingw",
             "/usr/share/dxvk-async", "-name", "d3d11.dll"],
            capture_output=True).stdout.strip()),
        "found", "not found",
        "yay -S dxvk-mingw")

    # VKD3D-Proton (D3D12 -> Vulkan) — installed via AUR vkd3d-proton-bin
    chk("VKD3D-Proton (D3D12)",
        lambda: bool(subprocess.run(
            ["find", "/usr/share/vkd3d-proton", "/usr/share/vkd3d-proton-mingw",
             "/usr/lib/vkd3d-proton", "-name", "d3d12.dll"],
            capture_output=True).stdout.strip()),
        "found", "not found",
        "yay -S vkd3d-proton-bin")

    # Vulkan driver
    chk("Vulkan ICD / driver",
        lambda: bool(subprocess.run(
            ["find", "/usr/share/vulkan/icd.d", "-name", "*.json"],
            capture_output=True).stdout.strip()),
        "found", "not found",
        "sudo pacman -S vulkan-intel  (or vulkan-radeon for AMD)")

    # Realtime limits
    chk("realtime audio limits",
        lambda: (Path("/etc/security/limits.conf").exists() and
                 "@audio" in Path("/etc/security/limits.conf").read_text()),
        "configured", "not set",
        "selahpro audio config")

    # audio group
    user = os.environ.get("USER", "")
    chk(f"user in audio group",
        lambda: "audio" in subprocess.run(
            ["groups", user], capture_output=True, text=True).stdout,
        "yes", "no",
        f"sudo usermod -aG audio {user}")

    # udev MIDI rules
    chk("MIDI udev rules",
        lambda: Path("/etc/udev/rules.d/99-selah-midi.rules").exists(),
        "present", "missing",
        "selahpro install")

    # linux-zen kernel
    chk("linux-zen kernel",
        lambda: "zen" in subprocess.run(
            ["uname", "-r"], capture_output=True, text=True).stdout,
        "active", "not active (recommended for low latency)")

    # fsync kernel support
    chk("fsync support",
        lambda: Path("/proc/sys/kernel/ngroups_max").exists(),
        "available", "may not be available")

    passed = sum(checks)
    total  = len(checks)
    color  = TEAL if passed == total else (GOLD if passed >= total * 0.7 else RED)
    print(f"\n  {color}{BOLD}{passed}/{total}{RESET} checks passed\n")

    if passed < total:
        if verbose:
            info(f"Run 'selahpro install' to fix most issues")
        else:
            info(f"Run 'selahpro diagnose --verbose' to see fix commands")


# ═══════════════════════════════════════════════════════════════════════════════
#  MIDI
# ═══════════════════════════════════════════════════════════════════════════════

def cmd_midi_list():
    """List USB MIDI devices and ALSA sequencer ports."""
    hdr("MIDI Devices")

    # USB MIDI via /dev/selah-midi symlinks
    midi_links = list(Path("/dev/selah-midi").glob("*")) if Path("/dev/selah-midi").exists() else []
    if midi_links:
        ok("SelahBridgePro MIDI devices:")
        for link in sorted(midi_links):
            target = link.resolve() if link.is_symlink() else link
            print(f"    {TEAL}{link.name:<24}{RESET} → {MUTED}{target}{RESET}")
    else:
        info("No SelahBridgePro MIDI symlinks found (connect a device)")

    # Raw USB devices — Akai VID
    print()
    usb_result = subprocess.run(
        ["find", "/dev/bus/usb", "-type", "c"],
        capture_output=True, text=True, check=False)

    akai_result = _lsusb("-d", "09e8:")
    if akai_result is None:
        warn("lsusb not found (usbutils not installed) — Akai detection skipped")
        info("Install: sudo pacman -S usbutils")
    elif akai_result.stdout.strip():
        ok("Akai USB devices found:")
        for line in akai_result.stdout.strip().splitlines():
            print(f"    {PARCH}{line}{RESET}")
    else:
        info("No Akai devices connected")

    # ALSA sequencer ports
    print()
    aconnect = subprocess.run(["aconnect", "-l"],
                               capture_output=True, text=True, check=False)
    if aconnect.returncode == 0 and aconnect.stdout.strip():
        ok("ALSA MIDI sequencer ports:")
        for line in aconnect.stdout.strip().splitlines():
            print(f"    {PARCH}{line}{RESET}")
    else:
        info("No ALSA MIDI ports — install alsa-utils or connect a device")

def cmd_midi_passthrough(device: str):
    """Set up USB passthrough for a named MIDI device."""
    hdr(f"USB MIDI Passthrough: {device}")
    _check_license()

    device_map = {
        "akai-mpk-mini4":         ("09e8", "006b"),
        "mpk":                    ("09e8", "006b"),
        "akai-mpc-studio2":       ("09e8", "004a"),
        "mpc":                    ("09e8", "004a"),
        "akai-mpc-studio2-legacy":("09e8", "0076"),
    }

    dev_key = device.lower().replace(" ", "-")
    if dev_key not in device_map:
        # Try by lsusb name
        lsusb = _lsusb()
        if lsusb is None:
            warn("lsusb not found (usbutils not installed) — cannot list connected USB devices")
            info("Install: sudo pacman -S usbutils")
        else:
            info(f"Connected USB devices:\n{lsusb.stdout}")
        info(f"Known device IDs: {', '.join(device_map.keys())}")
        die(f"Unknown device '{device}'. Pass the key from the list above.")

    vid, pid = device_map[dev_key]
    info(f"VID:PID = {vid}:{pid}")

    # Find the USB device path
    result = _lsusb("-d", f"{vid}:{pid}")
    if result is None:
        warn("lsusb not found (usbutils not installed) — skipping device presence check")
        info("Install: sudo pacman -S usbutils")
    elif not result.stdout.strip():
        die(f"Device {vid}:{pid} not connected. Plug it in and retry.")
    else:
        ok(f"Device found: {result.stdout.strip()}")

    # Reload udev to ensure rules are applied
    subprocess.run(["sudo", "udevadm", "control", "--reload-rules"],
                   check=False, capture_output=True)
    subprocess.run(["sudo", "udevadm", "trigger",
                    "--action=add", "--subsystem-match=usb"],
                   check=False, capture_output=True)
    ok("udev rules reloaded")

    # Check ALSA MIDI node
    alsa_nodes = list(Path("/dev/snd").glob("midiC*D*"))
    if alsa_nodes:
        ok(f"ALSA MIDI nodes: {', '.join(str(n) for n in alsa_nodes)}")
    else:
        warn("No ALSA MIDI nodes — device may need snd-usb-audio loaded")
        subprocess.run(["sudo", "modprobe", "snd-usb-audio"],
                       check=False, capture_output=True)

    # Trigger hidraw rules so display/LED HID interface is accessible
    subprocess.run(["sudo", "udevadm", "trigger",
                    "--action=add", "--subsystem-match=hidraw"],
                   check=False, capture_output=True)

    # Confirm HID device is accessible
    mpc_hid = Path("/dev/selah-mpc-hid")
    hidraw_nodes = sorted(Path("/dev").glob("hidraw*"))
    if mpc_hid.exists():
        ok(f"MPC HID device: {mpc_hid} → {mpc_hid.resolve()}")
    elif hidraw_nodes:
        ok(f"HID raw nodes available: {', '.join(str(h) for h in hidraw_nodes[:4])}")
        info("Run 'selah-mpc-bridge hid-monitor' to confirm display/LED access")
    else:
        warn("No hidraw nodes found — display and RGB LED control unavailable")
        info("Check: /etc/udev/rules.d/99-selah-midi.rules")

    info("SysEx passthrough: enabled via hidraw (see udev rules)")
    info("Wine will see this device as a Windows MIDI device via WineASIO/ALSA")
    ok("Passthrough configured. Launch MPC Software with: selahpro launch mpc")


# ═══════════════════════════════════════════════════════════════════════════════
#  AUTH BROWSER
# ═══════════════════════════════════════════════════════════════════════════════

def _pyqt6_webengine_available() -> bool:
    try:
        import importlib.util
        return importlib.util.find_spec("PyQt6.QtWebEngineWidgets") is not None
    except Exception:
        return False

def cmd_auth(daw_name: str | None, url: str | None = None):
    """Open the authorization browser for a DAW or a specific URL."""
    _check_license()

    selahauth = shutil.which("selahauth")
    if not selahauth:
        die("selahauth not found. Run: selahpro install")

    if not _pyqt6_webengine_available():
        warn("python-pyqt6-webengine not installed — selahauth will open system browser")
        info("Install: sudo pacman -S python-pyqt6-webengine")

    if url:
        hdr("SelahBridgePro Authorization")
        info(f"URL: {url}")
        os.execvp(selahauth, [selahauth, url])
    elif daw_name:
        daw_key = daw_name.lower()
        if daw_key not in KNOWN_DAWS:
            die(f"Unknown DAW '{daw_name}'. Known: {', '.join(KNOWN_DAWS)}")
        hdr(f"{KNOWN_DAWS[daw_key]['name']} Authorization")
        os.execvp(selahauth, [selahauth, "--daw", daw_key])
    else:
        hdr("SelahBridgePro Authorization Browser")
        info("Usage: selahpro auth <daw>  or  selahpro auth --url <url>")
        info("Known DAWs: " + ", ".join(KNOWN_DAWS))
        subprocess.run([selahauth, "--list"])


# ═══════════════════════════════════════════════════════════════════════════════
#  AUDIO CONFIG
# ═══════════════════════════════════════════════════════════════════════════════

def cmd_audio_config(rate: int, buffer: int):
    """Configure PipeWire + SelahASIO for low-latency audio production."""
    hdr("SelahASIO Audio Configuration")
    _check_license()

    latency_ms = (buffer / rate) * 1000
    info(f"Sample rate:  {rate} Hz")
    info(f"Buffer size:  {buffer} samples")
    info(f"Latency:      {latency_ms:.2f} ms")

    if latency_ms > 10:
        warn(f"{latency_ms:.1f} ms exceeds 10ms — for studio work, try --buffer 128 or --buffer 256")
    elif latency_ms <= 5:
        ok(f"{latency_ms:.2f} ms — sub-5ms target achieved")

    subprocess.run(["selah-asio-config",
                    "--rate", str(rate), "--buffer", str(buffer)],
                   check=False)

    # Ensure realtime limits exist
    limits_path = Path("/etc/security/limits.conf")
    if limits_path.exists():
        content = limits_path.read_text()
        if "@audio" not in content:
            try:
                with limits_path.open("a") as f:
                    f.write("\n# SelahBridgePro realtime audio\n"
                            "@audio  -  rtprio   88\n"
                            "@audio  -  memlock  unlimited\n")
                ok("Realtime limits added to /etc/security/limits.conf")
            except PermissionError:
                warn("Cannot write limits.conf — run as root")
        else:
            ok("Realtime limits already configured")

    # Restart PipeWire to pick up new quantum
    info("Restarting PipeWire...")
    subprocess.run(["systemctl", "--user", "restart",
                    "pipewire", "pipewire-pulse"],
                   check=False, capture_output=True)
    ok("PipeWire restarted with new audio settings")
    info("Run 'selahpro diagnose' to verify the full stack")


# ═══════════════════════════════════════════════════════════════════════════════
#  GENERIC WINE PREFIXES (non-DAW Windows apps — iLok License Manager, installers, etc.)
# ═══════════════════════════════════════════════════════════════════════════════

PREFIXES_DIR = Path.home() / ".selahbridgepro" / "prefixes"

def cmd_prefix_create(name: str):
    """Create an isolated Wine prefix for a Windows app."""
    prefix_dir = PREFIXES_DIR / name
    if prefix_dir.exists():
        info(f"Prefix '{name}' already exists at {prefix_dir}")
        return
    hdr(f"Creating Wine Prefix: {name}")
    prefix_dir.mkdir(parents=True, exist_ok=True)
    env = {**os.environ, "WINEPREFIX": str(prefix_dir), "WINEARCH": "win64"}
    subprocess.run(["wineboot", "--init"], env=env, check=False, capture_output=True)
    ok(f"Created prefix '{name}' at {prefix_dir}")

def cmd_prefix_list():
    """List all SelahBridgePro-managed Wine prefixes."""
    hdr("SelahBridgePro Wine Prefixes")
    prefixes = sorted(p for p in PREFIXES_DIR.glob("*") if p.is_dir()) if PREFIXES_DIR.exists() else []
    if not prefixes:
        info("No prefixes created yet — run: selahpro prefix create <name>")
        return
    for p in prefixes:
        print(f"    {TEAL}{p.name:<24}{RESET} {MUTED}{p}{RESET}")

def cmd_prefix_delete(name: str):
    """Remove a Wine prefix."""
    prefix_dir = PREFIXES_DIR / name
    if not prefix_dir.exists():
        die(f"Prefix '{name}' not found. Run: selahpro prefix list")
    shutil.rmtree(prefix_dir)
    ok(f"Deleted prefix '{name}'")

def cmd_run(prefix_name: str, exe_path: str):
    """Run a Windows executable inside a specific prefix."""
    _check_license()
    prefix_dir = PREFIXES_DIR / prefix_name
    if not prefix_dir.exists():
        die(f"Prefix '{prefix_name}' not found. Run: selahpro prefix create {prefix_name}")
    exe = Path(exe_path).expanduser().resolve()
    if not exe.exists():
        die(f"File not found: {exe}")

    hdr(f"Running in prefix '{prefix_name}'")
    info(f"Exe: {exe}")
    env = {**os.environ, "WINEPREFIX": str(prefix_dir)}
    subprocess.run(["wine", str(exe)], env=env, check=False)

def cmd_install_app(name: str, exe_path: str):
    """Full workflow: create a prefix, apply general Windows-app fixes, run the installer."""
    _check_license()
    exe = Path(exe_path).expanduser().resolve()
    if not exe.exists():
        die(f"Installer not found: {exe}")

    hdr(f"Installing {name}")
    cmd_prefix_create(name)
    prefix_dir = PREFIXES_DIR / name
    env = {**os.environ, "WINEPREFIX": str(prefix_dir)}

    # Common dependencies most Windows installers/utilities expect.
    info("Installing common dependencies (corefonts, vcrun2022)...")
    subprocess.run(["winetricks", "-q", "corefonts", "vcrun2022"],
                   env=env, check=False, capture_output=True)

    info(f"Running installer: {exe.name}")
    info("Complete the installer window, then close it to continue.")
    subprocess.run(["wine", str(exe)], env=env, check=False)
    ok(f"'{name}' set up in prefix at {prefix_dir}")
    info(f"Run it again with: selahpro run {name} <path-to-exe-inside-prefix>")


# ═══════════════════════════════════════════════════════════════════════════════
#  UNIVERSAL APP DETECTION (native / Flatpak / AUR / web — checked before Wine)
# ═══════════════════════════════════════════════════════════════════════════════

APP_COMPAT_DB = Path("/usr/share/selahos/app-compat-db.json")

def _load_compat_db() -> list[dict]:
    if not APP_COMPAT_DB.exists():
        return []
    try:
        return json.loads(APP_COMPAT_DB.read_text())
    except (json.JSONDecodeError, OSError):
        return []

def _search_pacman(query: str) -> bool | None:
    if not shutil.which("pacman"):
        return None
    r = subprocess.run(["pacman", "-Ss", query], capture_output=True, text=True, check=False)
    return bool(r.stdout.strip())

def _search_aur(query: str) -> bool | None:
    yay = shutil.which("yay")
    if not yay:
        return None
    r = subprocess.run([yay, "-Ss", "--aur", query], capture_output=True, text=True, check=False)
    return bool(r.stdout.strip())

def _search_flatpak(query: str) -> bool | None:
    if not shutil.which("flatpak"):
        return None
    r = subprocess.run(["flatpak", "search", query], capture_output=True, text=True, check=False)
    return bool(r.stdout.strip()) and "No matches found" not in r.stdout

def cmd_find_app(name: str):
    """Check native/Flatpak/AUR/web alternatives before recommending Wine."""
    hdr(f"Searching for: {name}")

    native = _search_pacman(name)
    aur    = _search_aur(name)
    flat   = _search_flatpak(name)
    entry  = next((e for e in _load_compat_db() if e.get("app", "").lower() == name.lower()), None)

    def line(label, found):
        sym = f"{TEAL}✓{RESET}" if found else (f"{MUTED}?{RESET}" if found is None else f"{MUTED}–{RESET}")
        txt = "Found" if found else ("no tool to check" if found is None else "Not found")
        print(f"  {sym} {PARCH}{label:<16}{RESET} {MUTED}{txt}{RESET}")

    line("Native Linux:", native)
    line("AUR:", aur)
    line("Flatpak:", flat)

    web  = entry.get("web_fallback") if entry else None
    wine = entry.get("wine_config", {}) if entry else {}
    print(f"  {TEAL + '✓' + RESET if web else MUTED + '–' + RESET} {PARCH}{'Web wrapper:':<16}{RESET} "
          f"{MUTED}{web or 'Not available'}{RESET}")
    if entry:
        print(f"  {TEAL}✓{RESET} {PARCH}{'Wine compatible:':<16}{RESET} {MUTED}Yes ({entry.get('approach', 'unknown')}){RESET}")
    else:
        print(f"  {MUTED}?{RESET} {PARCH}{'Wine compatible:':<16}{RESET} {MUTED}Unknown — not in app-compat-db.json{RESET}")

    print()
    profile = entry.get("selahpro_daw") if entry else None
    if native or aur:
        info("Recommendation: install from official repos/AUR — no Wine needed")
    elif web:
        info(f"Recommendation: use web wrapper — selahpro web-app \"{entry['app']}\" \"{web}\"")
    elif profile:
        info(f"Recommendation: Wine — selahpro install {profile}  (then: selahpro launch {profile})")
    elif wine:
        info(f"Recommendation: Wine — selahpro install-app {wine.get('prefix', name.lower())} <installer.exe>")
    else:
        info("No known alternative — check WineHQ AppDB: https://appdb.winehq.org")

def cmd_web_app(name: str, url: str):
    """Wrap a web app as a desktop app via nativefier."""
    hdr(f"Creating Web App: {name}")

    nativefier = shutil.which("nativefier")
    if not nativefier:
        die("nativefier not found. Install: sudo npm install -g nativefier")

    safe_name = re.sub(r"[^A-Za-z0-9]+", "", name) or "WebApp"
    apps_dir = Path.home() / "Applications"
    apps_dir.mkdir(parents=True, exist_ok=True)

    info(f"Running nativefier for {url} ...")
    result = subprocess.run([nativefier, "--name", safe_name, url, str(apps_dir)], check=False)
    if result.returncode != 0:
        die("nativefier failed — see output above")

    candidates = sorted(apps_dir.glob(f"{safe_name}-linux-*"))
    if not candidates:
        die(f"nativefier finished but no output directory found under {apps_dir}")
    exe = candidates[-1] / safe_name
    if not exe.exists():
        warn(f"Expected binary not found at {exe} — check {candidates[-1]}")

    desktop_dir = Path.home() / ".local/share/applications"
    desktop_dir.mkdir(parents=True, exist_ok=True)
    desktop_file = desktop_dir / f"{safe_name.lower()}.desktop"
    desktop_file.write_text(
        "[Desktop Entry]\n"
        "Type=Application\n"
        f"Name={name}\n"
        f"Comment={name} (web)\n"
        f"Exec={exe}\n"
        "Icon=internet-mail\n"
        "Terminal=false\n"
        "Categories=Network;\n"
    )
    ok(f"Desktop entry created: {desktop_file}")
    info(f"Launch from your application menu, or run: {exe}")


# ═══════════════════════════════════════════════════════════════════════════════
#  ARGUMENT PARSER
# ═══════════════════════════════════════════════════════════════════════════════

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="selahpro",
        description=f"SelahBridgePro v{VERSION} — Creator DAW compatibility for SelahOS",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            f"  {GOLD}selahpro install dp --installer ~/Downloads/DP1136.exe{RESET}  Install Digital Performer\n"
            f"  {GOLD}selahpro install flstudio{RESET}          Install + scaffold FL Studio prefix\n"
            f"  {GOLD}selahpro install mpc{RESET}               Install + scaffold MPC Software prefix\n"
            f"  {GOLD}selahpro install{RESET}                   Install SelahBridgePro runtime only\n"
            f"  {GOLD}selahpro launch reaper{RESET}             Launch REAPER via SelahWine\n"
            f"  {GOLD}selahpro launch mpc{RESET}                Launch MPC Software via SelahWine\n"
            f"  {GOLD}selahpro auth ableton{RESET}              Open Ableton authorization browser\n"
            f"  {GOLD}selahpro auth mpc{RESET}                  Open Akai account portal\n"
            f"  {GOLD}selahpro diagnose{RESET}                  Full system readiness check\n"
            f"  {GOLD}selahpro midi list{RESET}                 List MIDI devices\n"
            f"  {GOLD}selahpro midi passthrough mpc{RESET}      Activate MPC Studio 2 HID passthrough\n"
            f"  {GOLD}selahpro audio config --buffer 128{RESET} Configure low-latency audio\n"
            f"  {GOLD}selahpro prefix create ilok{RESET}       Create a Wine prefix for iLok License Manager\n"
            f"  {GOLD}selahpro run ilok ~/Downloads/iLok.exe{RESET}  Run an .exe inside that prefix\n"
            f"  {GOLD}selahpro install-app ilok ~/Downloads/iLok.exe{RESET}  Create + install in one step\n"
            f"  {GOLD}selahpro find-app \"Spark\"{RESET}          Check native/Flatpak/AUR/web before using Wine\n"
            f"  {GOLD}selahpro web-app \"Spark Mail\" \"https://mail.sparkmailapp.com\"{RESET}  Wrap a web app\n"
        )
    )
    p.add_argument("--version", action="version", version=f"selahpro {VERSION}")
    p.add_argument("--machine-id", action="store_true",
                   help="Print machine ID (send to support for licensing)")
    p.add_argument("--activate", metavar="KEY",
                   help="Activate with a license key")
    p.add_argument("--status", action="store_true",
                   help="Show license / trial status")

    sub = p.add_subparsers(dest="command")

    # install
    ins = sub.add_parser("install", help="Install SelahBridgePro runtime [+ DAW scaffold]")
    ins.add_argument("daw", nargs="?",
                     help="DAW to scaffold (flstudio/ableton/reaper/protools/dp)")
    ins.add_argument("--prefix", metavar="PATH",
                     help="Apply fixes to an existing Wine prefix instead of creating a new one")
    ins.add_argument("--installer", metavar="PATH",
                     help="Path to the DAW installer .exe — runs it after prefix setup and re-applies service patches post-install")

    # launch
    launch = sub.add_parser("launch", help="Launch a DAW via SelahWine")
    launch.add_argument("daw", help="DAW to launch")
    launch.add_argument("--exe", help="Override executable path")

    # diagnose
    diag = sub.add_parser("diagnose", help="Run system readiness checks")
    diag.add_argument("--verbose", "-v", action="store_true",
                      help="Show fix commands for failed checks")

    # auth
    auth = sub.add_parser("auth", help="Open DAW authorization browser")
    auth.add_argument("daw", nargs="?",
                      help="DAW to authorize (flstudio/ableton/reaper/protools)")
    auth.add_argument("--url", metavar="URL", help="Open a specific authorization URL")

    # midi
    midi = sub.add_parser("midi", help="MIDI device management")
    midi_sub = midi.add_subparsers(dest="midi_cmd")
    midi_sub.add_parser("list", help="List MIDI devices")
    midi_pt = midi_sub.add_parser("passthrough", help="Enable USB passthrough for a device")
    midi_pt.add_argument("device", help="Device name (e.g. mpk, mpc, akai-mpk-mini4)")

    # audio
    audio = sub.add_parser("audio", help="Audio configuration")
    audio_sub = audio.add_subparsers(dest="audio_cmd")
    audio_cfg = audio_sub.add_parser("config", help="Configure PipeWire + SelahASIO")
    audio_cfg.add_argument("--rate", type=int, default=48000,
                           help="Sample rate in Hz (default: 48000)")
    audio_cfg.add_argument("--buffer", type=int, default=256,
                           help="Buffer size in samples (default: 256)")

    # prefix
    prefix = sub.add_parser("prefix", help="Manage isolated Wine prefixes for Windows apps")
    prefix_sub = prefix.add_subparsers(dest="prefix_cmd")
    prefix_create = prefix_sub.add_parser("create", help="Create a new Wine prefix")
    prefix_create.add_argument("name", help="Prefix name (e.g. ilok)")
    prefix_sub.add_parser("list", help="List all Wine prefixes")
    prefix_delete = prefix_sub.add_parser("delete", help="Remove a Wine prefix")
    prefix_delete.add_argument("name", help="Prefix name to delete")

    # run
    run = sub.add_parser("run", help="Run a Windows .exe inside a specific prefix")
    run.add_argument("prefix", help="Prefix name")
    run.add_argument("exe", help="Path to the .exe to run")

    # install-app
    install_app = sub.add_parser("install-app",
                                  help="Create a prefix and install a Windows app (auto-configured)")
    install_app.add_argument("name", help="App name (used as the prefix name)")
    install_app.add_argument("exe", help="Path to the installer .exe")

    # find-app
    find_app = sub.add_parser("find-app",
                               help="Check native/Flatpak/AUR/web alternatives before using Wine")
    find_app.add_argument("name", help="App name to search for")

    # web-app
    web_app = sub.add_parser("web-app", help="Wrap a web app as a desktop app (via nativefier)")
    web_app.add_argument("name", help="Display name for the app")
    web_app.add_argument("url", help="URL to wrap")

    return p


def main():
    # No-arg: print banner + help
    if len(sys.argv) == 1:
        print(BANNER)
        build_parser().print_help()
        sys.exit(0)

    parser = build_parser()
    args = parser.parse_args()

    if args.machine_id:
        print(f"Machine ID: {GOLD}{_machine_id()}{RESET}")
        print(f"Email to:   {MUTED}{SUPPORT}{RESET}")
        sys.exit(0)

    if args.activate:
        cmd_activate(args.activate)
        sys.exit(0)

    if args.status:
        import datetime
        mid = _machine_id()
        hdr("SelahBridgePro Status")

        # ── License ────────────────────────────────────────────────────────
        print(f"  {MUTED}Machine ID:{RESET}  {GOLD}{mid}{RESET}")
        if LIC_FILE.exists():
            try:
                key = LIC_FILE.read_text().strip()
            except PermissionError:
                key = ""
            if key and key == _expected_key(mid):
                ok(f"Licensed — {PRODUCT} activated on this machine")
            elif key:
                warn("License file present but key does not match this machine")
            else:
                warn("License file unreadable — run: sudo selahpro --activate <KEY>")
        elif TRIAL_FILE.exists():
            try:
                first = datetime.date.fromisoformat(TRIAL_FILE.read_text().strip())
                used = (datetime.date.today() - first).days
                rem  = TRIAL_DAYS - used
                if rem > 0:
                    info(f"Trial: {rem} day(s) remaining (started {first})")
                else:
                    warn(f"Trial EXPIRED ({used} days ago)")
            except ValueError:
                warn("Corrupt trial file")
        else:
            info("No trial started yet — run any selahpro command to begin")

        # ── Devices ────────────────────────────────────────────────────────
        print()
        akai = _lsusb("-d", "09e8:")
        if akai is None:
            print(f"  {MUTED}Devices:{RESET}     {MUTED}not detected (usbutils not installed — run: sudo pacman -S usbutils){RESET}")
        else:
            akai_lines = [l.strip() for l in akai.stdout.splitlines() if l.strip()]
            dev_color = TEAL if akai_lines else MUTED
            print(f"  {MUTED}Devices:{RESET}     {dev_color}{len(akai_lines)} Akai device(s) connected{RESET}")
            for line in akai_lines:
                print(f"    {DIM}{line}{RESET}")

        # ── DAW prefixes ───────────────────────────────────────────────────
        prefixes = sorted(p for p in Path.home().glob(".wine-selah-*") if p.is_dir())
        pfx_color = TEAL if prefixes else MUTED
        print(f"  {MUTED}DAW prefixes:{RESET} {pfx_color}{len(prefixes)} installed{RESET}")
        for p in prefixes:
            daw_label = p.name.replace(".wine-selah-", "")
            print(f"    {DIM}{daw_label:<20} {p}{RESET}")

        # ── Audio stack ────────────────────────────────────────────────────
        pw = subprocess.run(["pgrep", "-x", "pipewire"],
                            capture_output=True).returncode == 0
        mpc = subprocess.run(["pgrep", "-f", "selah-mpc-bridge"],
                             capture_output=True).returncode == 0
        print()
        pw_sym  = f"{TEAL}✓{RESET}" if pw  else f"{RED}✗{RESET}"
        mpc_sym = f"{TEAL}✓{RESET}" if mpc else f"{MUTED}–{RESET}"
        print(f"  {pw_sym} PipeWire      {'running' if pw  else 'not running'}")
        print(f"  {mpc_sym} MPC bridge   {'running' if mpc else 'not started'}")
        print()

        sys.exit(0)

    cmd = args.command
    if cmd == "install":
        cmd_install(getattr(args, "daw", None), getattr(args, "prefix", None), getattr(args, "installer", None))
    elif cmd == "launch":
        cmd_launch(args.daw, getattr(args, "exe", None))
    elif cmd == "auth":
        cmd_auth(getattr(args, "daw", None), getattr(args, "url", None))
    elif cmd == "diagnose":
        cmd_diagnose(verbose=getattr(args, "verbose", False))
    elif cmd == "midi":
        if args.midi_cmd == "list":
            cmd_midi_list()
        elif args.midi_cmd == "passthrough":
            cmd_midi_passthrough(args.device)
        else:
            build_parser().parse_args(["midi", "--help"])
    elif cmd == "audio":
        if args.audio_cmd == "config":
            cmd_audio_config(args.rate, args.buffer)
        else:
            build_parser().parse_args(["audio", "--help"])
    elif cmd == "prefix":
        if args.prefix_cmd == "create":
            cmd_prefix_create(args.name)
        elif args.prefix_cmd == "list":
            cmd_prefix_list()
        elif args.prefix_cmd == "delete":
            cmd_prefix_delete(args.name)
        else:
            build_parser().parse_args(["prefix", "--help"])
    elif cmd == "run":
        cmd_run(args.prefix, args.exe)
    elif cmd == "install-app":
        cmd_install_app(args.name, args.exe)
    elif cmd == "find-app":
        cmd_find_app(args.name)
    elif cmd == "web-app":
        cmd_web_app(args.name, args.url)
    else:
        print(BANNER)
        parser.print_help()


if __name__ == "__main__":
    main()
