MUTED = "\033[38;2;154;141;123m"
RED   = "\033[38;2;185;122;111m"
BOLD  = "\033[1m"
DIM   = "\033[2m"
RESET = "\033[0m"

BANNER = f"""\
{GOLD}{BOLD}
  ╔══════════════════════════════════════════════════════════════╗
  ║        SelahBridgePro™  v{VERSION}  —  Creator DAW Layer         ║
  ║  Wine · DXVK · VKD3D-Proton · SelahASIO · USB MIDI          ║
  ╚══════════════════════════════════════════════════════════════╝
{RESET}"""

