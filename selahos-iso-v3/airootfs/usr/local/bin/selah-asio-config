#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════════════════════
#  selah-asio-config — SelahASIO v1 Configuration Tool
#  Direct PipeWire backend for Wine ASIO — <5ms target latency
#  Selah Technologies LLC — Copyright (C) 2026
#
#  Usage: selah-asio-config [--rate 48000] [--buffer 256] [--status]
#         selah-asio-config --auto-detect   (queries running DAW process)
#         selah-asio-config --install       (register WineASIO DLL)
#         selah-asio-config --benchmark     (measure achieved latency)
# ═══════════════════════════════════════════════════════════════════════════════

set -euo pipefail

GOLD=$'\033[38;2;214;168;90m'
PARCH=$'\033[38;2;237;228;212m'
TEAL=$'\033[38;2;142;195;184m'
MUTED=$'\033[38;2;154;141;123m'
RED=$'\033[38;2;185;122;111m'
BOLD=$'\033[1m'
RESET=$'\033[0m'

VERSION="1.0.0"
WINEPREFIX="${WINEPREFIX:-$HOME/.wine-selah}"
PIPEWIRE_CONF_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/pipewire/pipewire.conf.d"
JACK_CONF_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/pipewire"

ok()   { printf '  %s✓%s %s%s%s\n' "$TEAL" "$RESET" "$PARCH" "$1" "$RESET"; }
info() { printf '  %s→ %s%s\n' "$MUTED" "$1" "$RESET"; }
warn() { printf '  %s⚠  %s%s\n' "$RED" "$1" "$RESET"; }
die()  { printf '\n%s✗  %s%s\n' "$RED" "$1" "$RESET" >&2; exit 1; }
hdr()  { printf '\n%s%s══  %s  ══%s\n' "$GOLD" "$BOLD" "$1" "$RESET"; }

# ── Compute latency in ms ────────────────────────────────────────────────────
_latency_ms() {
    local buffer="$1" rate="$2"
    awk "BEGIN { printf \"%.2f\", ($buffer / $rate) * 1000 }"
}

# ── Write PipeWire RT config ─────────────────────────────────────────────────
_write_pipewire_conf() {
    local rate="$1" buffer="$2"
    mkdir -p "$PIPEWIRE_CONF_DIR"

    cat > "${PIPEWIRE_CONF_DIR}/selah-asio-rt.conf" << EOF
# SelahASIO v1 — PipeWire realtime audio config
# Generated by selah-asio-config on $(date -u +%Y-%m-%dT%H:%M:%SZ)
context.properties = {
    default.clock.rate          = ${rate}
    default.clock.quantum       = ${buffer}
    default.clock.min-quantum   = 32
    default.clock.max-quantum   = 2048
    log.level                   = 2
}
context.modules = [
    {   name = libpipewire-module-rt
        args = {
            nice.level  = -11
            rt.prio     = 88
            rt.time.soft = 2000000
            rt.time.hard = 2000000
        }
        flags = [ ifexists nofail ]
    }
]
EOF
    ok "PipeWire RT config written (${buffer} samples @ ${rate} Hz)"
}

# ── Write JACK compat config for Wine ───────────────────────────────────────
_write_jack_conf() {
    local rate="$1" buffer="$2"
    mkdir -p "$JACK_CONF_DIR"

    # pipewire-jack uses this to negotiate with Wine's ASIO request
    cat > "${JACK_CONF_DIR}/jack.conf" << EOF
jack.properties = {
    node.latency        = ${buffer}/${rate}
    node.rate           = 1/${rate}
    resample.quality    = 4
}
EOF
    ok "JACK compat config written"
}

# ── Register WineASIO DLL ────────────────────────────────────────────────────
_install_wineasio() {
    hdr "Registering WineASIO"

    [[ -d "$WINEPREFIX" ]] || {
        info "Initializing Wine prefix at $WINEPREFIX..."
        WINEPREFIX="$WINEPREFIX" wineboot --init &>/dev/null
    }

    # wineasio-register is the standard tool from AUR wineasio package
    if command -v wineasio-register &>/dev/null; then
        WINEPREFIX="$WINEPREFIX" wineasio-register && ok "wineasio-register succeeded"
    else
        # Fallback: manual regsvr32
        local dll32 dll64
        dll32="$(find /usr/lib32 /usr/lib -name "wineasio.dll.so" 2>/dev/null | head -1)"
        dll64="$(find /usr/lib   -name "wineasio.dll.so" 2>/dev/null | head -1)"

        [[ -n "$dll32" || -n "$dll64" ]] || die "wineasio.dll.so not found — install wineasio package"

        if [[ -n "$dll64" ]]; then
            WINEPREFIX="$WINEPREFIX" wine64 regsvr32 wineasio.dll && ok "Registered 64-bit WineASIO"
        fi
        if [[ -n "$dll32" ]]; then
            WINEPREFIX="$WINEPREFIX" wine regsvr32 wineasio.dll && ok "Registered 32-bit WineASIO"
        fi
    fi
}

# ── Auto-detect sample rate from running DAW ────────────────────────────────
_auto_detect() {
    hdr "Auto-detecting DAW sample rate"

    # Query PipeWire for current negotiated rate
    local pw_rate=""
    if command -v pw-metadata &>/dev/null; then
        pw_rate=$(pw-metadata -n settings 2>/dev/null \
            | grep -oP 'clock\.rate.*?value:\s*\K[0-9]+' | head -1)
    fi

    if [[ -n "$pw_rate" ]]; then
        ok "PipeWire negotiated rate: ${pw_rate} Hz"
        DETECTED_RATE="$pw_rate"
    else
        info "Cannot detect active rate — defaulting to 48000 Hz"
        DETECTED_RATE=48000
    fi

    # Query PipeWire for current quantum (buffer size)
    local pw_quantum=""
    if command -v pw-metadata &>/dev/null; then
        pw_quantum=$(pw-metadata -n settings 2>/dev/null \
            | grep -oP 'clock\.quantum.*?value:\s*\K[0-9]+' | head -1)
    fi

    if [[ -n "$pw_quantum" ]]; then
        ok "PipeWire negotiated quantum: ${pw_quantum} samples"
        DETECTED_BUFFER="$pw_quantum"
    else
        info "Cannot detect active quantum — defaulting to 256 samples"
        DETECTED_BUFFER=256
    fi

    printf '  %sDetected latency:%s %s%s ms%s\n' \
        "$MUTED" "$RESET" "$GOLD" \
        "$(_latency_ms "$DETECTED_BUFFER" "$DETECTED_RATE")" "$RESET"
}

# ── Benchmark mode ───────────────────────────────────────────────────────────
_benchmark() {
    hdr "SelahASIO Latency Benchmark"

    if ! command -v pw-jack &>/dev/null && ! command -v jack_iodelay &>/dev/null; then
        warn "Install jack_delay (jack-example-tools) for full benchmark"
        info "Showing PipeWire timing stats instead..."
        pw-top --no-color 2>/dev/null | head -20 || \
            info "pw-top not available — install pipewire-utils"
        return
    fi

    info "Running jack_iodelay round-trip measurement (5s)..."
    timeout 5 pw-jack jack_iodelay 2>/dev/null || \
        warn "Benchmark requires JACK loopback hardware or virtual patch"
    info "For accurate results: patch output→input in qpwgraph and re-run"
}

# ── Status display ───────────────────────────────────────────────────────────
_status() {
    hdr "SelahASIO v${VERSION} Status"

    # PipeWire running?
    if pidof pipewire &>/dev/null; then
        ok "PipeWire running"
        if command -v pw-cli &>/dev/null; then
            local ver
            ver=$(pw-cli --version 2>/dev/null | head -1 || echo "unknown")
            info "Version: $ver"
        fi
    else
        warn "PipeWire not running"
    fi

    # pipewire-jack installed?
    if ldconfig -p 2>/dev/null | grep -q libpipewire-0.3; then
        ok "pipewire-jack bridge available"
    else
        warn "pipewire-jack not found — install lib32-pipewire-jack pipewire-jack"
    fi

    # WineASIO registered?
    local asio_reg
    asio_reg=$(WINEPREFIX="$WINEPREFIX" wine64 regedit /E /dev/stdout \
        "HKEY_CLASSES_ROOT\\CLSID\\{48D0C522-BFCC-45CC-8B84-17F25F33E6E8}" \
        2>/dev/null | head -1 || true)
    if [[ -n "$asio_reg" ]]; then
        ok "WineASIO registered in WINEPREFIX"
    else
        warn "WineASIO not registered — run: selah-asio-config --install"
    fi

    # Config files
    local cfg="${PIPEWIRE_CONF_DIR}/selah-asio-rt.conf"
    if [[ -f "$cfg" ]]; then
        ok "RT config present: $cfg"
        local cur_buf cur_rate
        cur_buf=$(grep  "clock.quantum" "$cfg" | grep -oP '[0-9]+' | head -1)
        cur_rate=$(grep "clock.rate"    "$cfg" | grep -oP '[0-9]+' | head -1)
        if [[ -n "$cur_buf" && -n "$cur_rate" ]]; then
            printf '  %sCurrent latency target:%s %s%s ms%s (%s samples @ %s Hz)\n' \
                "$MUTED" "$RESET" "$GOLD" \
                "$(_latency_ms "$cur_buf" "$cur_rate")" \
                "$RESET" "$cur_buf" "$cur_rate"
        fi
    else
        warn "No RT config — run: selah-asio-config --buffer 256 --rate 48000"
    fi

    # Realtime privileges
    if grep -q "^@audio" /etc/security/limits.conf 2>/dev/null; then
        ok "Realtime limits configured (/etc/security/limits.conf)"
    else
        warn "No realtime limits — run: selahpro audio config"
    fi
}

# ── Argument parsing ─────────────────────────────────────────────────────────
RATE=48000
BUFFER=256
MODE="apply"

[[ $# -eq 0 ]] && { _status; exit 0; }

while [[ $# -gt 0 ]]; do
    case "$1" in
        --rate)    shift; RATE="$1";   shift ;;
        --buffer)  shift; BUFFER="$1"; shift ;;
        --status)  MODE="status";      shift ;;
        --install) MODE="install";     shift ;;
        --auto-detect) MODE="autodetect"; shift ;;
        --benchmark)   MODE="benchmark";  shift ;;
        --version) printf 'selah-asio-config %s\n' "$VERSION"; exit 0 ;;
        *) warn "Unknown option: $1"; shift ;;
    esac
done

case "$MODE" in
    apply)
        hdr "Configuring SelahASIO v${VERSION}"
        printf '  %sRate:%s   %s%s Hz%s\n'   "$MUTED" "$RESET" "$GOLD" "$RATE"   "$RESET"
        printf '  %sBuffer:%s %s%s samples%s\n' "$MUTED" "$RESET" "$GOLD" "$BUFFER" "$RESET"
        printf '  %sLatency:%s%s%s ms%s\n'   "$MUTED" "$RESET" "$GOLD" \
            "$(_latency_ms "$BUFFER" "$RATE")" "$RESET"
        _write_pipewire_conf "$RATE" "$BUFFER"
        _write_jack_conf     "$RATE" "$BUFFER"
        ok "SelahASIO configured. Restart PipeWire to apply."
        info "Restart: systemctl --user restart pipewire pipewire-pulse"
        ;;
    install)
        _install_wineasio
        _write_pipewire_conf "$RATE" "$BUFFER"
        _write_jack_conf     "$RATE" "$BUFFER"
        ok "SelahASIO installation complete"
        ;;
    status)      _status       ;;
    autodetect)  _auto_detect  ;;
    benchmark)   _benchmark    ;;
esac
