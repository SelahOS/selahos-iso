def run(cmd, **kw):
    return subprocess.run(cmd, capture_output=True, text=True, **kw)


def detect_live_usb():
    """Return the device backing the live ISO (to prevent installing to it)."""
    try:
        r = run(['findmnt', '-n', '-o', 'SOURCE', '/run/archiso/airootfs'])
        src = r.stdout.strip()
        if src:
            # strip partition number to get disk
            return re.sub(r'p?\d+$', '', src)
    except Exception:
        pass
    try:
        r = run(['lsblk', '-rno', 'NAME,MOUNTPOINT'])
        for line in r.stdout.splitlines():
            parts = line.split()
            if len(parts) >= 2 and 'archiso' in parts[1]:
                name = '/dev/' + re.sub(r'p?\d+$', '', parts[0])
                return name
    except Exception:
        pass
    return None


def get_disks():
    """Return list of dicts for all block devices suitable for installation."""
    live = detect_live_usb()
    result = run(['lsblk', '-dpno', 'NAME,SIZE,MODEL,TYPE,TRAN'])
    disks = []
    for line in result.stdout.strip().splitlines():
        parts = line.split(None, 4)
        if len(parts) < 2:
            continue
        name, size = parts[0], parts[1]
        model = parts[2] if len(parts) > 2 else ''
        tran  = parts[4].strip() if len(parts) > 4 else ''
        if name.startswith('/dev/loop') or name.startswith('/dev/sr'):
            continue
        # Skip small devices (< 8 GiB)
        if 'M' in size and not size.endswith('G'):
            continue
        is_live = (live and name == live)
        is_small = False
        try:
            num = float(re.sub(r'[^0-9.]', '', size))
            unit = re.sub(r'[0-9.]', '', size)
            if unit in ('G', 'GB') and num < 20:
                is_small = True
            if unit in ('M', 'MB'):
                is_small = True
        except Exception:
            pass
        disk_type = 'NVMe SSD' if 'nvme' in name else ('USB Drive' if tran == 'usb' else 'SSD/HDD')
        disks.append({
            'name': name, 'size': size, 'model': model.strip(),
            'type': disk_type, 'is_live': is_live, 'is_small': is_small,
        })
    return disks


def get_timezones():
    try:
        r = run(['timedatectl', 'list-timezones'])
        return r.stdout.strip().splitlines()
    except Exception:
        return ['UTC', 'America/New_York', 'America/Los_Angeles', 'Europe/London']


def detect_timezone():
    try:
        r = run(['timedatectl', 'show', '--property=Timezone', '--value'])
        tz = r.stdout.strip()
        if tz:
            return tz
    except Exception:
        pass
    return 'America/New_York'


def detect_hardware():
    info = {'manufacturer': '', 'product': '', 'cpu': '', 'gpu': '', 'ram': ''}
    try:
        info['manufacturer'] = run(['dmidecode', '-s', 'system-manufacturer']).stdout.strip()
        info['product']      = run(['dmidecode', '-s', 'system-product-name']).stdout.strip()
    except Exception:
        pass
    try:
        for line in run(['lscpu']).stdout.splitlines():
            if 'Model name' in line:
                info['cpu'] = line.split(':', 1)[1].strip()
                break
    except Exception:
        pass
    try:
        for line in run(['lspci']).stdout.splitlines():
            if 'VGA' in line or 'Display' in line or '3D' in line:
                info['gpu'] = line.split(':', 2)[-1].strip()
                break
    except Exception:
        pass
    try:
        for line in run(['free', '-h']).stdout.splitlines():
            if line.startswith('Mem'):
                info['ram'] = line.split()[1]
                break
    except Exception:
        pass
    return info


def glass_frame(parent=None, radius=18):
    f = QFrame(parent)
    f.setStyleSheet(
        f"QFrame {{ background: rgba(42,48,66,0.85); "
        f"border: 1px solid rgba(230,194,122,0.15); "
        f"border-radius: {radius}px; }}"
    )
    return f


def gold_label(text, size=14, weight=QFont.Weight.Normal):
    lbl = QLabel(text)
    lbl.setFont(QFont('Inter', size, weight))
    lbl.setStyleSheet(f"color: {C['gold_lt']}; background: transparent;")
    return lbl


def muted_label(text, size=13):
    lbl = QLabel(text)
    lbl.setFont(QFont('Inter', size))
    lbl.setStyleSheet(f"color: {C['muted']}; background: transparent;")
    return lbl


def separator():
    line = QFrame()
    line.setFixedHeight(1)
    line.setStyleSheet(f"background: rgba(230,194,122,0.12); border: none;")
    return line


