class SlideWidget(QWidget):
    """A single installer slide with branding and text."""

    def __init__(self, slide_data, parent=None):
        super().__init__(parent)
        self.slide = slide_data
        self.setMinimumHeight(300)
        self._build()

    def _build(self):
        layout = QVBoxLayout(self)
        layout.setContentsMargins(60, 50, 60, 50)
        layout.setSpacing(20)
        layout.setAlignment(Qt.AlignmentFlag.AlignVCenter)

        # Accent line
        accent = QFrame()
        accent.setFixedHeight(3)
        accent.setStyleSheet(f"background: {self.slide['accent']}; border: none; border-radius: 2px;")
        layout.addWidget(accent)

        layout.addSpacing(20)

        # Title
        title = QLabel(self.slide['title'])
        title.setFont(QFont('Noto Sans', 34, QFont.Weight.Light))
        title.setStyleSheet(f"color: {COLORS['parch']}; background: transparent;")
        layout.addWidget(title)

        # Subtitle
        subtitle = QLabel(self.slide['subtitle'])
        subtitle.setFont(QFont('Noto Sans', 16))
        subtitle.setStyleSheet(f"color: {self.slide['accent']}; font-style: italic; background: transparent;")
        layout.addWidget(subtitle)

        layout.addSpacing(16)

        # Body
        body = QLabel(self.slide['body'])
        body.setFont(QFont('Noto Sans', 14))
        body.setStyleSheet(f"color: {COLORS['muted']}; line-height: 1.8; background: transparent;")
        body.setWordWrap(True)
        layout.addWidget(body)

        layout.addStretch()


