################################################################################
################# SelahOS Default Mirrorlist ###################################
# Baked into ISO — ensures pacman works immediately in live environment
# without requiring network mirror refresh
################################################################################

# Worldwide CDN (fastest for most users)
Server = https://geo.mirror.pkgbuild.com/$repo/os/$arch

# United States
Server = https://mirror.rackspace.com/archlinux/$repo/os/$arch
Server = https://mirrors.kernel.org/archlinux/$repo/os/$arch
Server = https://mirror.us.leaseweb.net/archlinux/$repo/os/$arch
Server = https://mirrors.mit.edu/archlinux/$repo/os/$arch

# Additional reliable mirrors
Server = https://archive.archlinux.org/$repo/os/$arch
Server = https://mirror.cyberbits.eu/archlinux/$repo/os/$arch
Server = https://ftp.halifax.rwth-aachen.de/archlinux/$repo/os/$arch
