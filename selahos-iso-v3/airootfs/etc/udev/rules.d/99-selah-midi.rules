# ═══════════════════════════════════════════════════════════════
#  SelahBridgePro — USB MIDI Passthrough Rules
#  Selah Technologies LLC — Copyright (C) 2026
#
#  Grants audio group + seat-local (uaccess) access to USB MIDI
#  devices.  udev reloads automatically on ISO/package install.
#  To reload manually: sudo udevadm control --reload-rules
#                      sudo udevadm trigger --subsystem-match=usb
# ═══════════════════════════════════════════════════════════════

# ── Akai MPK mini IV (PID:005d, confirmed hardware) ─────────────
SUBSYSTEM=="usb", ATTRS{idVendor}=="09e8", ATTRS{idProduct}=="005d", \
  TAG+="uaccess", GROUP="audio", MODE="0664", \
  SYMLINK+="selah-midi/akai-mpk-mini-iv"

SUBSYSTEM=="sound", ATTRS{idVendor}=="09e8", ATTRS{idProduct}=="005d", \
  GROUP="audio", MODE="0664", TAG+="uaccess"

# ── Akai MPK mini Mk II (PID:0045) — older hardware ─────────────
SUBSYSTEM=="usb", ATTRS{idVendor}=="09e8", ATTRS{idProduct}=="0045", \
  TAG+="uaccess", GROUP="audio", MODE="0664", \
  SYMLINK+="selah-midi/akai-mpk-mini-mk2"

SUBSYSTEM=="sound", ATTRS{idVendor}=="09e8", ATTRS{idProduct}=="0045", \
  GROUP="audio", MODE="0664", TAG+="uaccess"

# ── Akai MPC Studio 2 (VID:09e8 PID:004a) ──────────────────────
SUBSYSTEM=="usb", ATTRS{idVendor}=="09e8", ATTRS{idProduct}=="004a", \
  TAG+="uaccess", GROUP="audio", MODE="0664", \
  SYMLINK+="selah-midi/akai-mpc-studio2"

SUBSYSTEM=="sound", ATTRS{idVendor}=="09e8", ATTRS{idProduct}=="004a", \
  GROUP="audio", MODE="0664", TAG+="uaccess"

# HID interface — grants display + RGB LED access to Wine and selah-mpc-bridge
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="09e8", ATTRS{idProduct}=="004a", \
  TAG+="uaccess", GROUP="audio", MODE="0664", \
  SYMLINK+="selah-mpc-hid"

# ── Akai MPC Studio 2 legacy (VID:09e8 PID:0076) ────────────────
SUBSYSTEM=="usb", ATTRS{idVendor}=="09e8", ATTRS{idProduct}=="0076", \
  TAG+="uaccess", GROUP="audio", MODE="0664", \
  SYMLINK+="selah-midi/akai-mpc-studio2-legacy"

SUBSYSTEM=="sound", ATTRS{idVendor}=="09e8", ATTRS{idProduct}=="0076", \
  GROUP="audio", MODE="0664", TAG+="uaccess"

# ── Generic USB MIDI class devices ──────────────────────────────
# USB Audio class (bDeviceClass=0x00, interface class=0x01,
# subclass=0x03 = MIDI Streaming).  Matches any class-compliant
# USB MIDI controller not listed above.
SUBSYSTEM=="usb", ENV{ID_USB_INTERFACES}=="*:010300:*", \
  TAG+="uaccess", GROUP="audio", MODE="0664", \
  SYMLINK+="selah-midi/usb-midi-%k"

# ── ALSA raw MIDI nodes ─────────────────────────────────────────
SUBSYSTEM=="sound", KERNEL=="midiC[0-9]D[0-9]", \
  GROUP="audio", MODE="0664", TAG+="uaccess"

# ── ALSA sequencer nodes ────────────────────────────────────────
SUBSYSTEM=="sound", KERNEL=="seq", \
  GROUP="audio", MODE="0664", TAG+="uaccess"

SUBSYSTEM=="sound", KERNEL=="timer", \
  GROUP="audio", MODE="0664", TAG+="uaccess"

# ── SysEx / HID passthrough for all other Akai devices ──────────
# Catch-all for any Akai hidraw interface not matched above
# (covers legacy PIDs and future devices).
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="09e8", \
  TAG+="uaccess", GROUP="audio", MODE="0664"
